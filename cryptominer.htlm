// ── TUTO ──
let tutoStep = 0;
function startTuto() {
  tutoStep = 0;
  const L = LANGS[currentLang];
  const steps = L.tutoSteps;
  // Build dots
  const dotsEl = document.getElementById('tuto-dots');
  if (dotsEl) dotsEl.innerHTML = steps.map((_,i) =>
    `<div class="tuto-dot" id="td-${i}"></div>`
  ).join('');
  showTutoStep(0);
}

const TUTO_TARGETS = [null, 'tab-upg', 'tab-auto', 'tab-market', 'tab-ach', 'tab-skins', null, null];

function showTutoStep(idx) {
  const L = LANGS[currentLang];
  const steps = L.tutoSteps;
  if (idx >= steps.length) { skipTuto(); return; }
  const step = steps[idx];

  // Barre de progression
  const pct = Math.round((idx / (steps.length-1)) * 100);
  const progFill = document.getElementById('tuto-prog-fill');
  if (progFill) progFill.style.width = pct + '%';

  // Dots (active + done)
  steps.forEach((_,i) => {
    const d = document.getElementById('td-'+i);
    if (!d) return;
    if (i < idx)       d.className = 'tuto-dot done';
    else if (i === idx) d.className = 'tuto-dot active';
    else               d.className = 'tuto-dot';
  });

  document.getElementById('tuto-step-lbl').textContent = `${idx+1} / ${steps.length}`;
  document.getElementById('tuto-icon').textContent  = step.icon;
  document.getElementById('tuto-title').textContent = step.title;
  document.getElementById('tuto-body').textContent  = step.body;

  const tipEl = document.getElementById('tuto-tip');
  if (step.tip) {
    tipEl.style.display = 'flex';
    tipEl.textContent = step.tip;
  } else {
    tipEl.style.display = 'none';
  }

  const nextBtn = document.getElementById('tuto-next-btn');
  const tutoNextLabels = { fr:'Suivant →', en:'Next →', es:'Siguiente →', ar:'التالي →', pt:'Seguinte →' };
  const tutoLastLabels = { fr:'🎮 Go !', en:'🎮 Go!', es:'🎮 ¡Vamos!', ar:'🎮 انطلق!', pt:'🎮 Vamos!' };
  nextBtn.textContent = idx === steps.length-1 ? (tutoLastLabels[currentLang]||'🎮 Go!') : (tutoNextLabels[currentLang]||'Next →');
  document.getElementById('tuto-skip-btn').textContent = L.tutoSkip;

  // Elements
  const overlay   = document.getElementById('tuto-overlay');
  const spotlight = document.getElementById('tuto-spotlight');
  const arrow     = document.getElementById('tuto-arrow');
  const card      = document.getElementById('tuto-card');

  overlay.classList.add('active');
  card.classList.remove('show');
  // Petit délai pour l'animation d'entrée
  requestAnimationFrame(() => { requestAnimationFrame(() => { card.classList.add('show'); }); });

  const targetId = TUTO_TARGETS[idx] || null;
  if (targetId) {
    const el = document.getElementById(targetId);
    if (el) {
      const r = el.getBoundingClientRect(), pad = 7;
      spotlight.style.display = 'block';
      spotlight.style.left   = (r.left - pad)+'px';
      spotlight.style.top    = (r.top - pad)+'px';
      spotlight.style.width  = (r.width + pad*2)+'px';
      spotlight.style.height = (r.height + pad*2)+'px';
      posCard(card, r);
      posArrow(arrow, r, card);
    }
  } else {
    spotlight.style.display = 'none';
    if (arrow) arrow.style.display = 'none';
    centerCard(card);
  }
}

function posCard(card, r) {
  const cw = 296, ch = 280, vw = window.innerWidth, vh = window.innerHeight;
  let left, top;

  // Essayer à droite
  if (r.right + cw + 18 < vw) {
    left = r.right + 14;
    top  = Math.max(8, Math.min(r.top - 20, vh - ch - 8));
  }
  // Sinon à gauche
  else if (r.left - cw - 18 > 0) {
    left = r.left - cw - 14;
    top  = Math.max(8, Math.min(r.top - 20, vh - ch - 8));
  }
  // Sinon en bas
  else {
    left = Math.max(8, Math.min(r.left, vw - cw - 8));
    top  = Math.min(r.bottom + 14, vh - ch - 8);
  }

  card.style.left = left+'px';
  card.style.top  = top+'px';
  card.style.transform = 'none';
  card.style.right = 'auto';
  card.style.bottom = 'auto';
}

function posArrow(arrow, targetRect, card) {
  if (!arrow) return;
  const cardRect = card.getBoundingClientRect();
  const cx = parseFloat(card.style.left) + 148; // centre card
  const cy = parseFloat(card.style.top) + 30;
  const tx = targetRect.left + targetRect.width/2;
  const ty = targetRect.top + targetRect.height/2;

  // Calcul de l'angle
  const dx = tx - cx, dy = ty - cy;
  const angle = Math.atan2(dy, dx) * 180 / Math.PI;

  // Positionner entre la card et la cible
  const mx = (cx + tx) / 2 - 13;
  const my = (cy + ty) / 2 - 13;

  arrow.style.display = 'block';
  arrow.style.left    = mx + 'px';
  arrow.style.top     = my + 'px';
  arrow.style.setProperty('--rot', angle + 'deg');
  arrow.style.setProperty('--dx', (dx > 0 ? '10px' : '-10px'));
}

function centerCard(card) {
  card.style.left = '50%'; card.style.top = '50%';
  card.style.transform = 'translate(-50%, -50%)';
  card.style.right = 'auto'; card.style.bottom = 'auto';
}
function tutoNext() {
  tutoStep++;
  const L = LANGS[currentLang];
  if (tutoStep >= L.tutoSteps.length) skipTuto();
  else showTutoStep(tutoStep);
}
function skipTuto() {
  document.getElementById('tuto-overlay')?.classList.remove('active');
  document.getElementById('tuto-spotlight').style.display='none';
  document.getElementById('tuto-card')?.classList.remove('show');
  localStorage.setItem('cm_tuto_done','1');
}

// ── DON ──
function openDon() { document.getElementById('don-overlay')?.classList.remove('hidden'); }
function closeDon() {
  document.getElementById('don-overlay')?.classList.add('hidden');
  // Replanifier dans 30 min après fermeture
  clearTimeout(_donTimer);
  _donTimer = setTimeout(openDon, 30 * 60 * 1000);
}

// Afficher le don toutes les 30 min (première fois après 30 min de jeu)
let _donTimer = setTimeout(openDon, 30 * 60 * 1000);

