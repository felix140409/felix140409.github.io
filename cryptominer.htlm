<!-- PARAMÈTRES -->
<div class="settings-overlay hidden" id="settings-overlay">
  <div class="settings-box">

    <!-- Titre fixe -->
    <div class="settings-title">
      <span id="settings-title">⚙ PARAMÈTRES</span>
      <button class="settings-close" onclick="toggleSettings()">✕</button>
    </div>

    <!-- Corps scrollable -->
    <div class="settings-body">

      <!-- LANGUE (en haut) -->
      <div class="settings-section-title" id="lang-settings-label">🌍 LANGUE</div>
      <div class="lang-picker-wrap" id="lang-picker">
        <button class="lang-pick-btn active" id="lbtn-fr" onclick="changeLang('fr')">
          <span class="lp-flag">🇫🇷</span><span class="lp-name">FRANÇAIS</span>
        </button>
        <button class="lang-pick-btn" id="lbtn-en" onclick="changeLang('en')">
          <span class="lp-flag">🇬🇧</span><span class="lp-name">ENGLISH</span>
        </button>
        <button class="lang-pick-btn" id="lbtn-es" onclick="changeLang('es')">
          <span class="lp-flag">🇪🇸</span><span class="lp-name">ESPAÑOL</span>
        </button>
        <button class="lang-pick-btn" id="lbtn-ar" onclick="changeLang('ar')">
          <span class="lp-flag">🇸🇦</span><span class="lp-name">عربية</span>
        </button>
        <button class="lang-pick-btn" id="lbtn-pt" onclick="changeLang('pt')">
          <span class="lp-flag">🇧🇷</span><span class="lp-name">PORTUGUÊS</span>
        </button>
      </div>

      <!-- THÈME (en dessous langue) -->
      <div class="settings-section-title" id="theme-section-title">🎨 THÈME</div>
      <div class="theme-picker-wrap">
        <div class="theme-pick-card active" id="tcard-night" onclick="selectTheme('night')">
          <div class="t-dot"></div>
          <span class="t-icon">🌙</span>
          <span class="t-name" id="tname-night">NUIT</span>
        </div>
      </div>

      <!-- OPTIONS -->
      <div class="settings-section-title">⚙ OPTIONS</div>
      <div class="settings-row">
        <span class="settings-label"><span id="sound-label">🔊 Sons</span></span>
        <button class="toggle-btn on" id="toggle-sound" onclick="toggleOpt('sound')"></button>
      </div>
      <div class="settings-row">
        <span class="settings-label"><span id="anim-label">✨ Animations flottantes</span></span>
        <button class="toggle-btn on" id="toggle-anim" onclick="toggleOpt('anim')"></button>
      </div>
      <div class="settings-row">
        <span class="settings-label"><span id="vibro-label">📳 Vibration (mobile)</span></span>
        <button class="toggle-btn on" id="toggle-vibro" onclick="toggleOpt('vibro')"></button>
      </div>
      <div class="settings-row">
        <span class="settings-label" id="scale-label">🔍 Taille de l'interface</span>
        <div style="display:flex;align-items:center;gap:8px">
          <button onclick="changeScale(-0.05)" style="width:26px;height:26px;border-radius:6px;background:#111B2E;border:1px solid #1A2840;color:#8899BB;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center">−</button>
          <span id="scale-val" style="font-size:10px;color:var(--skin-accent);min-width:36px;text-align:center;font-family:'Space Mono',monospace">100%</span>
          <button onclick="changeScale(+0.05)" style="width:26px;height:26px;border-radius:6px;background:#111B2E;border:1px solid #1A2840;color:#8899BB;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center">+</button>
        </div>
      </div>

      <!-- DONNÉES -->
      <div class="settings-section-title">💾 DONNÉES</div>
      <div class="settings-row">
        <span class="settings-label" style="color:#FF4560" id="settings-reset-label">⚠️ Réinitialiser la partie</span>
        <button class="btn-danger" id="reset-label" onclick="resetGame()">RESET</button>
      </div>
      <div style="display:flex;gap:6px;width:100%;margin-top:8px">
        <button class="btn-cancel" style="flex:1" onclick="exportSave()" id="btn-export">📤 Exporter</button>
        <button class="btn-cancel" style="flex:1" onclick="importSave()" id="btn-import">📥 Importer</button>
      </div>
      <div class="confirm-box hidden" id="confirm-box" style="margin-top:10px">
        <div class="confirm-msg" id="confirm-msg-text">Toute ta progression sera perdue.<br>Tu es sûr ?</div>
        <div class="confirm-btns">
          <button class="btn-cancel" onclick="cancelReset()" id="btn-reset-cancel">Annuler</button>
          <button class="btn-danger" onclick="doReset()" id="btn-reset-yes">Oui, reset !</button>
        </div>
      </div>

    </div><!-- /settings-body -->
  </div>
</div>

