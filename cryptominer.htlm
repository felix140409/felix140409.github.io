// currentLang declared in intro script

// ── APPLIQUER LA LANGUE ──
function applyLang(code) {
  currentLang = code;
  const L = LANGS[code];
  if (!L) return;

  document.body.dir = code === 'ar' ? 'rtl' : 'ltr';

  const set = (id, val) => { const el = document.getElementById(id); if (el && val !== undefined) el.textContent = val; };

  // Header
  set('btc-label',  L.btcLabel);
  set('mine-label', L.mineLabel);

  // Onglets
  set('tab-upg',    L.tabUpg);
  set('tab-auto',   L.tabBots);
  set('tab-market', L.tabMarket);
  set('tab-stats',  L.tabStats);
  set('tab-ach',    L.tabAch);
  set('tab-skins',  L.tabSkins);
  set('tab-shop',   L.tabShop);

  // Sections
  set('sec-click-label', L.secClickLabel);
  set('sec-bot-label',   L.secBotLabel);

  // Marché
  set('market-label', L.miseLabel);
  const maxB = document.getElementById('btn-max'); if (maxB) maxB.textContent = L.maxBtn;
  set('diff-facile-name',    L.facile);
  set('diff-normal-name',    L.normal);
  set('diff-difficile-name', L.difficile);
  set('diff-impossible-name',L.impossible);
  document.querySelectorAll('.diff-example').forEach(el => { el.textContent = L.enterBet; });
  document.querySelectorAll('.diff-gain').forEach(el => { el.textContent = L.gainLabel; });
  document.querySelectorAll('.diff-lose').forEach(el => { el.textContent = L.loseLabel; });

  // Stats
  set('stat-title',           L.statTitle);
  set('stat-total-mine',      L.sTotalMine);
  set('stat-clics',           L.sClics);
  set('stat-btc-clic',        L.sBtcClic);
  set('stat-auto-clic',       L.sAutoClic);
  set('stat-bets-won',        L.sBetsWon);
  set('stat-bets-lost',       L.sBetsLost);
  set('stat-won-mkt',         L.sWonMkt);
  set('stat-lost-mkt',        L.sLostMkt);
  set('stat-trophies-label',  L.sTrophies);
  set('stat-skins-label',     L.sSkins);

  // Chart legend
  const legBull = document.getElementById('chart-leg-bull');
  const legBear = document.getElementById('chart-leg-bear');
  const legWick = document.getElementById('chart-leg-wick');
  if (legBull) legBull.textContent = L.chartBull || 'Bullish';
  if (legBear) legBear.textContent = L.chartBear || 'Bearish';
  if (legWick) legWick.textContent = L.chartWick || 'Wick';
  const chartLabel = document.getElementById('chart-label-btc');
  if (chartLabel) chartLabel.textContent = L.chartLabel || '📊 BTC BALANCE — LIVE CHART';

  // Session stats labels
  const sessTime  = document.getElementById('sess-label-time');
  const sessRate  = document.getElementById('sess-label-rate');
  const sessEvts  = document.getElementById('sess-label-events');
  const statTitle2 = document.getElementById('stat-title-2');
  const renaSection = document.getElementById('stats-rena-section');
  if (sessTime) sessTime.textContent  = L.sessLabelTime  || '⏱ SESSION TIME';
  if (sessRate) sessRate.textContent  = L.sessLabelRate  || '⚡ CURRENT BTC/MIN';
  if (sessEvts) sessEvts.textContent  = L.sessLabelEvents|| '🎲 EVENTS';
  if (statTitle2) statTitle2.textContent = L.statTitle2  || '📈 TOTALS';
  // Renaissance leaderboard title
  const renaTitle = renaSection && renaSection.querySelector('div');
  if (renaTitle) renaTitle.textContent = L.renaLeaderTitle || '♾ RENAISSANCE LEADERBOARD';

  // Battle overlay (static HTML in French by default)
  const battleDesc2 = document.getElementById('battle-desc');
  if (battleDesc2 && L.battleDesc) battleDesc2.textContent = L.battleDesc;
  const battleReward2 = document.getElementById('battle-reward');
  const battleHint2 = document.getElementById('battle-hint');
  if (battleHint2 && L.battleHint) battleHint2.textContent = L.battleHint;

  // Wheel overlay
  const wheelTitle2 = document.getElementById('wheel-title');
  const wheelSub2 = document.getElementById('wheel-subtitle');
  const wheelSpinBtn = document.getElementById('wheel-spin-btn');
  if (wheelTitle2 && L.wheelTitle) wheelTitle2.textContent = L.wheelTitle;
  if (wheelSub2 && L.wheelSubtitle) wheelSub2.textContent = L.wheelSubtitle;
  if (wheelSpinBtn && L.wheelSpin) wheelSpinBtn.textContent = L.wheelSpin;

  // Headers
  set('trophy-header', L.trophyHeader);
  set('skin-header',   L.skinHeader);

  // Paramètres
  set('sound-label',  L.soundLabel);
  set('anim-label',   L.animLabel);
  set('vibro-label',  L.vibroLabel);
  set('reset-label',  L.resetLabel);
  set('next-trophy-label', L.nextTrophy);
  set('lang-settings-label', L.langSettingsLabel);

  // Prestige bar
  set('prest-title',   L.prestTitle);
  set('prest-box-title', L.prestTitle);
  set('sess-label-best', L.bestHalving || '🏆 MEILLEURE RENAISSANCE');
  const cancelEl = document.getElementById('prest-cancel-btn');
  if (cancelEl) cancelEl.textContent = L.prestCancel;
  const halvBtn = document.getElementById('prest-halv-btn');
  if (halvBtn) halvBtn.textContent = L.halvingBtn;

  // Don
  set('don-title', L.donTitle);
  const donText = document.getElementById('don-text');
  if (donText) donText.textContent = L.donText;
  set('don-close-btn', L.donClose);

  // Tuto
  set('tuto-skip-btn', L.tutoSkip);

  // Titre paramètres
  set('settings-title', L.settingsTitle);
  // Section thème
  const tst = document.getElementById('theme-section-title');
  if (tst) tst.textContent = L.themeSection || '🎨 THÈME';
  if (typeof updateThemeCards === 'function') updateThemeCards();
  if (typeof updateLangPicker === 'function') updateLangPicker(code);

  // ── Textes statiques HTML traduits ──
  const si = document.getElementById('save-indicator');
  if (si) si.textContent = L.saveIndicator || '✓ SAVED';
  const confirmMsg = document.getElementById('confirm-msg-text');
  if (confirmMsg) confirmMsg.innerHTML = L.confirmBoxMsg || (L.resetConfirmMsg || 'All progress will be lost.<br>Are you sure?');
  const btnCancel = document.getElementById('btn-reset-cancel');
  if (btnCancel) btnCancel.textContent = L.resetCancelBtn || L.resetNo || 'Cancel';
  const btnYes = document.getElementById('btn-reset-yes');
  if (btnYes) btnYes.textContent = L.resetYesBtn || L.resetYes || 'Yes, reset!';
  const btnExport = document.getElementById('btn-export');
  if (btnExport) btnExport.textContent = L.exportBtn || '📤 Export';
  const btnImport = document.getElementById('btn-import');
  if (btnImport) btnImport.textContent = L.importBtn || '📥 Import';
  const scaleLbl = document.getElementById('scale-label');
  if (scaleLbl) scaleLbl.textContent = L.scaleLabel || '🔍 Interface size';
  const resetLbl = document.getElementById('settings-reset-label');
  if (resetLbl) resetLbl.textContent = L.resetSettingsLabel || L.resetLabel || '⚠️ Reset game';
  set('sess-label-best', L.bestHalving || '🏆 BEST RENAISSANCE');

  // Bouton HALVINGUER
  const halvBtn2 = document.getElementById('prest-halv-btn');
  if (halvBtn2) halvBtn2.textContent = L.halvingBtn;
  // Le bouton halving dans la barre prestige n'a pas d'id, on le cherche autrement
  const halvConfirm = document.querySelector('.prest-btn-confirm');
  if (halvConfirm) halvConfirm.textContent = L.halvingBtn;

  // Battle : bouton Fuir + label MINER
  const fleeBtn = document.getElementById('battle-flee-btn');
  if (fleeBtn) fleeBtn.textContent = L.battleFlee;
  const clickLabel = document.getElementById('battle-click-label');
  if (clickLabel) clickLabel.textContent = L.mineLabel;

  // Bouton SABOTER (si pas en cooldown)
  const sabBtn = document.getElementById('rival-sabotage-btn');
  if (sabBtn && !sabBtn.disabled) sabBtn.textContent = L.rivalSabotage;

  // Chart panel labels
  const crbAll = document.getElementById('crb-all');
  if (crbAll) crbAll.textContent = L.chartAll || 'All';
  const cStatTotal = document.getElementById('chart-stat-lbl-total');
  const cStatRate  = document.getElementById('chart-stat-lbl-rate');
  const cStatClick = document.getElementById('chart-stat-lbl-click');
  const cStatBot   = document.getElementById('chart-stat-lbl-bot');
  const cBreakdown = document.getElementById('chart-breakdown-title');
  const cLblClicks = document.getElementById('chart-lbl-clicks');
  const cLblBots   = document.getElementById('chart-lbl-bots');
  if (cStatTotal) cStatTotal.textContent = L.chartStatTotal || '₿ TOTAL MINED';
  if (cStatRate)  cStatRate.textContent  = L.chartStatRate  || '⚡ RATE / MIN';
  if (cStatClick) cStatClick.textContent = L.chartStatClick || '👆 BTC / CLICK';
  if (cStatBot)   cStatBot.textContent   = L.chartStatBot   || '🤖 BTC / SEC (BOTS)';
  if (cBreakdown) cBreakdown.textContent = L.chartBreakdown || 'INCOME BREAKDOWN';
  if (cLblClicks) cLblClicks.textContent = L.chartLblClicks || '👆 Clicks';
  if (cLblBots)   cLblBots.textContent   = L.chartLblBots   || '🤖 Bots';
  const tabChartEl = document.getElementById('tab-chart');
  if (tabChartEl) tabChartEl.textContent = L.tabChart || '📊 CHART';

  // Rival status initial text
  const rivalStatusEl = document.getElementById('rival-status');
  if (rivalStatusEl && !rivalStatusEl.style.display) {
    rivalStatusEl.textContent = L.rivalSilent || 'Mining in silence...';
  }
  const lblYou  = document.getElementById('battle-lbl-you');
  const lblThem = document.getElementById('battle-lbl-them');
  if (lblYou)  lblYou.textContent  = L.battleYou  || 'YOU';
  if (lblThem) lblThem.textContent = L.battleThem  || 'THEM';
  // Rival bar labels
  const rLblYou  = document.getElementById('rival-lbl-you');
  const rLblThem = document.getElementById('rival-lbl-them');
  if (rLblYou)  rLblYou.textContent  = L.battleYou  || 'YOU';
  if (rLblThem) rLblThem.textContent = L.battleThem  || 'THEM';

  // Shop panel header + desc
  const shopLabel = document.getElementById('sec-shop-label');
  const shopDesc  = document.getElementById('shop-desc');
  if (shopLabel) shopLabel.textContent = L.shopSectionLabel || '♾️ RENAISSANCE SHOP';
  if (shopDesc)  shopDesc.innerHTML    = L.shopSectionDesc  || '🎁 Reach a Renaissance milestone to unlock a permanent reward.<br>Bonuses survive every reset — they accumulate forever.';

  // Mise à jour de l'affichage
  updateDisplay();
  updateLangButtons();
  updateShopTab();
  applyShopBonuses();
  applyShopClickBonus();
  // Rebuild les listes avec les nouveaux noms traduits
  document.getElementById('upg-list').innerHTML='';
  document.getElementById('auto-list').innerHTML='';
  buildUpgrades();
  buildAutoList();
  buildAchList();
  buildShopList();
  // Init objectifs après que tout soit déclaré
  setTimeout(() => { pickObjectives(); setInterval(() => buildObjectives(), 5000); }, 0);
  updateRenaissanceLeaderboard();
}

