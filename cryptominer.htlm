<!-- PANEL MARCHÉ -->
<div class="panel hidden" id="panel-market">
  <div class="market-input-row">
    <span class="market-label" id="market-label">MISE</span>
    <input class="market-input" id="market-amount" type="number" min="1" placeholder="Montant…" oninput="updateExamples()"/>
    <span class="market-currency">BTC</span>
    <button class="btn-max" id="btn-max" onclick="setMax()">MAX</button>
  </div>
  <div class="diff-grid">
    <div class="diff-card" id="diff-facile" onclick="play('facile')">
      <div class="diff-name"><span id="diff-facile-name">😊 FACILE</span></div>
      <div class="diff-stats"><div class="diff-stat win">✅ Gain <strong>×1.4</strong></div><div class="diff-stat lose">❌ Perd la mise</div></div>
      <div class="diff-chance">75% de chance</div>
      <div class="diff-example" id="ex-facile">Entrez une mise</div>
      <div class="diff-cooldown-label" id="cd-facile"></div>
      <div class="diff-cooldown-bar" id="bar-facile" style="width:0%"></div>
    </div>
    <div class="diff-card" id="diff-normal" onclick="play('normal')">
      <div class="diff-name"><span id="diff-normal-name">😐 NORMAL</span></div>
      <div class="diff-stats"><div class="diff-stat win">✅ Gain <strong>×2</strong></div><div class="diff-stat lose">❌ Perd la mise</div></div>
      <div class="diff-chance">35% de chance</div>
      <div class="diff-example" id="ex-normal">Entrez une mise</div>
      <div class="diff-cooldown-label" id="cd-normal"></div>
      <div class="diff-cooldown-bar" id="bar-normal" style="width:0%"></div>
    </div>
    <div class="diff-card" id="diff-difficile" onclick="play('difficile')">
      <div class="diff-name"><span id="diff-difficile-name">😤 DIFFICILE</span></div>
      <div class="diff-stats"><div class="diff-stat win">✅ Gain <strong>×3</strong></div><div class="diff-stat lose">❌ Perd la mise</div></div>
      <div class="diff-chance">15% de chance</div>
      <div class="diff-example" id="ex-difficile">Entrez une mise</div>
      <div class="diff-cooldown-label" id="cd-difficile"></div>
      <div class="diff-cooldown-bar" id="bar-difficile" style="width:0%"></div>
    </div>
    <div class="diff-card diff-impossible" id="diff-impossible" onclick="play('impossible')">
      <div class="diff-name"><span id="diff-impossible-name">💀 IMPOSSIBLE</span></div>
      <div class="diff-stats"><div class="diff-stat win">✅ Gain <strong>×8</strong></div><div class="diff-stat lose">❌ Perd la mise</div></div>
      <div class="diff-chance">1% de chance</div>
      <div class="diff-example" id="ex-impossible">Entrez une mise</div>
      <div class="diff-cooldown-label" id="cd-impossible"></div>
      <div class="diff-cooldown-bar" id="bar-impossible" style="width:0%"></div>
    </div>
  </div>
  <div class="market-result hidden" id="market-result">
    <span id="result-icon">🎉</span><span id="result-text"></span>
  </div>
</div>

<!-- PANEL CHART -->
<div class="panel hidden" id="panel-chart">
  <div class="section-title"><span id="chart-panel-title">📊 BTC BALANCE — HISTORIQUE</span></div>

  <!-- Sélecteur de période -->
  <div style="display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap">
    <button class="chart-range-btn active" id="crb-5m"  onclick="setChartRange('5m')">5 min</button>
    <button class="chart-range-btn"        id="crb-15m" onclick="setChartRange('15m')">15 min</button>
    <button class="chart-range-btn"        id="crb-30m" onclick="setChartRange('30m')">30 min</button>
    <button class="chart-range-btn"        id="crb-1h"  onclick="setChartRange('1h')">1 h</button>
    <button class="chart-range-btn"        id="crb-all" onclick="setChartRange('all')">Tout</button>
  </div>

  <!-- Graphique principal courbe BTC -->
  <div style="position:relative;width:100%;height:160px;background:rgba(13,20,32,.6);border:1px solid #111B2E;border-radius:8px;overflow:hidden;margin-bottom:10px">
    <canvas id="btc-history-canvas" style="width:100%;height:100%"></canvas>
    <div id="btc-chart-tooltip" style="position:absolute;top:6px;right:8px;font-size:8px;font-family:'Space Mono',monospace;color:#F7931A;pointer-events:none;text-align:right;line-height:1.6"></div>
  </div>

  <!-- Stats live -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:10px">
    <div style="background:rgba(13,20,32,.6);border:1px solid #111B2E;border-radius:8px;padding:8px 10px">
      <div style="font-size:7px;color:#445577;letter-spacing:.1em;margin-bottom:3px" id="chart-stat-lbl-total">₿ TOTAL MINÉ</div>
      <div style="font-size:14px;font-weight:700;color:#F7931A;font-family:'Space Mono',monospace" id="chart-stat-total">0</div>
    </div>
    <div style="background:rgba(13,20,32,.6);border:1px solid #111B2E;border-radius:8px;padding:8px 10px">
      <div style="font-size:7px;color:#445577;letter-spacing:.1em;margin-bottom:3px" id="chart-stat-lbl-rate">⚡ TAUX / MIN</div>
      <div style="font-size:14px;font-weight:700;color:#00D97E;font-family:'Space Mono',monospace" id="chart-stat-rate">0</div>
    </div>
    <div style="background:rgba(13,20,32,.6);border:1px solid #111B2E;border-radius:8px;padding:8px 10px">
      <div style="font-size:7px;color:#445577;letter-spacing:.1em;margin-bottom:3px" id="chart-stat-lbl-click">👆 BTC / CLIC</div>
      <div style="font-size:14px;font-weight:700;color:#627EEA;font-family:'Space Mono',monospace" id="chart-stat-click">0</div>
    </div>
    <div style="background:rgba(13,20,32,.6);border:1px solid #111B2E;border-radius:8px;padding:8px 10px">
      <div style="font-size:7px;color:#445577;letter-spacing:.1em;margin-bottom:3px" id="chart-stat-lbl-bot">🤖 BTC / SEC (BOTS)</div>
      <div style="font-size:14px;font-weight:700;color:#A78BFA;font-family:'Space Mono',monospace" id="chart-stat-bot">0</div>
    </div>
  </div>

  <!-- Graphique bots vs clics (barres) -->
  <div style="background:rgba(13,20,32,.6);border:1px solid #111B2E;border-radius:8px;padding:10px;margin-bottom:8px">
    <div style="font-size:7px;color:#445577;letter-spacing:.12em;margin-bottom:8px" id="chart-breakdown-title">RÉPARTITION DES REVENUS</div>
    <div style="display:flex;flex-direction:column;gap:5px">
      <div style="display:flex;align-items:center;gap:8px">
        <span style="font-size:8px;color:#627EEA;width:60px;flex-shrink:0" id="chart-lbl-clicks">👆 Clics</span>
        <div style="flex:1;height:8px;background:#111B2E;border-radius:4px;overflow:hidden">
          <div id="chart-bar-clicks" style="height:100%;background:linear-gradient(90deg,#627EEA,#A78BFA);border-radius:4px;transition:width .5s ease;width:0%"></div>
        </div>
        <span style="font-size:8px;color:#627EEA;width:50px;text-align:right;font-family:'Space Mono',monospace" id="chart-pct-clicks">0%</span>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <span style="font-size:8px;color:#A78BFA;width:60px;flex-shrink:0" id="chart-lbl-bots">🤖 Bots</span>
        <div style="flex:1;height:8px;background:#111B2E;border-radius:4px;overflow:hidden">
          <div id="chart-bar-bots" style="height:100%;background:linear-gradient(90deg,#A78BFA,#F7931A);border-radius:4px;transition:width .5s ease;width:0%"></div>
        </div>
        <span style="font-size:8px;color:#A78BFA;width:50px;text-align:right;font-family:'Space Mono',monospace" id="chart-pct-bots">0%</span>
      </div>
    </div>
  </div>
</div>

<!-- PANEL STATS -->
<div class="panel hidden" id="panel-stats">
  <div class="section-title"><span id="stat-title">📊 STATISTIQUES</span></div>
  <div style="font-size:8px;color:#A78BFA;padding:6px 10px;background:rgba(167,139,250,.07);border:1px solid #A78BFA33;border-radius:8px;margin-bottom:8px" id="stats-rena-section">
    <div style="font-size:9px;font-weight:700;color:#A78BFA;margin-bottom:6px">♾ CLASSEMENT RENAISSANCES</div>
    <div id="renaissance-leaderboard" style="display:flex;flex-direction:column;gap:3px"></div>
  </div>

  <!-- Graphique en chandeliers BTC -->
  <div class="stats-chart-wrap">
    <div class="stats-chart-label" id="chart-label-btc">📊 BTC BALANCE — LIVE CHART</div>
    <div class="stats-canvas-wrap" style="height:120px;position:relative">
      <canvas id="chart-btc" style="width:100%;height:120px"></canvas>
      <div id="chart-hover-tooltip" style="position:absolute;top:4px;right:4px;background:rgba(6,12,20,.9);border:1px solid #F7931A44;border-radius:4px;padding:4px 8px;font-size:8px;font-family:'Space Mono',monospace;color:#F7931A;pointer-events:none;display:none"></div>
    </div>
    <div class="chart-legend">
      <div class="chart-legend-item"><div class="chart-legend-dot" style="background:#00D97E"></div><span id="chart-leg-bull">Hausse</span></div>
      <div class="chart-legend-item"><div class="chart-legend-dot" style="background:#FF4560"></div><span id="chart-leg-bear">Baisse</span></div>
      <div class="chart-legend-item"><div class="chart-legend-dot" style="background:#627EEA"></div><span id="chart-leg-wick">Wick</span></div>
    </div>
  </div>

  <!-- Stats session -->
  <div class="stats-session-grid">
    <div class="session-stat"><div class="session-label" id="sess-label-time">⏱ TEMPS SESSION</div><div class="session-val" style="color:#627EEA" id="s-session-time">0m</div></div>
    <div class="session-stat"><div class="session-label" id="sess-label-rate">⚡ BTC/MIN ACTUEL</div><div class="session-val" style="color:#F7931A" id="s-btc-rate">0</div></div>
    <div class="session-stat"><div class="session-label" id="sess-label-best">🏆 MEILLEUR HALVING</div><div class="session-val" style="color:#FFD166" id="s-best-prest">0</div></div>
    <div class="session-stat"><div class="session-label" id="sess-label-events">🎲 ÉVÉNEMENTS</div><div class="session-val" style="color:#00D97E" id="s-events">0</div></div>
  </div>

  <div class="section-title" style="margin-top:8px"><span id="stat-title-2">📈 TOTAUX</span></div>
  <div class="stats-grid">
    <div class="stat-card"><div class="stat-label"><span id="stat-total-mine">₿ TOTAL MINÉ</span></div><div class="stat-val" style="color:#F7931A" id="s-total">0</div></div>
    <div class="stat-card"><div class="stat-label"><span id="stat-clics">🖱 CLICS MANUELS</span></div><div class="stat-val" style="color:#627EEA" id="s-clics">0</div></div>
    <div class="stat-card"><div class="stat-label"><span id="stat-btc-clic">⚡ BTC / CLIC</span></div><div class="stat-val" style="color:#F7931A" id="s-vpc">1</div></div>
    <div class="stat-card"><div class="stat-label"><span id="stat-auto-clic">🤖 CLICS AUTO/SEC</span></div><div class="stat-val" style="color:#00D97E" id="s-auto">0</div></div>
    <div class="stat-card"><div class="stat-label"><span id="stat-bets-won">📈 PARIS GAGNÉS</span></div><div class="stat-val" style="color:#00D97E" id="s-wins">0</div></div>
    <div class="stat-card"><div class="stat-label"><span id="stat-bets-lost">📉 PARIS PERDUS</span></div><div class="stat-val" style="color:#FF4560" id="s-losses">0</div></div>
    <div class="stat-card"><div class="stat-label"><span id="stat-won-mkt">💰 GAGNÉ MARCHÉ</span></div><div class="stat-val" style="color:#00D97E" id="s-mwin">0</div></div>
    <div class="stat-card"><div class="stat-label"><span id="stat-lost-mkt">💸 PERDU MARCHÉ</span></div><div class="stat-val" style="color:#FF4560" id="s-mloss">0</div></div>
    <div class="stat-card"><div class="stat-label"><span id="stat-trophies-label">🏆 TROPHÉES</span></div><div class="stat-val" style="color:#FFD166" id="s-achs">0/30</div></div>
    <div class="stat-card"><div class="stat-label"><span id="stat-skins-label">🎨 SKINS ACHETÉS</span></div><div class="stat-val" style="color:#BF7EFF" id="s-skins">1/25</div></div>
  </div>
</div>

