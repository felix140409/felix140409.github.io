// ═══ BOUTIQUE RENAISSANCE ═══
// Chaque récompense se débloque à un palier de renaissances (1, 2, 3... 10)
// Coût = nombre de renaissances requis, pas des BTC
// Les bonus sont PERMANENTS et survivent aux resets

const SHOP_REWARDS = [
  { palier:1,  icon:'🔥', name:'Forge de Renaissance',    desc:'Commence chaque Renaissance avec +10 BTC/clic bonus permanent',      type:'click',  bonus:10   },
  { palier:2,  icon:'🤖', name:'Bot Hérité',               desc:'Commence avec le Bot basique déjà débloqué après chaque reset',      type:'bot',    bonus:1    },
  { palier:3,  icon:'⚡', name:'Condensateur Energie',     desc:'+25% BTC/clic en bonus permanent sur ta production de base',         type:'mult',   bonus:0.25 },
  { palier:4,  icon:'🛡', name:'Bouclier Anti-Rival',      desc:'Le rival te vole 25% de moins lors de la roue',                     type:'rival',  bonus:0.25 },
  { palier:5,  icon:'💾', name:'Memoire du Marche',        desc:'+30% de gains sur tous les paris du marche',                        type:'market', bonus:0.30 },
  { palier:6,  icon:'🌟', name:'Aura de Satoshi',          desc:'Chaque clic rapporte +5% de BTC en bonus supplémentaire',           type:'aura',   bonus:0.05 },
  { palier:7,  icon:'🏦', name:'Coffre-fort Quantique',    desc:'Conserve 10% de tes BTC lors de chaque Renaissance',                type:'vault',  bonus:0.10 },
  { palier:8,  icon:'🚀', name:'Turbo Bot Heritage',       desc:'Commence aussi avec le Turbo bot deja débloqué apres chaque reset', type:'bot2',   bonus:1    },
  { palier:9,  icon:'♾', name:'Echo Infini',              desc:'+2 BTC/sec auto permanent qui survit aux Renaissances',             type:'auto',   bonus:2    },
  { palier:10, icon:'👑', name:'SATOSHI LEGACY',           desc:'x2 sur tout — BTC/clic, auto, marche. Le pouvoir ultime.',          type:'ultimate',bonus:2   },
];

// shopLevels[i] = 1 si récompense i débloquée, 0 sinon
const shopLevels = new Array(10).fill(0);
let shopVaultPct       = 0;
let shopRivalReduction = 0;
let shopMarketBonus    = 0;
let shopAutoBonus      = 0;

function buildShopList() {
  const list = document.getElementById('shop-list');
  if (!list) return;
  list.innerHTML = '';
  const L = LANGS[currentLang]||LANGS.fr;

  // Progress
  const prog = document.getElementById('shop-progress');
  const next = SHOP_REWARDS.find((r,i) => shopLevels[i] === 0 && prestigeCount < r.palier);
  if (prog) {
    if (prestigeCount >= 10) prog.textContent = L.shopAllUnlocked || '🌟 All rewards unlocked!';
    else if (next) prog.textContent = (L.shopProgress || 'Renaissance {n}/10 — Next unlock at {p}').replace('{n}', prestigeCount).replace('{p}', next.palier);
    else prog.textContent = L.shopClaim || '🎁 You have rewards to collect!';
  }

  SHOP_REWARDS.forEach((item, idx) => {
    const unlocked  = prestigeCount >= item.palier;
    const collected = shopLevels[idx] === 1;
    const div = document.createElement('div');
    div.className = 'upg-item' + (collected ? ' maxed' : unlocked ? ' can-buy' : '');
    div.style.opacity = unlocked ? '1' : '0.4';
    const name = (L.shopNames&&L.shopNames[idx]) || item.name;
    const desc = (L.shopDescs&&L.shopDescs[idx]) || item.desc;

    const statusText = collected
      ? '<span style="color:#00D97E;font-size:10px">✅ ' + (L.shopOwned||'Obtained') + '</span>'
      : unlocked
        ? '<span style="color:#F7931A;font-size:9px">🎁 ' + (L.shopCollect||'Collect!') + '</span>'
        : '<span style="color:#445577;font-size:9px">🔒 Renaissance ' + item.palier + '</span>';

    div.innerHTML = `
      <div class="upg-icon" style="background:linear-gradient(135deg,#1a0a2e,#0d1420);font-size:20px">${item.icon}</div>
      <div class="upg-info">
        <div class="upg-name" style="color:${collected?'#445577':unlocked?'#FFD166':'#8899BB'}">${name}</div>
        <div class="upg-desc">${desc}</div>
      </div>
      <div class="upg-right">${statusText}</div>
    `;
    if (unlocked && !collected) div.onclick = () => claimShopReward(idx);
    list.appendChild(div);
  });
}

function claimShopReward(idx) {
  const item = SHOP_REWARDS[idx];
  if (!item) return;
  if (prestigeCount < item.palier) return;
  if (shopLevels[idx] === 1) return;
  shopLevels[idx] = 1;
  applyShopBonuses();
  buildShopList();
  updateDisplay();
  scheduleSave();
  showToast(item.icon + ' ' + item.name + ' ' + (LANGS[currentLang]?.toastUnlocked||'unlocked!'));
}

function applyShopBonuses() {
  shopVaultPct       = shopLevels[6] ? 0.10 : 0;
  shopRivalReduction = shopLevels[3] ? 0.25 : 0;
  shopMarketBonus    = shopLevels[4] ? 0.30 : 0;
  shopAutoBonus      = shopLevels[8] ? 2    : 0;
  if (SHOP_REWARDS[9] && shopLevels[9]) {
    // SATOSHI LEGACY x2 stacke avec tout
  }
}

function applyShopClickBonus() {
  // Forge +10 BTC/clic
  if (shopLevels[0]) btcPerClick = Math.max(1, btcPerClick + 10);
  // Condensateur +25%
  if (shopLevels[2]) btcPerClick = Math.round(btcPerClick * 1.25);
  // Aura +5% par clic (appliqué au multiplicateur de base)
  if (shopLevels[5]) btcPerClick = Math.round(btcPerClick * 1.05);
  // SATOSHI LEGACY x2
  if (shopLevels[9]) btcPerClick = Math.round(btcPerClick * 2);
}

function applyShopBotBonus() {
  // Bot Hérité : débloque bot basique si pas déjà actif
  if (shopLevels[1] && autoLevels[0] === 0) {
    autoLevels[0] = 1;
    autoPerSec += AUTO_UPGRADES[0].speed;
  }
  // Turbo Bot Héritage
  if (shopLevels[7] && autoLevels[2] === 0) {
    autoLevels[2] = 1;
    autoPerSec += AUTO_UPGRADES[2].speed;
  }
  // Echo Infini : +2 BTC/sec permanent (ajout direct a autoPerSec)
  if (shopLevels[8]) autoPerSec += shopAutoBonus;
  // SATOSHI LEGACY x2 sur auto
  if (shopLevels[9]) autoPerSec *= 2;
}

function updateShopTab() {
  const tab = document.getElementById('tab-shop');
  if (!tab) return;
  tab.classList.toggle('hidden', prestigeCount < 1);
}


// 30 trophées
const ACHIEVEMENTS = [
  // Clics
  {id:'c1',    icon:'👆', name:'Premier clic',     cond:'Cliquer 1 fois',            check:()=>totalClics>=1},
