// ═══ FORMAT ═══
function fmt(n) {
  if(n>=1e21) return (n/1e21).toFixed(2)+' <span>Sep BTC</span>';
  if(n>=1e18) return (n/1e18).toFixed(2)+' <span>Qi BTC</span>';
  if(n>=1e15) return (n/1e15).toFixed(2)+' <span>Qd BTC</span>';
  if(n>=1e12) return (n/1e12).toFixed(2)+' <span>T BTC</span>';
  if(n>=1e9)  return (n/1e9).toFixed(2) +' <span>G BTC</span>';
  if(n>=1e6)  return (n/1e6).toFixed(2) +' <span>M BTC</span>';
  if(n>=1e3)  return (n/1e3).toFixed(1) +' <span>k BTC</span>';
  return Math.floor(n)+' <span>BTC</span>';
}
function fmtN(n) {
  if(n>=1e18) return (n/1e18).toFixed(2)+' Qi';
  if(n>=1e15) return (n/1e15).toFixed(2)+' Qd';
  if(n>=1e12) return (n/1e12).toFixed(2)+' T';
  if(n>=1e9)  return (n/1e9).toFixed(2) +' G';
  if(n>=1e6)  return (n/1e6).toFixed(2) +' M';
  if(n>=1e3)  return (n/1e3).toFixed(1) +' k';
  return Math.floor(n).toLocaleString('fr');
}


// ═══ BARRE PROCHAIN TROPHÉE ═══
function updateNextAch() {
  const _La = LANGS[currentLang] || LANGS.fr;
  const next = ACHIEVEMENTS.find(a => !unlocked.has(a.id));
  if (!next) {
    const allDoneTexts = { fr:'✓ Tous débloqués !', en:'✓ All unlocked!', es:'✓ ¡Todos desbloqueados!', ar:'✓ كل شيء مفتوح!', pt:'✓ Todos desbloqueados!' };
    document.getElementById('nab-name').textContent = allDoneTexts[currentLang] || allDoneTexts.en;
    document.getElementById('nab-pct').textContent = '100%';
    document.getElementById('nab-fill').style.width = '100%';
    document.getElementById('nab-fill').style.background = '#00D97E';
    return;
  }
  const nextIdx = ACHIEVEMENTS.indexOf(next);
  const nextName = (_La.achNames && _La.achNames[nextIdx]) || next.name;
  document.getElementById('nab-name').textContent = next.icon + ' ' + nextName;

  // Calculer le pourcentage selon le type de trophée
  let pct = 0;
  const id = next.id;

  if      (id==='c1')    pct = Math.min(100, (totalClics/1)*100);
  else if (id==='c10')   pct = Math.min(100, (totalClics/10)*100);
  else if (id==='c100')  pct = Math.min(100, (totalClics/100)*100);
  else if (id==='c500')  pct = Math.min(100, (totalClics/500)*100);
  else if (id==='c1k')   pct = Math.min(100, (totalClics/1000)*100);
  else if (id==='c10k')  pct = Math.min(100, (totalClics/10000)*100);
  else if (id==='b100')  pct = Math.min(100, (totalMined/100)*100);
  else if (id==='b1k')   pct = Math.min(100, (totalMined/1000)*100);
  else if (id==='b10k')  pct = Math.min(100, (totalMined/10000)*100);
  else if (id==='b100k') pct = Math.min(100, (totalMined/100000)*100);
  else if (id==='b1m')   pct = Math.min(100, (totalMined/1e6)*100);
  else if (id==='b1b')   pct = Math.min(100, (totalMined/1e9)*100);
  else if (id==='m1')    pct = Math.min(100, (mWins/1)*100);
  else if (id==='m10')   pct = Math.min(100, (mWins/10)*100);
  else if (id==='m50')   pct = Math.min(100, (mWins/50)*100);
  else if (id==='lose10') pct = Math.min(100, (mLosses/10)*100);
  else if (id==='s2')    pct = Math.min(100, ((skinsBought.size)/2)*100);
  else if (id==='s5')    pct = Math.min(100, ((skinsBought.size)/5)*100);
  else if (id==='s16')   pct = Math.min(100, ((skinsBought.size)/25)*100);
  else if (id==='rich')  pct = Math.min(100, (btc/1e6)*100);
  else if (id==='speed') pct = Math.min(100, (autoPerSec/500)*100);
  else if (id==='u1')    pct = upgLevels.some(l=>l>0) ? 100 : 0;
  else if (id==='u10')   pct = Math.min(100, (upgLevels.reduce((a,b)=>a+b,0)/10)*100);
  else if (id==='a1')    pct = autoLevels.some(l=>l>0) ? 100 : 0;
  else if (id==='a5')    pct = Math.min(100, (autoLevels.filter(l=>l>0).length/5)*100);
  else if (id==='a10')   pct = Math.min(100, (autoLevels.filter(l=>l>0).length/10)*100);
  else pct = unlocked.has(next.id) ? 100 : 0;

  document.getElementById('nab-pct').textContent = Math.floor(pct) + '%';
  document.getElementById('nab-fill').style.width = pct + '%';
  document.getElementById('nab-fill').style.background = pct >= 80
    ? 'linear-gradient(90deg, #FFD166, #00D97E)'
    : 'linear-gradient(90deg, #627EEA, #FFD166)';
}

// ═══ DISPLAY ═══
function updateDisplay() {
  const _L = LANGS[currentLang] || LANGS.fr;
  document.getElementById('btc-display').innerHTML = fmt(btc);
  document.getElementById('per-click-label').textContent = _L.perClick(fmtN(btcPerClick));
  const al = document.getElementById('auto-label');
  if(autoPerSec>0){ al.style.display=''; al.textContent = _L.autoLabel(fmtN(autoPerSec)); }
  else al.style.display='none';
  refreshUpgrades(); refreshAutoList(); updateExamples(); updateStats(); checkAchievements(); updateNextAch(); updatePrestigeBar(); checkMilestones(); updateSessionStats();
}

// ═══ ONGLETS ═══
const TABS=['upg','auto','market','chart','stats','ach','skins','shop'];
function switchTab(name){
  if (name === 'shop') buildShopList();
  if (name === 'chart') { setTimeout(drawBtcHistoryChart, 50); updateChartPanel(); }
  TABS.forEach(t=>{
    const tb=document.getElementById('tab-'+t);
    const pb=document.getElementById('panel-'+t);
    if(tb) tb.classList.toggle('active',t===name);
    if(pb) pb.classList.toggle('hidden',t!==name);
  });
  if(name==='ach') buildAchList();
}

// ═══ AMÉLIORATIONS ═══
function buildUpgrades(){
  const list=document.getElementById('upg-list');
  const L=LANGS[currentLang]||LANGS.fr;
  UPGRADES.forEach((u)=>{
    const el=document.createElement('div'); el.className='upg-item'; el.id='upg-'+u.i;
    const name = (L.upgNames&&L.upgNames[u.i]) || u.name;
    const desc = (L.upgDescs&&L.upgDescs[u.i]) || u.desc;
    el.innerHTML=`<div class="upg-icon" style="font-family:'Segoe UI Emoji','Apple Color Emoji','Noto Color Emoji',sans-serif;font-size:20px">${u.icon}</div><div class="upg-info"><div class="upg-name">${name}</div><div class="upg-desc">${desc}</div></div><div class="upg-right"><div class="upg-cost" id="uc-${u.i}"></div><div class="upg-level" id="ul-${u.i}"></div></div>`;
    el.addEventListener('click',()=>buyUpg(u.i));
    list.appendChild(el);
  });
}
function refreshUpgrades(){
  UPGRADES.forEach(u=>{
    const el=document.getElementById('upg-'+u.i), ce=document.getElementById('uc-'+u.i), le=document.getElementById('ul-'+u.i);
    if(!el||!ce||!le) return;
    const lv=upgLevels[u.i], cost=Math.floor(u.cost*Math.pow(2.2,lv));
    le.textContent=lv+' / '+u.max;
    if(lv>=u.max){el.className='upg-item maxed';ce.textContent='MAX ✓';ce.className='upg-cost';}
    else{const can=btc>=cost;el.className='upg-item'+(can?' can-buy':'');ce.textContent=fmtN(cost)+' BTC';ce.className='upg-cost'+(can?' affordable':'');}
  });
}
function buyUpg(i){
  const u=UPGRADES[i],lv=upgLevels[i];
  if(lv>=u.max) return;
  const cost=Math.floor(u.cost*Math.pow(2.2,lv));
  if(btc<cost) return;
  btc-=cost; upgLevels[i]++; btcPerClick+=Math.round(u.bonus * prestigeMult);
  const L=LANGS[currentLang]||LANGS.fr;
  const name=(L.upgNames&&L.upgNames[i])||u.name;
  showToast(u.icon+' '+name+' — +'+fmtN(u.bonus)+' '+(LANGS[currentLang]?.toastBtcClic||'BTC/click!')); scheduleSave();
  updateDisplay();
}

// ═══ BOTS ═══
function buildAutoList(){
  const list=document.getElementById('auto-list');
  const L=LANGS[currentLang]||LANGS.fr;
  AUTO_UPGRADES.forEach(u=>{
    const el=document.createElement('div'); el.className='upg-item'; el.id='auto-'+u.i;
    const name = (L.botNames&&L.botNames[u.i]) || u.name;
    const desc = (L.botDescs&&L.botDescs[u.i]) || u.desc;
    el.innerHTML=`<div class="upg-icon" style="font-family:'Segoe UI Emoji','Apple Color Emoji','Noto Color Emoji',sans-serif;font-size:20px">${u.icon}</div><div class="upg-info"><div class="upg-name">${name}</div><div class="upg-desc">${desc}</div></div><div class="upg-right"><div class="upg-cost" id="ac-${u.i}"></div><div class="upg-level" id="al-${u.i}"></div></div>`;
    el.addEventListener('click',()=>buyAuto(u.i));
    list.appendChild(el);
  });
}
function refreshAutoList(){
  AUTO_UPGRADES.forEach(u=>{
    const el=document.getElementById('auto-'+u.i), ce=document.getElementById('ac-'+u.i), le=document.getElementById('al-'+u.i);
    if(!el||!ce||!le) return;
    const lv=autoLevels[u.i];
    le.textContent=lv+' / '+u.max;
    const cost=autoCost(u,lv);
    const can=btc>=cost;
    el.className='upg-item'+(can?' can-buy':'');
    ce.textContent=fmtN(cost)+' BTC';
    ce.className='upg-cost'+(can?' affordable':'');
    le.textContent='Niv. '+lv;
  });
}
function autoCost(u, lv) {
  return Math.floor(u.cost * Math.pow(1.9, lv));
}
function buyAuto(i){
  const u=AUTO_UPGRADES[i];
  const lv=autoLevels[i];
  const cost=autoCost(u,lv);
  if(btc<cost) return;
  btc-=cost; autoLevels[i]++; autoPerSec+=u.speed;
  const Lb=LANGS[currentLang]||LANGS.fr;
  const bname=(Lb.botNames&&Lb.botNames[i])||u.name;
  if(!autoInterval) startAutoTick();
  showToast(u.icon+' '+bname+' — +'+u.speed+' '+(LANGS[currentLang]?.toastAutoSec||'BTC/sec!')); scheduleSave();
  updateDisplay();
}
function startAutoTick(){
  autoInterval=setInterval(()=>{
    if(autoPerSec<=0) return;
    const _aMult=(Date.now()<eventEndTime?eventMult:1);
    // Bots give their own FIXED BTC/sec — completely independent of btcPerClick
    const g = autoPerSec * _aMult;
    btc+=g/20; totalMined+=g/20;
    lifetimeMined+=g/20;
    _botIncome5s += g/20; // track for chart
    updateDisplay();
  },50); // 50ms tick = 20 ticks/sec for smooth auto income
}

// ═══ MARCHÉ ═══
const DIFFS={facile:{chance:.75,mult:1.4},normal:{chance:.35,mult:2},difficile:{chance:.15,mult:3},impossible:{chance:.01,mult:8}};
function getMise(){return Math.floor(Number(document.getElementById('market-amount').value)||0);}
function setMax(){document.getElementById('market-amount').value=Math.floor(Math.min(btc, btc*0.25));updateExamples();}
function updateExamples(){
  const mise=getMise();
  [{k:'facile',m:1.5},{k:'normal',m:2},{k:'difficile',m:3},{k:'impossible',m:10}].forEach(({k,m})=>{
    const el=document.getElementById('ex-'+k);
    el.textContent=mise>0?'→ +'+fmtN(Math.floor(mise*m))+' BTC':(LANGS[currentLang]?.enterBet||'Enter a bet');
  });
}
let betting=false;
const COOLDOWN_MS = 60000; // 1 minute
const cooldownEnd = {facile:0, normal:0, difficile:0, impossible:0};
const cooldownTimers = {};

function startCooldown(diff){
  cooldownEnd[diff] = Date.now() + COOLDOWN_MS;
  const card = document.getElementById('diff-'+diff);
  const bar  = document.getElementById('bar-'+diff);
  const lbl  = document.getElementById('cd-'+diff);
  card.classList.add('cooldown');
  if(cooldownTimers[diff]) clearInterval(cooldownTimers[diff]);
  cooldownTimers[diff] = setInterval(()=>{
    const remaining = cooldownEnd[diff] - Date.now();
    if(remaining <= 0){
      clearInterval(cooldownTimers[diff]);
      card.classList.remove('cooldown');
      bar.style.width = '0%';
      lbl.textContent = '';
    } else {
      const secs = Math.ceil(remaining/1000);
      const pct  = (remaining / COOLDOWN_MS) * 100;
      bar.style.width = pct + '%';
      lbl.textContent = '⏱ ' + secs + 's';
    }
  }, 100);
}

function play(diff){
  if(betting) return;
  if(cooldownEnd[diff] > Date.now()){
    const secs = Math.ceil((cooldownEnd[diff]-Date.now())/1000);
    showToast((LANGS[currentLang]?.toastWait||'⏱ Wait {n}s!').replace('{n}',secs)); return;
  }
  const mise=getMise();
  if(!mise||mise<=0){showToast(LANGS[currentLang]?.toastNoBet||'⚠️ Enter a bet!');return;}
  if(mise>btc){showToast(LANGS[currentLang]?.toastNoFunds||'⚠️ Not enough BTC!');return;}
  const miseMax = Math.floor(btc * 0.25);
  if(mise > miseMax && btc > 100){showToast((LANGS[currentLang]?.toastMaxBet||'⚠️ Max bet: 25% ({n})').replace('{n}',fmtN(miseMax)));return;}
  betting=true;
  const d=DIFFS[diff], won=Math.random()<d.chance;
  document.getElementById('market-result').className='market-result hidden';
  setTimeout(()=>{
    const res=document.getElementById('market-result');
    if(won){
      const gain=Math.floor(mise*d.mult); btc+=gain; totalMined+=gain; mWins++; mWonBtc+=gain;
      if(diff==='impossible') unlocked.add('_imp');
      res.className='market-result win';
      document.getElementById('result-icon').textContent='🎉';
      document.getElementById('result-text').textContent='+'+fmtN(gain)+' BTC — '+(LANGS[currentLang]?.marketWon||'WON!');
      showToast((LANGS[currentLang]?.toastWin||'🎉 WON +{n} BTC!').replace('{n}',fmtN(gain)));
    }else{
      btc=Math.max(0,btc-mise); mLosses++; mLostBtc+=mise;
      res.className='market-result lose';
      document.getElementById('result-icon').textContent='💸';
      document.getElementById('result-text').textContent='-'+fmtN(mise)+' BTC — '+(LANGS[currentLang]?.marketLost||'LOST');
      showToast((LANGS[currentLang]?.toastLoss||'💸 Lost -{n} BTC').replace('{n}',fmtN(mise)));
    }
    updateDisplay(); betting=false;
    startCooldown(diff);
  },400);
}

// ═══ STATS ═══
function updateStats(){
  document.getElementById('s-total').textContent  = fmtN(totalMined);
  document.getElementById('s-clics').textContent  = totalClics.toLocaleString(currentLang === 'ar' ? 'ar' : currentLang === 'pt' ? 'pt' : 'en');
  document.getElementById('s-vpc').textContent    = fmtN(btcPerClick);
  document.getElementById('s-auto').textContent   = autoPerSec+'/sec';
  document.getElementById('s-wins').textContent   = mWins;
  document.getElementById('s-losses').textContent = mLosses;
  document.getElementById('s-mwin').textContent   = fmtN(mWonBtc);
  document.getElementById('s-mloss').textContent  = fmtN(mLostBtc);
  const ac=ACHIEVEMENTS.filter(a=>unlocked.has(a.id)).length;
  document.getElementById('s-achs').textContent  = ac+'/'+ACHIEVEMENTS.length;
  document.getElementById('s-skins').textContent = skinsBought.size+'/'+(SKINS.length);
}

// ═══ TROPHÉES ═══
function buildAchList(){
  const list=document.getElementById('ach-list'); list.innerHTML='';
  const L=LANGS[currentLang]||LANGS.fr;
  ACHIEVEMENTS.forEach((a,idx)=>{
    const ok=unlocked.has(a.id);
    const el=document.createElement('div'); el.className='ach-card'+(ok?' unlocked':''); el.id='ach-'+a.id;
    const name = (L.achNames&&L.achNames[idx]) || a.name;
    const cond = (L.achConds&&L.achConds[idx]) || a.cond;
    el.innerHTML=`<div class="ach-icon-wrap">${a.icon}</div><div><div class="ach-name">${name}</div><div class="ach-cond">${cond}</div></div>`;
    list.appendChild(el);
  });
}
let achTimer;
function checkAchievements(){
  ACHIEVEMENTS.forEach((a,idx)=>{
    if(!unlocked.has(a.id)&&a.check()){
      unlocked.add(a.id);
      const La=LANGS[currentLang]||LANGS.fr;
      const aname=(La.achNames&&La.achNames[idx])||a.name;
      const acond=(La.achConds&&La.achConds[idx])||a.cond;
      const pop=document.getElementById('ach-popup');
      document.getElementById('ap-icon').textContent=a.icon;
      document.getElementById('ap-title').textContent=aname;
      document.getElementById('ap-sub').textContent=acond;
      pop.classList.add('show');
      clearTimeout(achTimer);
      achTimer=setTimeout(()=>pop.classList.remove('show'),3500);
    }
  });
}

// ═══ SKINS ═══
function buildSkins(){
  const list=document.getElementById('skin-list');
  SKINS.forEach(s=>{
    const el=document.createElement('div'); el.className='skin-card'+(s.id===currentSkin?' active':''); el.id='skin-'+s.id;
    el.innerHTML=`<div class="skin-preview" style="background:${s.bg};border:2px solid ${s.border}">${s.icon}</div><div class="skin-info"><div class="skin-name">${s.name}</div><div class="skin-sub">${s.sub}</div><div class="skin-price ${skinsBought.has(s.id)?'owned':''}" id="sp-${s.id}">${skinsBought.has(s.id)?(s.id===currentSkin?'✓ '+(LANGS[currentLang]?.skinEquipped||'Equipped'):'✓ '+(LANGS[currentLang]?.skinOwned||'Owned')):fmtN(s.cost)+' BTC'}</div></div>`;
    el.addEventListener('click',()=>buySkin(s.id));
    list.appendChild(el);
  });
}
function buySkin(id){
  const s=SKINS[id];
  if(!s) return;
  if(!skinsBought.has(id)){
    if(s.prestige !== undefined) {
      if(prestigeCount < s.prestige){showToast((LANGS[currentLang]?.toastSkinLocked||'🔒 Unlocked at Renaissance {n}!').replace('{n}',s.prestige));return;}
      skinsBought.add(id);
    } else {
      if(btc<s.cost){showToast(LANGS[currentLang]?.toastNoFunds||'⚠️ Not enough BTC!');return;}
      btc-=s.cost; skinsBought.add(id);
    }
    showToast((LANGS[currentLang]?.toastSkinBought||'🎨 Skin {n} purchased!').replace('{n}',s.name));
  }
  currentSkin=id;

  // ── Bouton mine ──
  const btn=document.getElementById('mine-btn');
  btn.style.setProperty('--btn-bg',s.bg);
  btn.style.setProperty('--btn-border',s.border);
  btn.style.setProperty('--btn-glow',s.glow);
  btn.style.setProperty('--btn-shadow',s.shadow);
  document.getElementById('mine-icon').textContent=s.icon;

  // ── Fond d'écran ──
  const gw = document.getElementById('game-wrapper');
  if(gw) gw.style.background = s.bodyBg || '#080C14';
  document.body.style.background = s.bodyBg || '#080C14';

  // ── Couleurs UI via CSS variables ──
  if(s.ui){
    const r = document.documentElement.style;
    r.setProperty('--skin-accent',   s.ui.accent);
    r.setProperty('--skin-accent2',  s.ui.accent2);
    r.setProperty('--skin-tab',      s.ui.tabActive);
    r.setProperty('--skin-border',   s.ui.border);
    r.setProperty('--skin-card',     s.ui.card);
    r.setProperty('--skin-text',     s.ui.text);
    r.setProperty('--skin-dim',      s.ui.dim);
  }

  // ── Pétales Sakura ──
  if(s.sakura){ initSakuraPetals(); }
  else { clearSakuraPetals(); }

  // ── Refresh liste ──
  SKINS.forEach(sk=>{
    const el=document.getElementById('skin-'+sk.id); if(!el) return;
    el.className='skin-card'+(sk.id===currentSkin?' active':'');
    const sp=document.getElementById('sp-'+sk.id);
    if(!sp) return;
    const own=skinsBought.has(sk.id);
    if(sk.prestige !== undefined && !own){
      sp.textContent='🔒 Renaissance '+sk.prestige;
    } else {
      sp.textContent=own?(sk.id===currentSkin?'✓ '+(LANGS[currentLang]?.skinEquipped||'Equipped'):'✓ '+(LANGS[currentLang]?.skinOwned||'Owned')):fmtN(sk.cost)+' BTC';
    }
    sp.className='skin-price'+(own?' owned':'');
  });
  updateDisplay();
}


// ═══ FONDS D'ÉCRAN ═══
const BACKGROUNDS = [
  { id:0,  name:'Grille',      style:'background:#080C14',                                                     grid:true  },
  { id:1,  name:'Nuit',        style:'background:linear-gradient(160deg,#080C14 0%,#0d1a2e 100%)',              grid:false },
  { id:2,  name:'Aurore',      style:'background:linear-gradient(160deg,#0a0820 0%,#1a0a3a 50%,#0a1a30 100%)', grid:false },
  { id:3,  name:'Feu',         style:'background:linear-gradient(160deg,#1a0500 0%,#3a0a00 50%,#1a0500 100%)', grid:false },
  { id:4,  name:'Océan',       style:'background:linear-gradient(160deg,#000d1a 0%,#001a3a 50%,#000d1a 100%)', grid:false },
  { id:5,  name:'Forêt',       style:'background:linear-gradient(160deg,#031003 0%,#0a2a0a 50%,#031003 100%)', grid:false },
  { id:6,  name:'Cosmos',      style:'background:linear-gradient(160deg,#02000f 0%,#0a0030 50%,#02000f 100%)', grid:false },
  { id:7,  name:'Rose',        style:'background:linear-gradient(160deg,#1a0008 0%,#3a0a1a 50%,#1a0008 100%)', grid:false },
  { id:8,  name:'Or',          style:'background:linear-gradient(160deg,#1a0f00 0%,#3a2a00 50%,#1a0f00 100%)', grid:false },
  { id:9,  name:'Cyber',       style:'background:linear-gradient(160deg,#001a10 0%,#003a2a 50%,#001a10 100%)', grid:false },
  { id:10, name:'Crépuscule',  style:'background:linear-gradient(160deg,#1a0820 0%,#3a1010 50%,#101a3a 100%)', grid:false },
  { id:11, name:'Arc-en-ciel', style:'background:linear-gradient(160deg,#1a0010 0%,#001a1a 30%,#1a1a00 60%,#0a001a 100%)', grid:false },
];
let currentBg = 0;

function buildBgGrid() {
  const grid = document.getElementById('bg-grid');
  if (!grid) return; // section fond d'écran supprimée
  BACKGROUNDS.forEach(bg => {
    const el = document.createElement('div');
    el.className = 'bg-opt' + (bg.id === currentBg ? ' active' : '');
    el.id = 'bg-' + bg.id;
    el.style.cssText = bg.style;
    el.innerHTML = '<span>' + bg.name + '</span>';
    el.addEventListener('click', () => applyBg(bg.id));
    grid.appendChild(el);
  });
}

function applyBg(id) {
  const bg = BACKGROUNDS[id];
  currentBg = id;
  // Apply to body
  document.body.style.cssText = bg.style;
  // Grid overlay
  const before = document.getElementById('bg-overlay');
  before.style.opacity = bg.grid ? '1' : '0';
  // Update active state
  BACKGROUNDS.forEach(b => {
    const el = document.getElementById('bg-' + b.id);
    if (el) el.className = 'bg-opt' + (b.id === id ? ' active' : '');
  });
}

// ═══ PARAMÈTRES ═══
function toggleSettings(){
  document.getElementById('settings-overlay')?.classList.toggle('hidden');
}
function toggleOpt(k){
  opts[k]=!opts[k];
  const tg=document.getElementById('toggle-'+k); if(tg) tg.classList.toggle('on',opts[k]);
}

// ── SCALE UI ──
let uiScale = parseFloat(localStorage.getItem('cm_scale') || '1.0');
function applyScale(s) {
  uiScale = Math.max(0.6, Math.min(1.6, s));
  const gw = document.getElementById('game-wrapper');
  if (gw) {
    gw.style.transformOrigin = 'top center';
    gw.style.transform = `scale(${uiScale})`;
    // Ajuster la hauteur pour éviter le scroll
    gw.style.height = (100 / uiScale) + 'vh';
  }
  const valEl = document.getElementById('scale-val');
  if (valEl) valEl.textContent = Math.round(uiScale * 100) + '%';
  localStorage.setItem('cm_scale', uiScale.toString());
}
function changeScale(delta) { applyScale(uiScale + delta); }
// Appliquer au chargement
applyScale(uiScale);
function resetGame(){
  document.getElementById('confirm-box')?.classList.remove('hidden');
}
function doReset(){
  btc=0; btcPerClick=1; totalMined=0; totalClics=0;
  mWins=0; mLosses=0; mWonBtc=0; mLostBtc=0;
  unlocked.clear(); currentSkin=0; skinsBought.clear(); skinsBought.add(0); autoPerSec=0;
  autoLevels.fill(0); upgLevels.fill(0);
  clearInterval(autoInterval); autoInterval=null;
  buySkin(0); applyBg(0);
  document.getElementById('confirm-box')?.classList.add('hidden');
  document.getElementById('settings-overlay')?.classList.add('hidden');
  // Rebuild lists
  document.getElementById('upg-list').innerHTML='';
  document.getElementById('auto-list').innerHTML='';
  document.getElementById('skin-list').innerHTML='';
  const bgGridEl = document.getElementById('bg-grid'); if (bgGridEl) bgGridEl.innerHTML='';
  buildUpgrades(); buildAutoList(); buildSkins(); buildBgGrid();
  showToast(LANGS[currentLang]?.toastReset||'🔄 Game reset!'); localStorage.removeItem(SAVE_KEY);
  updateDisplay();
}
function cancelReset(){
  document.getElementById('confirm-box')?.classList.add('hidden');
}

// spawnFloat — voir version améliorée

// ═══ TOAST ═══
let toastTimer;
function showToast(msg){
  const t=document.getElementById('toast'); if(t){t.textContent=msg; t.classList.add('show');}
  clearTimeout(toastTimer); toastTimer=setTimeout(()=>t.classList.remove('show'),2500);
}

// ═══ CLIC ═══
document.getElementById('mine-btn').addEventListener('pointerdown',function(e){
  e.preventDefault();
  const _cMult = (Date.now()<eventEndTime?eventMult:1); btc+=btcPerClick*_cMult; totalMined+=btcPerClick*_cMult; totalClics++; if(totalClics%100===0) scheduleSave();
  _clickIncome5s += btcPerClick * _cMult; // track for chart
  updateDisplay(); spawnFloat(e);

  // Animation inline — indépendante, fonctionne toujours
  const rect = this.getBoundingClientRect();
  const cx = rect.left + rect.width/2;
  const cy = rect.top  + rect.height/2;
  const earned = btcPerClick * _cMult;

  // Texte +BTC
  const t = document.createElement('div');
  t.textContent = '+' + (earned >= 1e6 ? (earned/1e6).toFixed(1)+'M' : earned >= 1e3 ? (earned/1e3).toFixed(1)+'k' : earned) + ' ₿';
  t.style.cssText = 'position:fixed;left:'+(cx-20)+'px;top:'+(cy-30)+'px;color:#F7931A;font-weight:700;font-size:16px;pointer-events:none;z-index:999999;font-family:monospace;text-shadow:0 0 8px #F7931A;transition:all 0.8s ease-out;';
  document.body.appendChild(t);
  requestAnimationFrame(()=>{ t.style.transform='translateY(-50px)'; t.style.opacity='0'; });
  setTimeout(()=>t.remove(), 850);

  // Particules
  const colors=['#F7931A','#FFD700','#00D97E','#627EEA','#FF6B6B'];
  for(let i=0;i<6;i++){
    const p=document.createElement('div');
    const angle=(Math.PI*2/6)*i;
    const dist=40+Math.random()*40;
    const dx=Math.cos(angle)*dist, dy=Math.sin(angle)*dist;
    p.style.cssText='position:fixed;left:'+cx+'px;top:'+cy+'px;width:6px;height:6px;border-radius:50%;pointer-events:none;z-index:999999;background:'+colors[i%colors.length]+';transition:all 0.5s ease-out;transform:translate(-50%,-50%);';
    document.body.appendChild(p);
    requestAnimationFrame(()=>{ p.style.transform='translate(calc(-50% + '+dx+'px),calc(-50% + '+dy+'px))'; p.style.opacity='0'; });
    setTimeout(()=>p.remove(), 550);
  }

  this.classList.add('pressed');
  setTimeout(()=>this.classList.remove('pressed'),110);
});

