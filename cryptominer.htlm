  // Tier 8 — légendaire
  {i:25, icon:'☯',  name:'Équilibre Univ.',  desc:'3M BTC/sec',      cost:150000000000000000000,  speed:3000000,   max:999},
  {i:26, icon:'🧿', name:'Œil du Destin',    desc:'4.5M BTC/sec',    cost:1200000000000000000000, speed:4500000,   max:999},
  {i:27, icon:'🌐', name:'Réseau Infini',    desc:'6.5M BTC/sec',    cost:1e22,                   speed:6500000,   max:999},
