const MILESTONES = [
  { key:'m100',    check:()=>totalMined>=100,     icon:'₿',  color:'#F7931A', label:()=>(LANGS[currentLang]?.notifBtc||'BTC mined'),    value:()=>'100 BTC' },
  { key:'m1k',     check:()=>totalMined>=1000,    icon:'💰', color:'#F7931A', label:()=>(LANGS[currentLang]?.notifBtc||'BTC mined'),    value:()=>'1,000 BTC' },
  { key:'m10k',    check:()=>totalMined>=10000,   icon:'💎', color:'#627EEA', label:()=>(LANGS[currentLang]?.notifBtc||'BTC mined'),    value:()=>'10,000 BTC' },
