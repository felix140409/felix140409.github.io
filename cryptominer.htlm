  // Tier 6 — divin
  {i:20, icon:'🌀', name:'Vortex Éternel',   desc:'450 000 BTC/sec', cost:15000000000000000,      speed:450000,    max:999},
  {i:21, icon:'👁',  name:'Œil Omniscient',  desc:'650 000 BTC/sec', cost:80000000000000000,      speed:650000,    max:999},
  {i:22, icon:'🔮', name:'Cristal Divin',    desc:'950 000 BTC/sec', cost:500000000000000000,     speed:950000,    max:999},
  // Tier 7 — cosmique extrême
  {i:23, icon:'💫', name:'Supernova Bot',    desc:'1.4M BTC/sec',    cost:3000000000000000000,    speed:1400000,   max:999},
