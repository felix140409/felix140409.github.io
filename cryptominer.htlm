<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>CRYPTO MINER</title>
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4355916824484692" crossorigin="anonymous"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root {
  --neon-green: #00FF88;
  --neon-blue:  #00D4FF;
  --neon-gold:  #FFD700;
  --neon-orange:#F7931A;
  --dark:       #020408;
  --dark2:      #060C14;
  --dark3:      #0A1220;
  /* Skin variables (overridden by JS) */
  --skin-accent:  #F7931A;
  --skin-accent2: #627EEA;
  --skin-tab:     #F7931A;
  --skin-border:  #111B2E;
  --skin-card:    rgba(13,20,32,.6);
  --skin-text:    #E8F0FF;
  --skin-dim:     #445577;
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100vw;height:100vh;overflow:hidden;background:var(--dark);font-family:'Orbitron',monospace;user-select:none;}

/* ── LAYERS ── */
#layer-bg    {position:fixed;inset:0;z-index:0;}
#layer-fx    {position:fixed;inset:0;z-index:2;pointer-events:none;}
#layer-glitch{position:fixed;inset:0;z-index:8;pointer-events:none;opacity:0;}
#layer-ui    {position:fixed;inset:0;z-index:10;}
#flash       {position:fixed;inset:0;z-index:90;pointer-events:none;background:#fff;opacity:0;}
#flash-green {position:fixed;inset:0;z-index:89;pointer-events:none;background:var(--neon-green);opacity:0;}

/* ── SCANLINES ── */
#scanlines{position:fixed;inset:0;z-index:5;pointer-events:none;
  background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,255,136,.012) 2px,rgba(0,255,136,.012) 4px);}

/* ── VIGNETTE ── */
#vignette{position:fixed;inset:0;z-index:4;pointer-events:none;
  background:radial-gradient(ellipse at center,transparent 25%,rgba(0,0,0,.97) 100%);}

/* ─────────────────────────────────────────
   INTRO SCREEN
───────────────────────────────────────── */
#intro{position:fixed;inset:0;z-index:20;display:flex;align-items:center;justify-content:center;flex-direction:column;}

.cin-line{
  position:absolute;text-align:center;
  font-family:'Share Tech Mono',monospace;
  font-size:clamp(12px,2.2vw,22px);
  color:rgba(255,255,255,.85);
  letter-spacing:.08em;line-height:1.8;
  opacity:0;width:80vw;max-width:700px;
  text-shadow:0 0 20px rgba(255,255,255,.3);
}

/* Bitcoin symbol */
#btc-symbol{
  position:absolute;opacity:0;
  font-size:clamp(60px,15vw,160px);
  font-weight:900;color:var(--neon-gold);
  text-shadow:0 0 40px var(--neon-gold),0 0 80px rgba(255,215,0,.5),0 0 160px rgba(255,215,0,.2);
  filter:drop-shadow(0 0 30px var(--neon-gold));
  transform:scale(.5);
}

/* Data tunnel */
#tunnel{position:fixed;inset:0;z-index:15;pointer-events:none;opacity:0;}

/* LOGO FINAL */
#logo-final{
  position:absolute;text-align:center;opacity:0;
  transform:scale(.3) translateY(20px);
  width:90vw;
}
#logo-final h1{
  font-size:clamp(32px,8vw,90px);font-weight:900;
  color:transparent;
  background:linear-gradient(135deg,var(--neon-gold),#fff,var(--neon-gold));
  -webkit-background-clip:text;background-clip:text;
  letter-spacing:.15em;
  filter:drop-shadow(0 0 30px var(--neon-gold));
  text-shadow:none;
}
#logo-smoke{
  position:absolute;width:100%;height:120px;
  background:radial-gradient(ellipse at center,rgba(0,255,136,.08) 0%,transparent 70%);
  bottom:-20px;filter:blur(20px);opacity:0;
}
.logo-tagline{
  font-size:clamp(7px,1.2vw,13px);letter-spacing:.5em;
  color:var(--neon-green);margin-top:14px;opacity:0;
  text-shadow:0 0 15px var(--neon-green);
  font-family:'Share Tech Mono',monospace;
}
.logo-tagline2{
  font-size:clamp(7px,1vw,11px);letter-spacing:.4em;
  color:var(--neon-blue);margin-top:8px;opacity:0;
  text-shadow:0 0 10px var(--neon-blue);
  font-family:'Share Tech Mono',monospace;
}

/* ─────────────────────────────────────────
   LANG SCREEN
───────────────────────────────────────── */
#lang-screen{
  position:fixed;inset:0;z-index:30;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:32px;opacity:0;pointer-events:none;
}
.lang-title{
  font-size:clamp(14px,3vw,28px);font-weight:700;letter-spacing:.4em;
  color:var(--neon-green);
  text-shadow:0 0 30px var(--neon-green),0 0 60px rgba(0,255,136,.3);
  margin-bottom:8px;
}
.lang-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;width:min(420px,80vw);}
.lang-btn{
  padding:14px 20px;border-radius:2px;cursor:pointer;
  background:rgba(0,255,136,.04);
  border:1px solid rgba(0,255,136,.25);
  color:var(--neon-green);
  font-family:'Orbitron',monospace;font-size:clamp(9px,1.3vw,12px);font-weight:700;
  letter-spacing:.2em;text-transform:uppercase;
  display:flex;align-items:center;gap:10px;justify-content:center;
  transition:all .2s;position:relative;overflow:hidden;
}
.lang-btn::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(90deg,transparent,rgba(0,255,136,.08),transparent);
  transform:translateX(-100%);transition:transform .4s;
}
.lang-btn:hover::before{transform:translateX(100%);}
.lang-btn:hover{
  background:rgba(0,255,136,.12);border-color:var(--neon-green);
  box-shadow:0 0 20px rgba(0,255,136,.3),inset 0 0 20px rgba(0,255,136,.05);
  transform:scale(1.04);color:#fff;
}
.lang-btn:active{transform:scale(.98);}
.lang-flag{font-size:20px;}
.lang-btn.full{grid-column:1/-1;}
.lang-divider{
  width:1px;height:60px;background:linear-gradient(to bottom,transparent,var(--neon-green),transparent);
  opacity:.3;
}

/* ─────────────────────────────────────────
   MAIN MENU
───────────────────────────────────────── */
#menu-screen{
  position:fixed;inset:0;z-index:30;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:0;opacity:0;pointer-events:none;
}
.menu-logo{
  font-size:clamp(22px,5vw,52px);font-weight:900;
  color:transparent;
  background:linear-gradient(135deg,var(--neon-gold),#fff,var(--neon-gold));
  -webkit-background-clip:text;background-clip:text;
  letter-spacing:.18em;
  filter:drop-shadow(0 0 20px var(--neon-gold));
  margin-bottom:6px;
}
.menu-sub{
  font-size:clamp(6px,1vw,9px);letter-spacing:.5em;color:var(--neon-green);
  margin-bottom:48px;font-family:'Share Tech Mono',monospace;
  text-shadow:0 0 10px var(--neon-green);
}
.menu-btn{
  width:min(320px,70vw);padding:15px 32px;margin-bottom:12px;
  border-radius:2px;cursor:pointer;
  background:rgba(0,212,255,.04);
  border:1px solid rgba(0,212,255,.2);
  color:var(--neon-blue);
  font-family:'Orbitron',monospace;font-size:clamp(10px,1.5vw,14px);font-weight:700;
  letter-spacing:.25em;text-transform:uppercase;
  display:flex;align-items:center;justify-content:center;gap:12px;
  transition:all .2s;position:relative;overflow:hidden;
}
.menu-btn::before{
  content:'';position:absolute;left:-100%;top:0;width:100%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(0,212,255,.1),transparent);
  transition:left .4s;
}
.menu-btn:hover::before{left:100%;}
.menu-btn:hover{
  background:rgba(0,212,255,.1);border-color:var(--neon-blue);
  box-shadow:0 0 25px rgba(0,212,255,.35),inset 0 0 25px rgba(0,212,255,.05);
  transform:scale(1.03);color:#fff;
}
.menu-btn.primary{
  border-color:rgba(0,255,136,.4);color:var(--neon-green);background:rgba(0,255,136,.06);
}
.menu-btn.primary::before{background:linear-gradient(90deg,transparent,rgba(0,255,136,.12),transparent);}
.menu-btn.primary:hover{
  background:rgba(0,255,136,.12);border-color:var(--neon-green);
  box-shadow:0 0 30px rgba(0,255,136,.4),inset 0 0 30px rgba(0,255,136,.06);
}
.menu-btn.danger{border-color:rgba(255,50,50,.3);color:#FF4560;background:rgba(255,69,96,.04);}
.menu-btn.danger:hover{background:rgba(255,69,96,.1);border-color:#FF4560;box-shadow:0 0 25px rgba(255,69,96,.35);}

/* ─────────────────────────────────────────
   OPTIONS
───────────────────────────────────────── */
#options-screen{
  position:fixed;inset:0;z-index:35;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;
  background:rgba(2,4,8,.92);backdrop-filter:blur(10px);
}
.opts-box{
  width:min(480px,88vw);border:1px solid rgba(0,212,255,.2);
  border-radius:4px;padding:32px;background:rgba(6,12,20,.9);
  box-shadow:0 0 60px rgba(0,212,255,.08);
}
.opts-title{font-size:clamp(12px,2vw,18px);font-weight:700;color:var(--neon-blue);letter-spacing:.3em;margin-bottom:28px;text-align:center;
  text-shadow:0 0 20px var(--neon-blue);}
.opts-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;}
.opts-label{font-size:10px;color:rgba(0,212,255,.7);letter-spacing:.2em;font-family:'Share Tech Mono',monospace;}
.opts-slider{-webkit-appearance:none;appearance:none;width:160px;height:2px;
  background:rgba(0,212,255,.2);border-radius:2px;outline:none;cursor:pointer;}
.opts-slider::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;
  background:var(--neon-blue);box-shadow:0 0 10px var(--neon-blue);cursor:pointer;}
.opts-select{background:rgba(0,212,255,.06);border:1px solid rgba(0,212,255,.2);
  color:var(--neon-blue);padding:6px 10px;font-family:'Orbitron',monospace;font-size:9px;letter-spacing:.15em;
  border-radius:2px;cursor:pointer;outline:none;}
.opts-close{margin-top:24px;width:100%;padding:12px;border-radius:2px;cursor:pointer;
  background:rgba(0,212,255,.06);border:1px solid rgba(0,212,255,.2);
  color:var(--neon-blue);font-family:'Orbitron',monospace;font-size:10px;letter-spacing:.2em;
  transition:all .2s;}
.opts-close:hover{background:rgba(0,212,255,.12);box-shadow:0 0 20px rgba(0,212,255,.3);}

/* ─────────────────────────────────────────
   QUIT POPUP
───────────────────────────────────────── */
#quit-popup{
  position:fixed;inset:0;z-index:40;
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;
  background:rgba(2,4,8,.88);backdrop-filter:blur(8px);
}
.quit-box{
  width:min(360px,80vw);border:1px solid rgba(255,69,96,.3);
  border-radius:4px;padding:32px;text-align:center;
  background:rgba(6,12,20,.95);
  box-shadow:0 0 60px rgba(255,69,96,.1);
}
.quit-title{font-size:clamp(11px,1.8vw,16px);color:#FF4560;letter-spacing:.2em;margin-bottom:8px;font-weight:700;
  text-shadow:0 0 20px #FF4560;}
.quit-sub{font-size:9px;color:rgba(255,255,255,.4);letter-spacing:.2em;margin-bottom:28px;font-family:'Share Tech Mono',monospace;}
.quit-btns{display:flex;gap:12px;justify-content:center;}
.quit-yes,.quit-no{
  flex:1;padding:12px;border-radius:2px;cursor:pointer;
  font-family:'Orbitron',monospace;font-size:10px;font-weight:700;letter-spacing:.2em;
  transition:all .2s;
}
.quit-yes{background:rgba(255,69,96,.1);border:1px solid rgba(255,69,96,.4);color:#FF4560;}
.quit-yes:hover{background:rgba(255,69,96,.2);box-shadow:0 0 20px rgba(255,69,96,.3);}
.quit-no{background:rgba(0,255,136,.06);border:1px solid rgba(0,255,136,.3);color:var(--neon-green);}
.quit-no:hover{background:rgba(0,255,136,.12);box-shadow:0 0 20px rgba(0,255,136,.3);}

/* ─────────────────────────────────────────
   SKIP
───────────────────────────────────────── */
#skip-btn{
  position:fixed;bottom:20px;right:24px;z-index:99;
  font-family:'Share Tech Mono',monospace;font-size:9px;color:rgba(0,255,136,.35);
  letter-spacing:.25em;cursor:pointer;
  border:1px solid rgba(0,255,136,.12);padding:7px 14px;border-radius:2px;
  background:rgba(0,0,0,.5);transition:all .2s;text-transform:uppercase;
  backdrop-filter:blur(4px);
}
#skip-btn:hover{color:var(--neon-green);border-color:rgba(0,255,136,.4);box-shadow:0 0 15px rgba(0,255,136,.2);}

/* ─────────────────────────────────────────
   PARTICLES LAYER (canvas bg items)
───────────────────────────────────────── */
.float-particle{position:fixed;border-radius:50%;pointer-events:none;z-index:1;}

/* ─────────────────────────────────────────
   DATA CODE STREAM
───────────────────────────────────────── */
#code-stream{position:fixed;inset:0;z-index:3;pointer-events:none;overflow:hidden;opacity:0;}
.code-col{
  position:absolute;top:-100%;
  font-family:'Share Tech Mono',monospace;font-size:12px;
  color:var(--neon-green);opacity:.15;
  white-space:nowrap;line-height:1.4;
  animation:codefall linear infinite;
}
@keyframes codefall{from{transform:translateY(0)}to{transform:translateY(200vh)}}

/* corner decorations */
.corner{position:fixed;width:50px;height:50px;z-index:6;opacity:0;}
.corner.tl{top:16px;left:16px;border-top:1px solid rgba(0,255,136,.4);border-left:1px solid rgba(0,255,136,.4);}
.corner.tr{top:16px;right:16px;border-top:1px solid rgba(0,255,136,.4);border-right:1px solid rgba(0,255,136,.4);}
.corner.bl{bottom:16px;left:16px;border-bottom:1px solid rgba(0,255,136,.4);border-left:1px solid rgba(0,255,136,.4);}
.corner.br{bottom:16px;right:16px;border-bottom:1px solid rgba(0,255,136,.4);border-right:1px solid rgba(0,255,136,.4);}

/* ═══════════════ CRYPTOMINER GAME CSS ═══════════════ */

* { box-sizing:border-box; margin:0; padding:0; }
body { background:#080C14; color:#E8F0FF; font-family:'Space Mono',monospace; height:100dvh; display:flex; flex-direction:column; overflow:hidden; user-select:none; }
body::before { content:""; position:fixed; inset:0; background-image:linear-gradient(rgba(99,126,234,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(99,126,234,.04) 1px,transparent 1px); background-size:40px 40px; pointer-events:none; }

/* HAUT */
.top { display:flex; align-items:center; gap:14px; padding:10px 16px 9px; border-bottom:1px solid #111B2E; flex-shrink:0; }
.btc-block { flex:1; }
.btc-label { font-size:9px; color:#445577; letter-spacing:.14em; margin-bottom:1px; }
.btc-value { font-size:20px; font-weight:700; color:#F7931A; line-height:1; }
.btc-value span { font-size:10px; color:#8899BB; margin-left:3px; }
.btc-sub { font-size:8px; color:#627EEA; margin-top:2px; }
.btc-auto { font-size:8px; color:#00D97E; }

/* Bouton settings */
.settings-btn { width:32px; height:32px; border-radius:8px; background:#0D1420; border:1px solid #1A2840; color:#8899BB; font-size:14px; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:border-color .15s,color .15s; }
.settings-btn:hover { border-color:#627EEA; color:#E8F0FF; }

/* Bouton mine */
.mine-btn {
  width:84px; height:84px; border-radius:50%;
  background:var(--btn-bg,radial-gradient(circle at 38% 35%,#1a2a4a,#080c14));
  border:2px solid var(--btn-border,#1A2840);
  cursor:pointer; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:3px;
  position:relative; flex-shrink:0; overflow:hidden;
  transition:transform .08s cubic-bezier(.34,1.56,.64,1),border-color .1s,box-shadow .1s;
  -webkit-tap-highlight-color:transparent; outline:none; color:inherit;
}
.mine-btn:hover { border-color:var(--btn-glow,#F7931A); box-shadow:0 0 24px var(--btn-shadow,rgba(247,147,26,.2)); }
.mine-btn.pressed { transform:scale(.86); border-color:var(--btn-glow,#F7931A); box-shadow:0 0 40px var(--btn-shadow,rgba(247,147,26,.35)); }
.mine-btn::before,.mine-btn::after { content:""; position:absolute; width:11px; height:11px; border-style:solid; border-color:var(--btn-glow,#627EEA); opacity:.4; }
.mine-btn::before { top:7px; left:7px; border-width:1.5px 0 0 1.5px; }
.mine-btn::after  { bottom:7px; right:7px; border-width:0 1.5px 1.5px 0; }
.mine-btn:hover::before,.mine-btn:hover::after { opacity:1; }
.scan-line { position:absolute; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,var(--btn-glow,#627EEA55),transparent); animation:scan 2.5s linear infinite; }
@keyframes scan { from{top:0} to{top:100%} }
.mine-icon  { font-size:24px; line-height:1; pointer-events:none; font-family:"Segoe UI Emoji","Apple Color Emoji","Noto Color Emoji",sans-serif; }
.mine-label { font-size:7px; color:#445577; letter-spacing:.16em; pointer-events:none; }

/* float */
.float-txt { position:fixed; font-size:13px; font-weight:700; color:var(--btn-glow,#F7931A); pointer-events:none; animation:floatUp .8s ease-out forwards; z-index:5999; }
@keyframes floatUp { 0%{opacity:1;transform:translateY(0) scale(1)} 100%{opacity:0;transform:translateY(-48px) scale(.7)} }

/* ONGLETS */
.tabs { display:flex; border-bottom:1px solid #111B2E; flex-shrink:0; overflow-x:auto; }
.tabs::-webkit-scrollbar { display:none; }
.tab { flex-shrink:0; padding:8px 10px; font-family:'Space Mono',monospace; font-size:8px; letter-spacing:.08em; color:#445577; background:transparent; border:none; cursor:pointer; border-bottom:2px solid transparent; transition:color .15s,border-color .15s; white-space:nowrap; }
.tab.active { color:#F7931A; border-bottom-color:#F7931A; }

/* PANELS */
.panel { flex:1; overflow-y:auto; padding:8px 12px 12px; }
.panel.hidden { display:none; }
.panel::-webkit-scrollbar { width:3px; }
.panel::-webkit-scrollbar-thumb { background:#1A2840; }
.section-title { font-size:8px; color:#445577; letter-spacing:.16em; margin:8px 0 6px; }

/* ITEMS */
.upg-item { display:flex; align-items:center; gap:10px; padding:9px 11px; border:1px solid #111B2E; border-radius:8px; margin-bottom:5px; background:rgba(13,20,32,.6); transition:border-color .15s,background .15s; cursor:pointer; position:relative; overflow:hidden; }
.upg-item:hover       { border-color:#1A2840; background:rgba(26,40,64,.4); }
.upg-item.can-buy     { border-color:#F7931A88; box-shadow:0 0 10px rgba(247,147,26,.2), inset 0 0 12px rgba(247,147,26,.06); animation: canBuyPulse 2s ease-in-out infinite; }
.upg-item.can-buy::after {
  content:'';
  position:absolute; top:0; left:-100%; width:60%; height:100%;
  background:linear-gradient(90deg, transparent, rgba(247,147,26,.18), transparent);
  animation: canBuyShimmer 2s ease-in-out infinite;
  pointer-events:none;
}
.upg-item.can-buy:hover { border-color:#F7931A; background:rgba(247,147,26,.08); box-shadow:0 0 18px rgba(247,147,26,.35), inset 0 0 20px rgba(247,147,26,.08); }
.upg-item.maxed       { opacity:.32; cursor:default; }
@keyframes canBuyPulse {
  0%,100% { box-shadow:0 0 8px rgba(247,147,26,.2), inset 0 0 10px rgba(247,147,26,.05); }
  50%     { box-shadow:0 0 18px rgba(247,147,26,.45), inset 0 0 18px rgba(247,147,26,.12); }
}
@keyframes canBuyShimmer {
  0%   { left:-100%; opacity:0; }
  20%  { opacity:1; }
  80%  { opacity:1; }
  100% { left:160%; opacity:0; }
}
.upg-icon { font-size:20px; width:36px; height:36px; display:flex; align-items:center; justify-content:center; background:#0D1420; border-radius:8px; flex-shrink:0; font-family:'Segoe UI Emoji','Apple Color Emoji','Noto Color Emoji',sans-serif; line-height:1; font-style:normal; }
.upg-info { flex:1; min-width:0; }
.upg-name { font-size:10px; font-weight:700; color:#E8F0FF; }
.upg-desc { font-size:8px; color:#445577; margin-top:1px; }
.upg-right { text-align:right; flex-shrink:0; }
.upg-cost { font-size:10px; font-weight:700; color:#8899BB; }
.upg-cost.affordable { color:#F7931A; }
.upg-level { font-size:7px; color:#445577; margin-top:2px; }

/* MARCHÉ */
.market-input-row { display:flex; align-items:center; gap:8px; margin-bottom:10px; }
.market-label { font-size:9px; color:#445577; letter-spacing:.12em; flex-shrink:0; }
.market-input { flex:1; background:#0D1420; border:1px solid #1A2840; border-radius:6px; padding:7px 10px; font-family:'Space Mono',monospace; font-size:13px; font-weight:700; color:#F7931A; outline:none; }
.market-input:focus { border-color:#F7931A44; }
.market-input::placeholder { color:#2a3a56; }
.market-currency { font-size:10px; color:#627EEA; flex-shrink:0; }
.btn-max { background:#111B2E; border:1px solid #1A2840; border-radius:5px; color:#627EEA; font-family:'Space Mono',monospace; font-size:9px; padding:5px 9px; cursor:pointer; transition:border-color .15s; }
.btn-max:hover { border-color:#627EEA; color:#E8F0FF; }
.diff-grid { display:grid; grid-template-columns:1fr 1fr; gap:7px; }
.diff-card { border:1px solid #1A2840; border-radius:10px; padding:11px 10px; background:rgba(13,20,32,.7); cursor:pointer; transition:border-color .15s,background .15s,transform .1s; display:flex; flex-direction:column; gap:5px; position:relative; overflow:hidden; }
.diff-card:hover { transform:translateY(-1px); } .diff-card:active { transform:scale(.97); }
.diff-card.cooldown { cursor:not-allowed; opacity:0.55; pointer-events:none; }
.diff-cooldown-bar { position:absolute; bottom:0; left:0; height:3px; background:linear-gradient(90deg,#627EEA,#00D4FF); transition:width .1s linear; border-radius:0 0 10px 10px; }
.diff-cooldown-label { font-size:9px; color:#627EEA; font-family:'Space Mono',monospace; margin-top:2px; letter-spacing:.05em; min-height:13px; }
#diff-facile    { border-color:#00D97E33; } #diff-facile:hover    { border-color:#00D97E; background:rgba(0,217,126,.06); }
#diff-normal    { border-color:#627EEA33; } #diff-normal:hover    { border-color:#627EEA; background:rgba(99,126,234,.06); }
#diff-difficile { border-color:#F7931A33; } #diff-difficile:hover { border-color:#F7931A; background:rgba(247,147,26,.06); }
.diff-impossible { border-color:#FF456033!important; } .diff-impossible:hover { border-color:#FF4560!important; background:rgba(255,69,96,.06)!important; }
.diff-name  { font-size:10px; font-weight:700; color:#E8F0FF; }
.diff-stats { display:flex; flex-direction:column; gap:3px; }
.diff-stat  { font-size:8px; } .diff-stat.win { color:#00D97E; } .diff-stat.lose { color:#FF4560; } .diff-stat strong { font-weight:700; }
.diff-chance { font-size:10px; font-weight:700; color:#FFD166; }
.diff-example { font-size:9px; color:#627EEA; border-top:1px solid #111B2E; padding-top:4px; margin-top:1px; }
.market-result { margin-top:10px; border-radius:10px; padding:13px; display:flex; align-items:center; justify-content:center; gap:10px; font-size:15px; font-weight:700; animation:popIn .35s cubic-bezier(.34,1.56,.64,1); }
.market-result.hidden { display:none; } .market-result.win { background:rgba(0,217,126,.1); border:1px solid #00D97E; color:#00D97E; } .market-result.lose { background:rgba(255,69,96,.1); border:1px solid #FF4560; color:#FF4560; }
@keyframes popIn { from{opacity:0;transform:scale(.8)} to{opacity:1;transform:scale(1)} }

/* STATS */
.stats-grid { display:grid; grid-template-columns:1fr 1fr; gap:7px; }
.stat-card { background:rgba(13,20,32,.7); border:1px solid #111B2E; border-radius:9px; padding:10px; }
.stat-label { font-size:8px; color:#445577; letter-spacing:.1em; margin-bottom:3px; }
.stat-val   { font-size:14px; font-weight:700; }

/* TROPHÉES */
.ach-grid { display:grid; grid-template-columns:1fr 1fr; gap:7px; }
.ach-card { border:1px solid #111B2E; border-radius:9px; padding:10px; background:rgba(13,20,32,.7); display:flex; align-items:center; gap:9px; transition:border-color .3s; }
.ach-card.unlocked { border-color:#FFD16655; background:rgba(255,209,102,.04); }
.ach-icon-wrap { font-size:22px; flex-shrink:0; filter:grayscale(1); transition:filter .3s; font-family:"Segoe UI Emoji","Apple Color Emoji","Noto Color Emoji",sans-serif; }
.ach-card.unlocked .ach-icon-wrap { filter:none; }
.ach-name { font-size:9px; font-weight:700; color:#445577; }
.ach-card.unlocked .ach-name { color:#FFD166; }
.ach-cond { font-size:7px; color:#2a3a56; margin-top:2px; }
.ach-card.unlocked .ach-cond { color:#8899BB; }

/* SKINS */
.skin-grid { display:grid; grid-template-columns:1fr 1fr; gap:7px; }
.skin-card { border:1px solid #111B2E; border-radius:9px; padding:9px; background:rgba(13,20,32,.7); cursor:pointer; display:flex; align-items:center; gap:9px; transition:border-color .15s,background .15s; }
.skin-card:hover { border-color:#243652; background:rgba(26,40,64,.4); }
.skin-card.active { border-color:var(--skin-accent) !important; background:rgba(0,0,0,.2) !important; box-shadow:0 0 12px var(--skin-accent)44; }
.skin-preview { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; font-family:"Segoe UI Emoji","Apple Color Emoji","Noto Color Emoji",sans-serif; }
.skin-name { font-size:9px; font-weight:700; color:var(--skin-text); }
.skin-sub  { font-size:7px; color:var(--skin-dim); margin-top:1px; }
.skin-price { font-size:8px; color:var(--skin-accent); margin-top:2px; }
.skin-price.owned { color:#00D97E; }

/* ── Skin theming on UI elements ── */
.tab.active          { color:var(--skin-tab) !important; border-bottom-color:var(--skin-tab) !important; }
.btc-value           { color:var(--skin-accent) !important; }
.btc-sub             { color:var(--skin-accent2) !important; }
.upg-item            { border-color:var(--skin-border) !important; background:var(--skin-card) !important; }
.upg-item.can-buy    { border-color:var(--skin-accent) !important; box-shadow:0 0 8px var(--skin-accent)33; }
.section-title       { color:var(--skin-dim) !important; }
.upg-cost.affordable { color:var(--skin-accent) !important; }
.stat-card           { border-color:var(--skin-border) !important; background:var(--skin-card) !important; }
.ach-card            { border-color:var(--skin-border) !important; background:var(--skin-card) !important; }
.top                 { border-bottom-color:var(--skin-border) !important; }
.tabs                { border-bottom-color:var(--skin-border) !important; }
.nab-track           { background:var(--skin-border) !important; }
.nab-fill            { background:linear-gradient(90deg,var(--skin-accent2),var(--skin-accent)) !important; }
.prestige-bar        { background:rgba(0,0,0,.3) !important; border-bottom-color:var(--skin-border) !important; }
.prest-title         { color:var(--skin-accent) !important; }
.rival-bar           { border-bottom-color:var(--skin-border) !important; background:var(--skin-card) !important; }
.music-bar           { border-top-color:var(--skin-border) !important; background:transparent !important; }
.music-btn           { border-color:var(--skin-border) !important; color:var(--skin-accent2) !important; }
.toggle-btn.on       { background:color-mix(in srgb,var(--skin-accent) 25%,transparent) !important; border-color:var(--skin-accent) !important; }
.toggle-btn.on::after{ background:var(--skin-accent) !important; }

/* PARAMÈTRES */
/* ══ SETTINGS REDESIGN ══ */
.settings-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.75);
  z-index: 100;
  display: flex; align-items: flex-end; justify-content: center;
}
.settings-overlay.hidden { display: none; }
.settings-box {
  background: #0D1420;
  border: 1px solid #1A2840;
  border-radius: 18px 18px 0 0;
  width: min(480px, 100vw);
  max-height: 88vh;
  display: flex; flex-direction: column;
  overflow: hidden;
}
.settings-title {
  font-size: 12px; font-weight: 700; color: #E8F0FF;
  display: flex; justify-content: space-between; align-items: center;
  padding: 16px 20px 12px; flex-shrink: 0;
  border-bottom: 1px solid #111B2E;
}
.settings-close {
  background: none; border: none; color: #445577;
  font-size: 18px; cursor: pointer; padding: 2px 6px; border-radius: 6px;
}
.settings-close:hover { color: #E8F0FF; background: rgba(255,255,255,.05); }

/* Scrollable body */
.settings-body {
  overflow-y: auto; flex: 1;
  padding: 0 20px 20px;
}
.settings-body::-webkit-scrollbar { width: 3px; }
.settings-body::-webkit-scrollbar-thumb { background: #1A2840; border-radius: 2px; }

.settings-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 11px 0; border-bottom: 1px solid #111B2E;
}
.settings-row:last-child { border-bottom: none; }
.settings-label { font-size: 10px; color: #8899BB; }

/* Section headers */
.settings-section-title {
  font-size: 8px; letter-spacing: .18em; color: #445577;
  text-transform: uppercase; margin: 14px 0 4px;
}

/* Language picker — top, horizontal scroll */
.lang-picker-wrap {
  display: flex; gap: 7px; overflow-x: auto; padding: 4px 0 2px;
  scrollbar-width: none;
}
.lang-picker-wrap::-webkit-scrollbar { display: none; }
.lang-pick-btn {
  flex-shrink: 0; padding: 8px 14px; border-radius: 10px;
  border: 1.5px solid #1A2840; background: rgba(13,20,32,.8);
  cursor: pointer; transition: all .15s;
  font-family: 'Space Mono', monospace; font-size: 11px;
  font-weight: 700; color: #E8F0FF; letter-spacing: .04em;
  display: flex; flex-direction: column; align-items: center; gap: 3px;
  min-width: 68px;
}
.lang-pick-btn .lp-flag { font-size: 22px; }
.lang-pick-btn .lp-name { font-size: 8px; color: #8899BB; letter-spacing: .06em; }
.lang-pick-btn:hover { border-color: #627EEA; background: rgba(99,126,234,.08); transform: translateY(-2px); }
.lang-pick-btn.active { border-color: #F7931A !important; background: rgba(247,147,26,.08) !important; }
.lang-pick-btn.active .lp-name { color: #F7931A; }

/* Theme picker — bottom, 3 cards */
.theme-picker-wrap {
  display: flex; gap: 8px; padding: 4px 0 2px;
}
.theme-pick-card {
  flex: 1; padding: 12px 8px; border-radius: 12px;
  border: 1.5px solid #1A2840;
  cursor: pointer; transition: all .18s;
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  position: relative; overflow: hidden;
}
.theme-pick-card:hover { transform: translateY(-2px); }
.theme-pick-card.active { border-color: var(--t-glow) !important; box-shadow: 0 0 16px var(--t-shadow); }
.theme-pick-card .t-icon { font-size: 22px; }
.theme-pick-card .t-name { font-size: 8px; font-weight: 700; color: #8899BB; letter-spacing: .08em; }
.theme-pick-card .t-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--t-glow); opacity: 0;
  position: absolute; top: 8px; right: 8px;
  transition: opacity .2s;
}
.theme-pick-card.active .t-dot { opacity: 1; }

/* Night card */
#tcard-night {
  background: linear-gradient(160deg,#080C14,#0d1a2e);
  --t-glow: #627EEA; --t-shadow: rgba(99,126,234,.2);
}
#tcard-night:hover { border-color: #627EEA55; }

/* Day card */
#tcard-day {
  background: linear-gradient(160deg,#E8EEFF,#F0F4FF);
  --t-glow: #F7931A; --t-shadow: rgba(247,147,26,.2);
}
#tcard-day .t-name { color: #8899BB; }
#tcard-day:hover { border-color: #F7931A55; }

/* Sakura card */
#tcard-sakura {
  background: linear-gradient(160deg,#1a0010,#2d0a1e);
  --t-glow: #FF69B4; --t-shadow: rgba(255,105,180,.25);
}
#tcard-sakura .t-name { color: rgba(255,182,193,.7); }
#tcard-sakura:hover { border-color: #FF69B455; }
/* Tiny petals on sakura card */
#tcard-sakura::before {
  content: '🌸';
  position: absolute; font-size: 28px; opacity: .08;
  bottom: -4px; right: -4px;
}
.settings-label { font-size:10px; color:#8899BB; }
.toggle-btn { width:42px; height:22px; border-radius:11px; background:#111B2E; border:1px solid #1A2840; cursor:pointer; position:relative; transition:background .2s; }
.toggle-btn.on { background:#F7931A44; border-color:#F7931A; }
.toggle-btn::after { content:""; position:absolute; top:3px; left:3px; width:14px; height:14px; border-radius:50%; background:#445577; transition:left .2s,background .2s; }
.toggle-btn.on::after { left:23px; background:#F7931A; }
.btn-danger { background:rgba(255,69,96,.1); border:1px solid #FF456055; color:#FF4560; font-family:'Space Mono',monospace; font-size:9px; padding:7px 14px; border-radius:6px; cursor:pointer; transition:background .15s; }
.btn-danger:hover { background:rgba(255,69,96,.2); }

/* TOAST & POPUP */
.toast { position:fixed; bottom:20px; left:50%; transform:translateX(-50%) translateY(60px); background:#0D1420; border:1px solid #00D97E; border-radius:8px; padding:8px 16px; font-size:10px; color:#00D97E; transition:transform .3s cubic-bezier(.34,1.56,.64,1); z-index:50; white-space:nowrap; }
.toast.show { transform:translateX(-50%) translateY(0); }
.ach-popup { position:fixed; top:14px; right:14px; background:#0D1420; border:1px solid #FFD166; border-radius:10px; padding:10px 13px; display:flex; align-items:center; gap:10px; transform:translateX(120%); transition:transform .4s cubic-bezier(.34,1.56,.64,1); z-index:60; }
.ach-popup.show { transform:translateX(0); }
.ach-popup-icon { font-size:20px; }
.ach-popup-title { font-size:9px; color:#FFD166; font-weight:700; }
.ach-popup-sub { font-size:7px; color:#8899BB; margin-top:2px; }

/* ── BARRE PROCHAIN TROPHÉE ── */
.next-ach-bar {
  padding: 6px 16px 5px;
  border-bottom: 1px solid #111B2E;
  flex-shrink: 0;
}
.nab-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 4px;
}
.nab-label { font-size: 7px; color: #445577; letter-spacing: .12em; }
.nab-name  { font-size: 8px; color: #FFD166; font-weight: 700; }
.nab-pct   { font-size: 7px; color: #8899BB; }
.nab-track {
  height: 3px; background: #111B2E; border-radius: 2px; overflow: hidden;
}
.nab-fill {
  height: 100%;
  background: linear-gradient(90deg, #627EEA, #FFD166);
  border-radius: 2px;
  transition: width .4s ease;
}

/* ── FONDS ── */
.bg-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-top:6px; }
.bg-opt {
  height:52px; border-radius:8px; border:2px solid #1A2840;
  cursor:pointer; display:flex; align-items:center; justify-content:center;
  font-size:9px; color:#8899BB; letter-spacing:.08em; text-align:center;
  transition:border-color .15s, transform .1s;
  position:relative; overflow:hidden;
}
.bg-opt:hover { border-color:#627EEA; transform:scale(1.03); }
.bg-opt.active { border-color:#FFD166 !important; }
.bg-opt span { position:relative; z-index:1; text-shadow:0 1px 3px rgba(0,0,0,.8); font-weight:700; }

/* confirm box */
.confirm-box {
  margin-top: 12px; padding: 12px; border-radius: 10px;
  background: rgba(255,69,96,.08); border: 1px solid #FF456055;
  text-align: center;
}
.confirm-box.hidden { display: none; }
.confirm-msg { font-size: 10px; color: #FF4560; margin-bottom: 10px; line-height: 1.5; }
.confirm-btns { display: flex; gap: 8px; justify-content: center; }
.btn-cancel { background: #111B2E; border: 1px solid #1A2840; border-radius: 6px; color: #8899BB; font-family:'Space Mono',monospace; font-size: 9px; padding: 7px 14px; cursor: pointer; }
.btn-cancel:hover { border-color: #627EEA; color: #E8F0FF; }

/* ── CHART RANGE BUTTONS ── */
.chart-range-btn {
  padding:4px 10px;border-radius:6px;font-size:8px;font-family:'Space Mono',monospace;
  letter-spacing:.08em;cursor:pointer;border:1px solid #1A2840;
  background:rgba(13,20,32,.6);color:#445577;transition:all .15s;
}
.chart-range-btn.active { border-color:#F7931A;color:#F7931A;background:rgba(247,147,26,.08); }
.chart-range-btn:hover  { border-color:#627EEA;color:#E8F0FF; }
.objectives-bar {
  padding: 5px 12px;
  border-bottom: 1px solid #111B2E;
  flex-shrink: 0;
  display: flex;
  gap: 6px;
  overflow-x: auto;
}
.objectives-bar::-webkit-scrollbar { display:none; }
.obj-card {
  flex-shrink: 0;
  background: rgba(13,20,32,.8);
  border: 1px solid #1A2840;
  border-radius: 8px;
  padding: 5px 9px;
  font-size: 8px;
  color: #8899BB;
  display: flex;
  align-items: center;
  gap: 5px;
  transition: border-color .2s;
  min-width: 120px;
}
.obj-card.done { border-color: #00D97E55; color: #00D97E; }
.obj-card.claimed { opacity: .4; }
.obj-progress { font-size: 7px; color: #445577; }
.obj-icon { font-size: 13px; }
.obj-reward { font-size: 7px; color: #F7931A; margin-left: auto; }


/* ── ANIMATION RENAISSANCE ── */
#rebirth-overlay {
  position: fixed; inset: 0; z-index: 500;
  display: flex; align-items: center; justify-content: center;
  pointer-events: none;
  overflow: hidden;
}
#rebirth-overlay.hidden { display: none; }

/* Vague de lumière */
.rebirth-wave {
  position: absolute; inset: 0;
  background: radial-gradient(circle at 50% 50%, rgba(167,139,250,0.95) 0%, rgba(99,126,234,0.6) 30%, transparent 70%);
  animation: rebirthWave 1.2s cubic-bezier(.2,0,.3,1) forwards;
  transform: scale(0);
}
@keyframes rebirthWave {
  0%   { transform: scale(0);   opacity: 1; }
  60%  { transform: scale(2.5); opacity: 0.8; }
  100% { transform: scale(4);   opacity: 0; }
}

/* Fond sombre */
.rebirth-bg {
  position: absolute; inset: 0;
  background: rgba(5,8,14,0.92);
  animation: rebirthBg 2.8s ease forwards;
}
@keyframes rebirthBg {
  0%   { opacity: 0; }
  15%  { opacity: 1; }
  80%  { opacity: 1; }
  100% { opacity: 0; }
}

/* Contenu central */
.rebirth-content {
  position: relative; z-index: 2;
  text-align: center;
  animation: rebirthContent 2.8s ease forwards;
}
@keyframes rebirthContent {
  0%   { opacity: 0; transform: scale(0.5) translateY(30px); }
  20%  { opacity: 1; transform: scale(1.05) translateY(0); }
  70%  { opacity: 1; transform: scale(1) translateY(0); }
  100% { opacity: 0; transform: scale(1.1) translateY(-20px); }
}

.rebirth-icon {
  font-size: 72px;
  display: block;
  margin-bottom: 16px;
  animation: rebirthSpin 2.8s ease forwards;
  filter: drop-shadow(0 0 30px #A78BFA);
}
@keyframes rebirthSpin {
  0%   { transform: rotate(-180deg) scale(0); filter: drop-shadow(0 0 0px #A78BFA); }
  30%  { transform: rotate(10deg) scale(1.2); filter: drop-shadow(0 0 40px #A78BFA); }
  50%  { transform: rotate(-5deg) scale(1);   filter: drop-shadow(0 0 20px #A78BFA); }
  100% { transform: rotate(0deg) scale(1.1);  filter: drop-shadow(0 0 60px #FFD166); }
}

.rebirth-title {
  font-family: 'Space Mono', monospace;
  font-size: 28px; font-weight: 700;
  color: #ffffff;
  letter-spacing: .12em;
  text-shadow: 0 0 40px #A78BFA, 0 0 80px #627EEA;
  margin-bottom: 8px;
}

.rebirth-num {
  font-family: 'Space Mono', monospace;
  font-size: 13px;
  color: #A78BFA;
  letter-spacing: .2em;
  margin-bottom: 16px;
}

.rebirth-bonus {
  font-family: 'Space Mono', monospace;
  font-size: 18px; font-weight: 700;
  color: #FFD166;
  text-shadow: 0 0 20px #FFD166;
  animation: rebirthPulse 0.4s ease infinite alternate;
}
@keyframes rebirthPulse {
  from { transform: scale(1);    text-shadow: 0 0 20px #FFD166; }
  to   { transform: scale(1.06); text-shadow: 0 0 40px #FFD166, 0 0 80px #F7931A; }
}

/* Lignes de vitesse */
.rebirth-lines {
  position: absolute; inset: 0; overflow: hidden;
}
.rebirth-line {
  position: absolute;
  width: 2px;
  background: linear-gradient(to bottom, transparent, #A78BFA, transparent);
  animation: rebirthLine var(--dur) var(--delay) ease-in forwards;
  opacity: 0;
}
@keyframes rebirthLine {
  0%   { top: -20%; opacity: 0; height: 15%; }
  20%  { opacity: 0.8; }
  100% { top: 120%; opacity: 0; height: 25%; }
}

/* Particules étoiles */
.rebirth-star {
  position: absolute;
  width: 4px; height: 4px;
  border-radius: 50%;
  background: #A78BFA;
  animation: rebirthStar var(--dur) var(--delay) ease-out forwards;
  opacity: 0;
}
@keyframes rebirthStar {
  0%   { transform: translate(0,0) scale(0); opacity: 1; }
  100% { transform: translate(var(--dx), var(--dy)) scale(0); opacity: 0; }
}


/* ══ ÉCRAN D'INTRO ══ */
#intro-overlay {
  position: fixed; inset: 0; z-index: 1000;
  background: #020508;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  overflow: hidden;
}
#intro-overlay.hidden { display: none; }

/* Grille animée en fond */
#intro-overlay::before {
  content: '';
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(99,126,234,.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(99,126,234,.06) 1px, transparent 1px);
  background-size: 40px 40px;
  animation: gridPulse 3s ease infinite alternate;
}
@keyframes gridPulse {
  from { opacity: 0.4; }
  to   { opacity: 1; }
}

/* Particules de fond intro */
.intro-particle {
  position: absolute;
  border-radius: 50%;
  animation: introFloat var(--dur) var(--delay) ease-in-out infinite alternate;
  pointer-events: none;
}
@keyframes introFloat {
  from { transform: translateY(0) scale(1); opacity: var(--opa); }
  to   { transform: translateY(-30px) scale(1.1); opacity: calc(var(--opa) * 0.5); }
}

/* Logo BTC */
.intro-logo {
  position: relative; z-index: 1;
  font-size: 80px;
  animation: introBounce 2s cubic-bezier(.34,1.56,.64,1) forwards;
  filter: drop-shadow(0 0 40px #F7931A);
  margin-bottom: 16px;
}
@keyframes introBounce {
  0%   { transform: scale(0) rotate(-180deg); opacity: 0; filter: drop-shadow(0 0 0px #F7931A); }
  60%  { transform: scale(1.15) rotate(8deg); opacity: 1; filter: drop-shadow(0 0 60px #F7931A); }
  80%  { transform: scale(0.95) rotate(-3deg); }
  100% { transform: scale(1) rotate(0deg); opacity: 1; filter: drop-shadow(0 0 30px #F7931A); }
}

/* Titre */
.intro-title {
  position: relative; z-index: 1;
  font-family: 'Space Mono', monospace;
  font-size: 32px; font-weight: 700;
  color: #F7931A;
  letter-spacing: .15em;
  text-shadow: 0 0 40px rgba(247,147,26,.8);
  animation: introSlideUp .8s .4s cubic-bezier(.34,1.56,.64,1) both;
  margin-bottom: 6px;
}
.intro-sub {
  position: relative; z-index: 1;
  font-family: 'Space Mono', monospace;
  font-size: 9px; color: #445577;
  letter-spacing: .3em;
  animation: introSlideUp .8s .6s cubic-bezier(.34,1.56,.64,1) both;
  margin-bottom: 40px;
}
@keyframes introSlideUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Écran choix de langue */
#intro-lang {
  position: relative; z-index: 1;
  width: min(340px, 90vw);
  animation: introSlideUp .8s .8s cubic-bezier(.34,1.56,.64,1) both;
}
.intro-lang-title {
  font-size: 10px; color: #627EEA;
  letter-spacing: .2em; text-align: center;
  margin-bottom: 14px;
}
.intro-lang-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.intro-lang-btn {
  padding: 12px; border-radius: 12px;
  background: rgba(13,20,32,.9);
  border: 1.5px solid #1A2840;
  cursor: pointer; transition: all .2s;
  display: flex; align-items: center; justify-content: center; gap: 8px;
  font-family: 'Space Mono', monospace;
  font-size: 10px; font-weight: 700; color: #E8F0FF;
  letter-spacing: .05em;
}
.intro-lang-btn:hover {
  border-color: #F7931A;
  background: rgba(247,147,26,.1);
  transform: translateY(-2px);
  box-shadow: 0 4px 20px rgba(247,147,26,.2);
}
.intro-lang-btn:active { transform: scale(.97); }
.intro-lang-flag { font-size: 22px; }

/* Écran menu principal */
#intro-menu {
  position: relative; z-index: 1;
  width: min(300px, 86vw);
  text-align: center;
  display: none;
}
#intro-menu.show { display: block; animation: introSlideUp .6s cubic-bezier(.34,1.56,.64,1) both; }

.menu-game-title {
  font-family: 'Space Mono', monospace;
  font-size: 26px; font-weight: 700;
  color: #F7931A;
  letter-spacing: .12em;
  text-shadow: 0 0 30px rgba(247,147,26,.6);
  margin-bottom: 4px;
}
.menu-game-sub {
  font-size: 8px; color: #445577;
  letter-spacing: .25em;
  margin-bottom: 32px;
}
.menu-btn {
  display: block; width: 100%;
  padding: 14px;
  border-radius: 12px;
  font-family: 'Space Mono', monospace;
  font-size: 12px; font-weight: 700;
  letter-spacing: .1em;
  cursor: pointer;
  transition: all .2s;
  margin-bottom: 10px;
}
.menu-btn-start {
  background: linear-gradient(135deg, #F7931A, #e8820a);
  border: none; color: white;
  box-shadow: 0 4px 24px rgba(247,147,26,.4);
}
.menu-btn-start:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(247,147,26,.6);
}
.menu-btn-quit {
  background: transparent;
  border: 1.5px solid #1A2840;
  color: #445577;
}
.menu-btn-quit:hover {
  border-color: #627EEA; color: #8899BB;
  transform: translateY(-1px);
}
.menu-version {
  font-size: 7px; color: #2a3a56;
  margin-top: 20px; letter-spacing: .15em;
}

/* ── LANGUE SELECTOR ── */
.lang-overlay {
  position:fixed; inset:0; z-index:200;
  background:rgba(5,8,14,0.97);
  display:flex; align-items:center; justify-content:center;
}
.lang-overlay.hidden { display:none; }

/* ── DISCLAIMER ── */
.disclaimer-overlay {
  position:fixed; inset:0; z-index:99999;
  background:rgba(5,8,14,0.98);
  display:flex; align-items:center; justify-content:center;
}
.disclaimer-overlay.hidden { display:none; }
.disclaimer-box {
  background:#0D1420; border:1.5px solid #F7931A44;
  border-radius:18px; padding:32px 28px;
  max-width:400px; width:92%; text-align:center;
}
.disclaimer-icon { font-size:36px; margin-bottom:12px; }
.disclaimer-title {
  font-size:13px; font-weight:700; color:#F7931A;
  letter-spacing:.12em; margin-bottom:16px;
}
.disclaimer-text {
  font-family:'Share Tech Mono',monospace;
  font-size:10px; color:#8899BB; line-height:1.8;
  letter-spacing:.04em; margin-bottom:22px;
}
.disclaimer-text strong { color:#E8F0FF; }
.disclaimer-btn {
  width:100%; padding:13px; border-radius:10px; border:none; cursor:pointer;
  background:linear-gradient(135deg,#F7931A,#c97410);
  color:#fff; font-family:'Orbitron',monospace;
  font-size:11px; font-weight:700; letter-spacing:.15em;
  transition:opacity .15s;
  box-shadow:0 0 20px rgba(247,147,26,.3);
}
.disclaimer-btn:hover { opacity:.88; }
.disclaimer-sep {
  width:60px; height:1px; background:#F7931A44;
  margin:0 auto 16px;
}
.lang-box {
  background:#0D1420; border:1.5px solid #1A2840;
  border-radius:18px; padding:32px 28px;
  max-width:380px; width:90%; text-align:center;
}
.lang-logo { font-size:44px; margin-bottom:10px; }
.lang-title { font-size:18px; font-weight:700; color:#F7931A; letter-spacing:.08em; margin-bottom:4px; }
.lang-sub   { font-size:9px; color:#445577; letter-spacing:.12em; margin-bottom:22px; }
.lang-grid  { display:grid; grid-template-columns:1fr 1fr; gap:9px; }
.lang-btn {
  padding:12px 8px; border-radius:10px;
  border:1.5px solid #1A2840; background:rgba(13,20,32,.8);
  cursor:pointer; transition:all .15s;
  display:flex; align-items:center; justify-content:center; gap:8px;
}
.lang-btn:hover { border-color:#627EEA; background:rgba(99,126,234,.08); transform:translateY(-1px); }
.lang-btn:active { transform:scale(.97); }
.lang-flag { font-size:22px; }
.lang-name { font-size:10px; font-weight:700; color:#E8F0FF; letter-spacing:.06em; }

/* ── TUTO OVERLAY ── */
.tuto-overlay {
  position:fixed; inset:0; z-index:180;
  background:rgba(0,0,0,0); pointer-events:none;
  transition:background .4s;
}
.tuto-overlay.active { background:rgba(0,0,0,0.78); pointer-events:all; }

/* Spotlight avec ring pulsé */
.tuto-spotlight {
  position:fixed; z-index:181; border-radius:12px;
  box-shadow:0 0 0 9999px rgba(0,0,0,0.78);
  transition:all .42s cubic-bezier(.34,1.56,.64,1);
  pointer-events:none; display:none;
  outline:2.5px solid #627EEA;
  outline-offset:0px;
  animation:spotPulse 1.6s ease-in-out infinite;
}
@keyframes spotPulse {
  0%,100% { outline-color:#627EEA; outline-offset:0px; }
  50%      { outline-color:#F7931A; outline-offset:3px; }
}

/* Flèche animée pointant vers la cible */
.tuto-arrow {
  position:fixed; z-index:183; pointer-events:none;
  font-size:26px; display:none;
  filter:drop-shadow(0 0 8px #627EEA);
  animation:arrowBounce .6s ease-in-out infinite alternate;
}
@keyframes arrowBounce {
  from { transform:translateX(0) rotate(var(--rot,0deg)); }
  to   { transform:translateX(var(--dx,8px)) rotate(var(--rot,0deg)); }
}

/* Card */
.tuto-card {
  position:fixed; z-index:182;
  background:linear-gradient(145deg,#0a1120,#0D1420);
  border:1.5px solid #627EEA; border-radius:16px;
  padding:18px 20px 14px; max-width:296px; min-width:234px;
  box-shadow:0 0 32px rgba(99,126,234,.35), 0 4px 20px rgba(0,0,0,.6);
  opacity:0; pointer-events:none;
  transition:opacity .3s ease, transform .35s cubic-bezier(.34,1.56,.64,1);
  transform:scale(.92) translateY(8px);
}
.tuto-card.show { opacity:1; pointer-events:all; transform:scale(1) translateY(0); }

/* Barre de progression en haut */
.tuto-progress {
  height:2px; background:#111B2E; border-radius:1px;
  margin-bottom:12px; overflow:hidden;
}
.tuto-progress-fill {
  height:100%; background:linear-gradient(90deg,#627EEA,#F7931A);
  border-radius:1px; transition:width .4s ease;
}

.tuto-dots { display:flex; justify-content:center; gap:5px; margin-bottom:10px; }
.tuto-dot  { width:6px; height:6px; border-radius:50%; background:#1A2840; transition:all .25s; }
.tuto-dot.active { background:#627EEA; transform:scale(1.3); }
.tuto-dot.done   { background:#00D97E; }

.tuto-step { font-size:7px; color:#445577; letter-spacing:.16em; margin-bottom:6px; }

/* Icône avec fond coloré */
.tuto-icon-wrap {
  width:48px; height:48px; border-radius:12px;
  background:linear-gradient(135deg,rgba(99,126,234,.15),rgba(247,147,26,.1));
  border:1px solid #1A2840;
  display:flex; align-items:center; justify-content:center;
  margin-bottom:10px;
}
.tuto-icon { font-size:26px; display:block; }

.tuto-title { font-size:14px; font-weight:700; color:#E8F0FF; margin-bottom:7px; line-height:1.3; }
.tuto-body  { font-size:10px; color:#8899BB; line-height:1.75; margin-bottom:10px; white-space:pre-line; }
.tuto-tip {
  background:rgba(247,147,26,.09); border:1px solid #F7931A33;
  border-radius:8px; padding:8px 10px;
  font-size:9px; color:#F7931A; line-height:1.55; margin-bottom:12px;
  display:flex; gap:6px; align-items:flex-start;
}
.tuto-tip::before { content:'💡'; flex-shrink:0; }
.tuto-btns { display:flex; gap:7px; }
.tuto-skip {
  flex:0 0 auto; padding:7px 11px; border-radius:8px;
  border:1px solid #1A2840; background:transparent;
  color:#445577; font-family:'Space Mono',monospace; font-size:9px;
  cursor:pointer; transition:all .15s;
}
.tuto-skip:hover { border-color:#FF456088; color:#FF4560; }
.tuto-next {
  flex:1; padding:9px; border-radius:8px; border:none;
  background:linear-gradient(135deg,#627EEA,#5a6fd6);
  color:white; font-family:'Space Mono',monospace;
  font-size:10px; font-weight:700; cursor:pointer;
  transition:all .15s; letter-spacing:.04em;
  box-shadow:0 2px 10px rgba(99,126,234,.3);
}
.tuto-next:hover { background:linear-gradient(135deg,#7089f0,#6a7fe6); transform:translateY(-1px); }
.tuto-next:active { transform:scale(.97); }

/* ── DON OVERLAY ── */
.don-overlay {
  position:fixed; inset:0; z-index:190;
  background:rgba(5,8,14,0.95);
  display:flex; align-items:center; justify-content:center;
}
.don-overlay.hidden { display:none; }
.don-box {
  background:#0D1420; border:1.5px solid #F7931A;
  border-radius:18px; padding:28px 24px;
  max-width:360px; width:90%; text-align:center;
  box-shadow:0 0 40px rgba(247,147,26,.25);
}
.don-icon  { font-size:48px; margin-bottom:10px; }
.don-title { font-size:18px; font-weight:700; color:#F7931A; margin-bottom:10px; letter-spacing:.06em; }
.don-text  { font-size:10px; color:#8899BB; line-height:1.8; margin-bottom:18px; }
.don-btn-kofi {
  display:flex; align-items:center; justify-content:center; gap:10px;
  width:100%; padding:13px; border-radius:10px;
  background:linear-gradient(90deg,#29ABE0,#1a8fbf);
  border:none; color:white; font-family:'Space Mono',monospace;
  font-size:12px; font-weight:700; cursor:pointer; text-decoration:none;
  margin-bottom:9px; letter-spacing:.06em;
  box-shadow:0 0 18px rgba(41,171,224,.35); transition:opacity .15s;
}
.don-btn-kofi:hover { opacity:.88; }
.don-btn-close {
  width:100%; padding:9px; border-radius:8px;
  background:transparent; border:1px solid #1A2840;
  color:#445577; font-family:'Space Mono',monospace; font-size:9px;
  cursor:pointer; transition:all .15s;
}
.don-btn-close:hover { border-color:#627EEA; color:#8899BB; }

/* ── BOUTON DON dans header ── */
.kofi-btn {
  width:32px; height:32px; border-radius:8px;
  background:#0D1420; border:1px solid #1A2840;
  color:#F7931A; font-size:14px; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0; transition:border-color .15s,color .15s;
  text-decoration:none;
}
.kofi-btn:hover { border-color:#F7931A; }

/* ── MUSIQUE ── */
.music-bar {
  display:flex; align-items:center; gap:8px;
  padding:6px 12px; border-top:1px solid #111B2E;
  background:#080C14; flex-shrink:0;
}
.music-btn {
  width:28px; height:28px; border-radius:7px;
  background:#0D1420; border:1px solid #1A2840;
  color:#627EEA; font-size:12px; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0; transition:all .15s;
}
.music-btn:hover { border-color:#627EEA; }
.music-btn.playing { border-color:#627EEA44; color:#F7931A; }
.music-track-name {
  flex:1; font-size:8px; color:#445577;
  letter-spacing:.08em; overflow:hidden;
  text-overflow:ellipsis; white-space:nowrap;
}
.music-track-name.playing { color:#8899BB; }
.music-vol-wrap { display:flex; align-items:center; gap:5px; flex-shrink:0; }
.music-vol-icon { font-size:10px; color:#445577; }
.music-vol {
  -webkit-appearance:none; width:60px; height:3px;
  border-radius:2px; background:#1A2840; outline:none; cursor:pointer;
}
.music-vol::-webkit-slider-thumb {
  -webkit-appearance:none; width:12px; height:12px;
  border-radius:50%; background:#627EEA; cursor:pointer;
}
/* Equalizer animé */
.music-eq {
  display:flex; align-items:flex-end; gap:1.5px;
  height:14px; flex-shrink:0;
}
.music-eq-bar {
  width:2.5px; border-radius:1px; background:#627EEA;
  animation:eqAnim var(--d,.5s) ease-in-out infinite alternate;
}
.music-eq-bar:nth-child(1) { --d:.45s; }
.music-eq-bar:nth-child(2) { --d:.6s;  }
.music-eq-bar:nth-child(3) { --d:.38s; }
.music-eq-bar:nth-child(4) { --d:.52s; }
@keyframes eqAnim {
  from { height:3px;  opacity:.5; }
  to   { height:13px; opacity:1;  }
}
.music-eq.paused .music-eq-bar { animation:none; height:3px; opacity:.4; }


/* Force emoji rendering */
.upg-icon, .ach-icon-wrap, .skin-preview, .mine-icon,
.tuto-icon, .lang-flag, .diff-name, .tab {
  font-family: 'Segoe UI Emoji','Apple Color Emoji','Noto Color Emoji','Space Mono',monospace;
}


/* ── PRESTIGE ── */
.prestige-bar {
  display: flex; align-items: center; gap: 10px;
  padding: 7px 14px; border-bottom: 1px solid #111B2E;
  background: rgba(124,58,237,.06); flex-shrink: 0;
  cursor: pointer; transition: background .2s;
  position: relative; overflow: hidden;
}
.prestige-bar:hover { background: rgba(124,58,237,.12); }
.prestige-bar::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(90deg, transparent, rgba(124,58,237,.08), transparent);
  animation: prestSweep 3s linear infinite;
}
@keyframes prestSweep { from{transform:translateX(-100%)} to{transform:translateX(100%)} }
.prest-icon { font-size: 16px; flex-shrink: 0; }
.prest-info { flex: 1; min-width: 0; }
.prest-title { font-size: 9px; font-weight: 700; color: #A78BFA; letter-spacing: .1em; }
.prest-sub   { font-size: 7px; color: #6D28D9; margin-top: 1px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.prest-track { width: 70px; height: 4px; background: #1A2840; border-radius: 2px; overflow: hidden; flex-shrink: 0; }
.prest-fill  { height: 100%; background: linear-gradient(90deg, #7C3AED, #EC4899); border-radius: 2px; transition: width .5s; }
.prest-count { font-size: 9px; font-weight: 700; color: #7C3AED; flex-shrink: 0; font-family: 'Space Mono', monospace; }
.prest-ready .prest-title { color: #EC4899; animation: prestPulse 1.2s infinite; }
.prest-ready .prest-fill  { background: linear-gradient(90deg, #EC4899, #F7931A); }
@keyframes prestPulse { 0%,100%{opacity:1} 50%{opacity:.6} }

/* ── PRESTIGE OVERLAY ── */
.prest-overlay {
  position: fixed; inset: 0; z-index: 300;
  background: rgba(5,3,14,.95);
  display: flex; align-items: center; justify-content: center;
}
.prest-overlay.hidden { display: none; }
.prest-box {
  background: linear-gradient(145deg, #0D0820, #150B35);
  border: 1.5px solid #7C3AED; border-radius: 18px;
  padding: 30px 26px; max-width: 360px; width: 90%;
  text-align: center; box-shadow: 0 0 60px rgba(124,58,237,.4);
}
.prest-box-icon  { font-size: 52px; margin-bottom: 10px; }
.prest-box-title { font-size: 22px; font-weight: 700; color: #E8F0FF; letter-spacing: .08em; margin-bottom: 6px; }
.prest-box-sub   { font-size: 10px; color: #7C3AED; line-height: 1.7; margin-bottom: 16px; font-family: 'Space Mono', monospace; }
.prest-box-bonus { font-size: 20px; font-weight: 700; color: #EC4899; margin-bottom: 4px; }
.prest-box-count { font-size: 9px; color: #6D28D9; font-family: 'Space Mono', monospace; margin-bottom: 20px; }
.prest-btn-confirm {
  width: 100%; padding: 13px; border-radius: 10px; border: none;
  background: linear-gradient(135deg, #7C3AED, #EC4899);
  color: white; font-family: 'Space Mono', monospace;
  font-size: 12px; font-weight: 700; cursor: pointer; margin-bottom: 9px;
  box-shadow: 0 0 20px rgba(124,58,237,.5); transition: opacity .15s;
}
.prest-btn-confirm:hover { opacity: .88; }
.prest-btn-cancel {
  width: 100%; padding: 9px; border-radius: 8px;
  background: transparent; border: 1px solid #1A2840;
  color: #445577; font-family: 'Space Mono', monospace; font-size: 9px; cursor: pointer;
}

/* ── NOTIFICATIONS DE PROGRESSION ── */
.milestone-notif {
  position: fixed; bottom: 56px; left: 50%;
  transform: translateX(-50%) translateY(80px);
  z-index: 80; pointer-events: none;
  transition: transform .4s cubic-bezier(.34,1.56,.64,1), opacity .4s;
  opacity: 0;
}
.milestone-notif.show {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
}
.milestone-inner {
  background: linear-gradient(135deg, rgba(13,20,32,.98), rgba(17,27,46,.98));
  border-radius: 14px; padding: 12px 18px;
  display: flex; align-items: center; gap: 12px;
  box-shadow: 0 4px 24px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.05);
  white-space: nowrap;
}
.milestone-icon { font-size: 28px; animation: miPop .4s cubic-bezier(.34,1.56,.64,1); }
@keyframes miPop { from{transform:scale(0) rotate(-20deg)} to{transform:scale(1) rotate(0)} }
.milestone-text { display: flex; flex-direction: column; gap: 2px; }
.milestone-label { font-size: 8px; letter-spacing: .14em; }
.milestone-value { font-size: 14px; font-weight: 700; font-family: 'Space Mono', monospace; }

/* Confettis */
.confetti-wrap {
  position: fixed; inset: 0; z-index: 79;
  pointer-events: none; overflow: hidden;
}
.confetti-piece {
  position: absolute; width: 8px; height: 8px;
  border-radius: 2px; opacity: 0;
  animation: confettiFall var(--dur) var(--delay) ease-in forwards;
}
@keyframes confettiFall {
  0%   { opacity: 1; transform: translateY(-10px) rotate(0deg) scale(1); }
  100% { opacity: 0; transform: translateY(100vh) rotate(720deg) scale(.5); }
}


/* Boutons langue dans paramètres */
.lang-setting-btn {
  padding: 7px 8px; border-radius: 8px;
  border: 1px solid #1A2840; background: #0D1420;
  color: #8899BB; font-family: 'Space Mono', monospace;
  font-size: 9px; cursor: pointer; transition: all .15s;
  text-align: center; letter-spacing: .04em;
}
.lang-setting-btn:hover { border-color: #627EEA; color: #E8F0FF; }
.lang-setting-btn.active { border-color: #F7931A; color: #F7931A; background: rgba(247,147,26,.08); }


/* ── INDICATEUR SAUVEGARDE ── */
.save-indicator {
  position: fixed; bottom: 56px; right: 10px;
  font-family: 'Space Mono', monospace; font-size: 8px;
  color: #00D97E; letter-spacing: .1em;
  opacity: 0; transition: opacity .3s;
  pointer-events: none; z-index: 70;
  background: rgba(0,217,126,.08);
  border: 1px solid rgba(0,217,126,.2);
  border-radius: 5px; padding: 3px 7px;
}
.save-indicator.show { opacity: 1; }


/* ── ÉVÉNEMENTS ALÉATOIRES ── */
.event-banner {
  position: fixed; top: 0; left: 0; right: 0; z-index: 150;
  padding: 10px 16px; display: flex; align-items: center; gap: 10px;
  font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700;
  transform: translateY(-100%);
  transition: transform .4s cubic-bezier(.34,1.56,.64,1);
  pointer-events: none;
}
.event-banner.show { transform: translateY(0); pointer-events: all; }
.event-banner.bull  { background: rgba(0,217,126,.92); color: #002a15; }
.event-banner.bear  { background: rgba(255,69,96,.92);  color: #1a0005; }
.event-banner.bonus { background: rgba(247,147,26,.92); color: #1a0800; }
.event-banner.hack  { background: rgba(99,126,234,.92); color: white; }
.event-banner-icon { font-size: 18px; }
.event-banner-text { flex: 1; }
.event-banner-close {
  background: rgba(0,0,0,.2); border: none; border-radius: 4px;
  color: inherit; font-size: 12px; cursor: pointer; padding: 2px 7px;
}

/* ── THÈME JOUR / NUIT ── */
body.theme-day {
  --bg-main:    #E8ECF4;
  --bg-card:    #F0F3FA;
  --bg-input:   #E2E8F5;
  --border-col: #C4CEDF;
  --border2-col:#A8B8D0;
  --text-main:  #1A2340;
  --text-mid:   #384870;
  --text-dim:   #6678A0;
}
body.theme-day { background: var(--bg-main) !important; color: var(--text-main) !important; }

/* Conteneurs principaux */
body.theme-day .top,
body.theme-day .tabs,
body.theme-day .panel,
body.theme-day .next-ach-bar,
body.theme-day .prestige-bar,
body.theme-day .music-bar { background: #F0F3FA; border-color: #C4CEDF; }

/* Items upgrades / stats / ach */
body.theme-day .upg-item  { background: #E8EDF8; border-color: #C4CEDF; color: #1A2340; }
body.theme-day .upg-item.can-buy { border-color: #F7931A99 !important; }
body.theme-day .upg-name  { color: #1A2340 !important; }
body.theme-day .upg-desc  { color: #6678A0 !important; }
body.theme-day .upg-cost  { color: #6678A0 !important; }
body.theme-day .upg-cost.affordable { color: #C97A10 !important; }
body.theme-day .upg-level { color: #6678A0 !important; }
body.theme-day .stat-card { background: #E8EDF8; border-color: #C4CEDF; }
body.theme-day .stat-label { color: #6678A0 !important; }
body.theme-day .stat-val   { color: #1A2340 !important; }
body.theme-day .ach-card   { background: #E8EDF8; border-color: #C4CEDF; }
body.theme-day .ach-name   { color: #1A2340 !important; }
body.theme-day .ach-cond   { color: #6678A0 !important; }
body.theme-day .ach-card.unlocked { background: #DFF0E8; border-color: #7ECBA0 !important; }

/* Header BTC */
body.theme-day .btc-value  { color: #C97A10; }
body.theme-day .btc-label  { color: #6678A0 !important; }
body.theme-day .btc-sub    { color: #6678A0 !important; }
body.theme-day .btc-auto   { color: #384870 !important; }

/* Tabs */
body.theme-day .tab        { color: #6678A0; background: transparent; }
body.theme-day .tab.active { color: #C97A10; border-color: #F7931A; }
body.theme-day .tab:hover  { color: #384870; }

/* Sections */
body.theme-day .section-title { color: #6678A0 !important; }

/* Paramètres */
body.theme-day .settings-box     { background: #F0F3FA; border-color: #C4CEDF; }
body.theme-day .settings-title   { color: #1A2340 !important; }
body.theme-day .settings-label   { color: #384870 !important; }
body.theme-day .settings-section-title { color: #6678A0 !important; }
body.theme-day .settings-body::-webkit-scrollbar-thumb { background: #C4CEDF; }

/* Inputs / toggles */
body.theme-day .toggle-row       { color: #384870 !important; }
body.theme-day .toggle-off       { background: #C4CEDF !important; }

/* Market / diff-cards */
body.theme-day .diff-card        { background: #E8EDF8 !important; border-color: #C4CEDF !important; }
body.theme-day .diff-name        { color: #1A2340 !important; }
body.theme-day .diff-chance      { color: #C97A10 !important; }
body.theme-day .diff-example     { color: #6678A0 !important; border-color: #C4CEDF !important; }
body.theme-day .market-input     { background: #E2E8F5 !important; border-color: #C4CEDF !important; color: #C97A10 !important; }
body.theme-day .market-label     { color: #6678A0 !important; }
body.theme-day .market-currency  { color: #6678A0 !important; }
body.theme-day .btn-max          { background: #E2E8F5 !important; border-color: #C4CEDF !important; color: #384870 !important; }

/* Prestige bar textes */
body.theme-day #prest-sub   { color: #384870 !important; }
body.theme-day #prest-count { color: #C97A10 !important; }
body.theme-day #prest-title { color: #1A2340 !important; }

/* Next ach bar */
body.theme-day #nab-name   { color: #384870 !important; }
body.theme-day #nab-needed { color: #6678A0 !important; }

/* Skins */
body.theme-day .skin-name  { color: #1A2340 !important; }
body.theme-day .skin-sub   { color: #6678A0 !important; }
body.theme-day .skin-price { color: #6678A0 !important; }
body.theme-day .skin-price.owned { color: #3A9E72 !important; }

/* Lang picker */
body.theme-day .lang-pick-btn { background: #E8EDF8; border-color: #C4CEDF; color: #1A2340; }
body.theme-day .lang-pick-btn .lp-name { color: #6678A0; }
body.theme-day .lang-pick-btn:hover { border-color: #627EEA; }
body.theme-day .lang-pick-btn.active { border-color: #F7931A !important; background: rgba(247,147,26,.08) !important; }
body.theme-day #tcard-night .t-name { color: #6678A0; }

/* Cooldown market */
body.theme-day .diff-cooldown-label { color: #384870 !important; }

/* Rival bar */
body.theme-day .rival-bar        { background: rgba(247,100,100,.07) !important; border-color: #C4CEDF !important; }
body.theme-day .rival-status     { color: #6678A0 !important; }
body.theme-day .rival-vs-label   { color: #6678A0 !important; }
body.theme-day .rival-vs-bar     { background: #C4CEDF !important; }
body.theme-day .rival-sabotage-btn { background: rgba(255,69,96,.08) !important; border-color: #FF456088 !important; }

/* Objectifs */
body.theme-day .objectives-bar   { border-color: #C4CEDF !important; background: #E8ECF4 !important; }
body.theme-day .obj-card         { background: #E2E8F5 !important; border-color: #C4CEDF !important; color: #384870 !important; }
body.theme-day .obj-card.done    { border-color: #5DB88A !important; color: #2E8A5E !important; }
body.theme-day .obj-progress     { color: #6678A0 !important; }
body.theme-day .obj-reward       { color: #C97A10 !important; }

/* Icônes upgrades */
body.theme-day .upg-icon         { background: #D8E0F0 !important; }

/* Bouton MINER */
body.theme-day .mine-btn         { background: radial-gradient(circle at 38% 35%, #C8D5F0, #A0B4E0) !important; border-color: #7090CC !important; }
body.theme-day .mine-btn:hover   { box-shadow: 0 0 24px rgba(100,130,220,.35) !important; border-color: #5070BB !important; }
body.theme-day .mine-icon        { color: #1A2340 !important; }
body.theme-day .mine-label       { color: #384870 !important; }

/* Boutons settings et don */
body.theme-day .settings-btn     { background: #D8E0F0 !important; border-color: #C4CEDF !important; color: #384870 !important; }
body.theme-day .settings-btn:hover { border-color: #627EEA !important; color: #1A2340 !important; }
body.theme-day .don-fab          { background: #D8E0F0 !important; border-color: #C4CEDF !important; color: #C97A10 !important; }

/* Barre musique */
body.theme-day .music-bar        { background: #E8EDF8 !important; border-color: #C4CEDF !important; }
body.theme-day .music-track-name { color: #384870 !important; }
body.theme-day .music-track-name.playing { color: #6678A0 !important; }
body.theme-day .music-btn        { background: #D8E0F0 !important; border-color: #C4CEDF !important; color: #384870 !important; }
body.theme-day .music-btn:hover  { border-color: #627EEA !important; }
body.theme-day .music-btn.playing { color: #C97A10 !important; }

/* Scrollbar */
body.theme-day ::-webkit-scrollbar-track { background: #E2E8F5; }
body.theme-day ::-webkit-scrollbar-thumb { background: #C4CEDF; }
/* Barre prestige fill */
body.theme-day #prest-fill { background: linear-gradient(90deg, #F7931A, #FFD700) !important; }
.theme-indicator {
  position: fixed; top: 6px; left: 50%; transform: translateX(-50%);
  font-size: 9px; font-family: 'Space Mono', monospace;
  color: var(--text-dim, #445577); letter-spacing: .1em;
  opacity: 0; transition: opacity .3s; pointer-events: none; z-index: 10;
}
.theme-indicator.show { opacity: 1; }

/* ── GRAPHIQUES STATS ── */
.stats-chart-wrap { padding: 10px 0 4px; }
.stats-chart-label { font-size: 7px; color: #445577; letter-spacing: .12em; margin-bottom: 5px; }
.stats-canvas-wrap { position: relative; height: 80px; }
.stats-canvas-wrap canvas { width: 100%; height: 80px; display: block; border-radius: 6px; }
.chart-legend { display: flex; gap: 12px; margin-top: 5px; flex-wrap: wrap; }
.chart-legend-item { display: flex; align-items: center; gap: 4px; font-size: 7px; color: #445577; font-family: 'Space Mono', monospace; }
.chart-legend-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.stats-session-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; margin-top: 8px; }
.session-stat { background: rgba(13,20,32,.5); border: 1px solid #111B2E; border-radius: 7px; padding: 7px 9px; }
.session-label { font-size: 7px; color: #445577; letter-spacing: .1em; margin-bottom: 2px; }
.session-val   { font-size: 11px; font-weight: 700; font-family: 'Space Mono', monospace; }


/* ── RIVAL MINER ── */
.rival-bar {
  display:flex; align-items:center; gap:8px;
  padding:6px 14px; border-bottom:1px solid #111B2E;
  background:rgba(255,69,96,.04); flex-shrink:0;
  cursor:default; position:relative; overflow:hidden;
}
.rival-avatar { font-size:16px; flex-shrink:0; }
.rival-info   { flex:1; min-width:0; }
.rival-name   { font-size:9px; font-weight:700; color:#FF4560; letter-spacing:.08em;
                white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.rival-status { font-size:7px; color:#445577; margin-top:1px; }
.rival-vs-wrap { display:flex; flex-direction:column; gap:3px; width:90px; flex-shrink:0; }
.rival-vs-row  { display:flex; align-items:center; gap:4px; }
.rival-vs-you  { height:4px; border-radius:2px; background:#627EEA; transition:width .5s; }
.rival-vs-them { height:4px; border-radius:2px; background:#FF4560; transition:width .5s; }
.rival-vs-label { font-size:6px; color:#445577; width:14px; flex-shrink:0; }
.rival-vs-bar  { flex:1; height:4px; background:#111B2E; border-radius:2px; overflow:hidden; }
.rival-sabotage-btn {
  padding:4px 9px; border-radius:6px; border:1px solid #FF456055;
  background:rgba(255,69,96,.08); color:#FF4560;
  font-family:'Space Mono',monospace; font-size:8px;
  cursor:pointer; flex-shrink:0; transition:all .15s; white-space:nowrap;
}
.rival-sabotage-btn:hover:not(:disabled) { background:rgba(255,69,96,.18); border-color:#FF4560; }
.rival-sabotage-btn:disabled { opacity:.35; cursor:not-allowed; }
.rival-alert {
  position:fixed; top:50%; left:50%; transform:translate(-50%,-50%) scale(0);
  background:rgba(10,3,5,.97); border:1.5px solid #FF4560;
  border-radius:12px; padding:16px 20px; z-index:200;
  text-align:center; min-width:220px;
  box-shadow:0 0 30px rgba(255,69,96,.4);
  transition:transform .3s cubic-bezier(.34,1.56,.64,1);
}
.rival-alert.show { transform:translate(-50%,-50%) scale(1); }
.rival-alert-icon  { font-size:36px; margin-bottom:6px; }
.rival-alert-title { font-size:13px; font-weight:700; color:#FF4560; margin-bottom:4px; }
.rival-alert-sub   { font-size:9px; color:#445577; font-family:'Space Mono',monospace; line-height:1.5; }

/* ── ANIMATIONS DE CLIC ── */
.float-ring {
  position:fixed; border-radius:50%;
  border:2px solid var(--ring-color,#F7931A);
  pointer-events:none; z-index:5999;
  animation:ringExpand .5s ease-out forwards;
}
@keyframes ringExpand {
  0%   { width:10px; height:10px; opacity:.9; transform:translate(-50%,-50%) scale(.3); }
  100% { width:80px; height:80px; opacity:0;  transform:translate(-50%,-50%) scale(1); }
}
.float-spark {
  position:fixed; pointer-events:none; z-index:5999;
  width:4px; height:4px; border-radius:50%;
  animation:sparkFly var(--dur,.5s) ease-out forwards;
}
@keyframes sparkFly {
  0%   { opacity:1; transform:translate(0,0) scale(1); }
  100% { opacity:0; transform:translate(var(--sx),var(--sy)) scale(0); }
}
/* Texte float amélioré */
.float-txt {
  position:fixed; pointer-events:none; z-index:5999;
  animation:floatUp2 .9s ease-out forwards;
  font-family:'Space Mono',monospace;
  text-shadow: 0 0 8px currentColor;
}
@keyframes floatUp2 {
  0%   { opacity:1; transform:translateY(0) scale(1.2); }
  30%  { opacity:1; transform:translateY(-15px) scale(1); }
  100% { opacity:0; transform:translateY(-55px) scale(.7); }
}


/* ── BATTLE RIVAL ── */
.battle-overlay {
  position: fixed; inset: 0; z-index: 250;
  background: rgba(5,3,14,.95);
  display: flex; align-items: center; justify-content: center;
}
.battle-overlay.hidden { display: none; }
.battle-box {
  background: linear-gradient(145deg,#0a0318,#0D1420);
  border: 1.5px solid #FF4560; border-radius: 18px;
  padding: 22px 20px; max-width: 340px; width: 92%;
  text-align: center;
  box-shadow: 0 0 40px rgba(255,69,96,.3);
}
.battle-diff-badge {
  display: inline-block; padding: 3px 12px; border-radius: 20px;
  font-family: 'Space Mono', monospace; font-size: 9px;
  font-weight: 700; letter-spacing: .12em; margin-bottom: 10px;
}
.battle-rival-name { font-size: 16px; font-weight: 700; color: #FF4560; margin-bottom: 4px; }
.battle-desc { font-family: 'Space Mono', monospace; font-size: 9px; color: #445577; line-height: 1.6; margin-bottom: 12px; }
.battle-reward { font-size: 13px; font-weight: 700; color: #FFD166; margin-bottom: 14px; }

/* Barres de clics */
.battle-bars { display: flex; flex-direction: column; gap: 8px; margin-bottom: 14px; }
.battle-bar-row { display: flex; align-items: center; gap: 8px; }
.battle-bar-lbl { font-family: 'Space Mono', monospace; font-size: 8px; width: 28px; text-align: right; }
.battle-bar-track { flex: 1; height: 10px; background: #111B2E; border-radius: 5px; overflow: hidden; position: relative; }
.battle-bar-fill { height: 100%; border-radius: 5px; transition: width .15s; }
.battle-bar-you  { background: linear-gradient(90deg,#627EEA,#F7931A); }
.battle-bar-them { background: #FF4560; }
.battle-bar-val  { font-family: 'Space Mono', monospace; font-size: 8px; width: 36px; }

/* Timer */
.battle-timer {
  font-family: 'Space Mono', monospace; font-size: 22px; font-weight: 700;
  color: #FF4560; margin-bottom: 10px;
  animation: timerPulse 1s ease-in-out infinite;
}
@keyframes timerPulse { 0%,100%{opacity:1} 50%{opacity:.6} }
.battle-timer.urgent { color: #FF4560; font-size: 28px; }

.battle-hint { font-family: 'Space Mono', monospace; font-size: 8px; color: #2a3a56; margin-bottom: 12px; }
.battle-flee-btn {
  background: transparent; border: 1px solid #1A2840;
  color: #445577; font-family: 'Space Mono', monospace;
  font-size: 8px; padding: 5px 12px; border-radius: 6px;
  cursor: pointer; transition: all .15s;
}
.battle-flee-btn:hover { border-color: #627EEA; color: #8899BB; }

/* Badge difficulté dans rival-bar */
.rival-diff-badge {
  font-family: 'Space Mono', monospace; font-size: 7px;
  font-weight: 700; padding: 1px 6px; border-radius: 10px;
  letter-spacing: .08em; flex-shrink: 0;
}


/* ── BOUTON CLIC BATTLE ── */
.battle-click-btn {
  width: 110px; height: 110px; border-radius: 50%;
  background: radial-gradient(circle at 38% 35%, #1a2a4a, #080c14);
  border: 3px solid #627EEA;
  cursor: pointer; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 4px;
  margin: 0 auto 14px;
  position: relative; overflow: hidden;
  transition: transform .08s cubic-bezier(.34,1.56,.64,1), border-color .1s, box-shadow .1s;
  -webkit-tap-highlight-color: transparent; outline: none;
  box-shadow: 0 0 20px rgba(99,126,234,.3);
  user-select: none;
}
.battle-click-btn:active,
.battle-click-btn.pressed {
  transform: scale(.86);
  border-color: #F7931A;
  box-shadow: 0 0 40px rgba(247,147,26,.5);
}
.battle-click-icon  { font-size: 36px; pointer-events: none; font-family: 'Segoe UI Emoji','Apple Color Emoji',sans-serif; }
.battle-click-label { font-size: 8px; color: #627EEA; letter-spacing: .16em; pointer-events: none; }
.battle-click-count {
  font-size: 22px; font-weight: 700; color: #F7931A;
  font-family: 'Space Mono', monospace; pointer-events: none;
}
/* Scan line animée dans le bouton */
.battle-scan {
  position: absolute; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, #627EEA88, transparent);
  animation: scan 2s linear infinite; pointer-events: none;
}
@keyframes scan { from{top:0} to{top:100%} }


/* ── ROUE DE VOL ── */
.wheel-overlay {
  position: fixed; inset: 0; z-index: 6000;
  background: rgba(5,2,12,.97);
  display: flex; align-items: center; justify-content: center;
}
.wheel-overlay.hidden { display: none; }
.wheel-box {
  background: linear-gradient(145deg, #0a0215, #0D1420);
  border: 1.5px solid #FF4560; border-radius: 20px;
  padding: 24px 20px; max-width: 340px; width: 93%;
  text-align: center;
  box-shadow: 0 0 50px rgba(255,69,96,.4);
}
.wheel-title { font-size: 13px; font-weight: 700; color: #FF4560; letter-spacing: .08em; margin-bottom: 4px; }
.wheel-subtitle { font-family: 'Space Mono', monospace; font-size: 9px; color: #445577; margin-bottom: 16px; line-height: 1.6; }

/* Roue */
.wheel-wrap {
  position: relative; width: 220px; height: 220px;
  margin: 0 auto 14px;
}
.wheel-canvas { width: 220px; height: 220px; border-radius: 50%; display: block; }
.wheel-pointer {
  position: absolute; top: -12px; left: 50%;
  transform: translateX(-50%);
  width: 0; height: 0;
  border-left: 10px solid transparent;
  border-right: 10px solid transparent;
  border-top: 22px solid #FF4560;
  filter: drop-shadow(0 0 6px #FF4560);
}
.wheel-center {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  width: 30px; height: 30px; border-radius: 50%;
  background: #0D1420; border: 2px solid #FF4560;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; cursor: pointer;
  transition: transform .1s;
  box-shadow: 0 0 10px rgba(255,69,96,.5);
}
.wheel-center:hover { transform: translate(-50%,-50%) scale(1.1); }

/* Résultat */
.wheel-result {
  font-size: 13px; font-weight: 700; color: #FF4560;
  min-height: 20px; margin-bottom: 12px; letter-spacing: .04em;
  font-family: 'Space Mono', monospace;
}
.wheel-spin-btn {
  width: 100%; padding: 12px; border-radius: 10px; border: none;
  background: linear-gradient(135deg, #FF4560, #c73050);
  color: white; font-family: 'Space Mono', monospace;
  font-size: 11px; font-weight: 700; cursor: pointer;
  transition: opacity .15s; margin-bottom: 0;
  box-shadow: 0 0 18px rgba(255,69,96,.4);
}
.wheel-spin-btn:hover:not(:disabled) { opacity: .88; }
.wheel-spin-btn:disabled { opacity: .4; cursor: not-allowed; }



/* ── GAME WRAPPER (hidden until JOUER clicked) ── */
#game-wrapper {
  display: none;
  flex-direction: column;
  height: 100dvh;
  overflow: hidden;
  position: fixed;
  inset: 0;
  background: #080C14;
}

/* ══════════════════════════════════
   THÈME SAKURA 🌸
══════════════════════════════════ */
body.theme-sakura {
  background: linear-gradient(160deg, #1a0010 0%, #2d0a1e 40%, #1a0818 100%) !important;
  color: #FFD6EC !important;
}
body.theme-sakura::before {
  background-image:
    linear-gradient(rgba(255,105,180,.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,105,180,.05) 1px, transparent 1px) !important;
}
/* Pétales animés en fond */
body.theme-sakura #sakura-petals { display: block !important; }

#sakura-petals {
  display: none;
  position: fixed; inset: 0; z-index: 0;
  pointer-events: none; overflow: hidden;
}
.sakura-petal {
  position: absolute;
  width: 8px; height: 8px;
  background: radial-gradient(circle at 40% 40%, #FFB7D5, #FF69B4);
  border-radius: 50% 0 50% 0;
  opacity: 0;
  animation: petalFall var(--dur) var(--delay) ease-in infinite;
  filter: drop-shadow(0 0 3px rgba(255,105,180,.4));
}
@keyframes petalFall {
  0%   { transform: translateY(-20px) translateX(0) rotate(0deg);   opacity: 0; }
  10%  { opacity: .7; }
  80%  { opacity: .5; }
  100% { transform: translateY(110vh) translateX(var(--dx)) rotate(var(--rot)); opacity: 0; }
}

/* Barre du haut */
body.theme-sakura .top {
  background: rgba(45, 10, 30, .95) !important;
  border-bottom-color: rgba(255,105,180,.2) !important;
}
body.theme-sakura .btc-value { color: #FF69B4 !important; }
body.theme-sakura .btc-sub   { color: #FFB7D5 !important; }
body.theme-sakura .btc-auto  { color: #FF90C0 !important; }

/* Onglets */
body.theme-sakura .tabs {
  background: rgba(45, 10, 30, .95) !important;
  border-bottom-color: rgba(255,105,180,.2) !important;
}
body.theme-sakura .tab       { color: rgba(255,105,180,.45) !important; }
body.theme-sakura .tab.active { color: #FF69B4 !important; border-bottom-color: #FF69B4 !important; }

/* Panels */
body.theme-sakura .panel { background: transparent !important; }
body.theme-sakura .section-title { color: rgba(255,105,180,.5) !important; }

/* Items */
body.theme-sakura .upg-item {
  background: rgba(60, 10, 40, .6) !important;
  border-color: rgba(255,105,180,.15) !important;
}
body.theme-sakura .upg-item:hover     { border-color: rgba(255,105,180,.35) !important; background: rgba(80,10,55,.6) !important; }
body.theme-sakura .upg-item.can-buy   { border-color: rgba(255,105,180,.8) !important; box-shadow:0 0 14px rgba(255,105,180,.4), inset 0 0 14px rgba(255,105,180,.08) !important; animation: canBuyPulseSakura 2s ease-in-out infinite !important; }
body.theme-sakura .upg-item.can-buy::after { background:linear-gradient(90deg, transparent, rgba(255,105,180,.25), transparent) !important; }
body.theme-sakura .upg-item.can-buy:hover { border-color: #FF69B4 !important; background: rgba(255,105,180,.1) !important; box-shadow:0 0 24px rgba(255,105,180,.55) !important; }
@keyframes canBuyPulseSakura {
  0%,100% { box-shadow:0 0 8px rgba(255,105,180,.25), inset 0 0 10px rgba(255,105,180,.06); }
  50%     { box-shadow:0 0 22px rgba(255,105,180,.6), inset 0 0 18px rgba(255,105,180,.15); }
}
body.theme-sakura .upg-icon  { background: rgba(45,10,30,.9) !important; }
body.theme-sakura .upg-name  { color: #FFD6EC !important; }
body.theme-sakura .upg-cost.affordable { color: #FF69B4 !important; }

/* Stats cards */
body.theme-sakura .stat-card {
  background: rgba(60,10,40,.7) !important;
  border-color: rgba(255,105,180,.15) !important;
}

/* Trophées */
body.theme-sakura .ach-card {
  background: rgba(60,10,40,.7) !important;
  border-color: rgba(255,105,180,.15) !important;
}
body.theme-sakura .ach-card.unlocked {
  border-color: rgba(255,105,180,.55) !important;
  background: rgba(255,105,180,.06) !important;
}
body.theme-sakura .ach-card.unlocked .ach-name { color: #FFB7D5 !important; }

/* Skins */
body.theme-sakura .skin-card {
  background: rgba(60,10,40,.7) !important;
  border-color: rgba(255,105,180,.15) !important;
}
body.theme-sakura .skin-card:hover { border-color: rgba(255,105,180,.4) !important; }
body.theme-sakura .skin-card.active { border-color: rgba(255,105,180,.8) !important; background: rgba(255,105,180,.07) !important; }

/* Marché */
body.theme-sakura .diff-card { border-color: rgba(255,105,180,.2) !important; background: rgba(60,10,40,.7) !important; }
body.theme-sakura #diff-facile:hover    { border-color: #FF90C0 !important; background: rgba(255,105,180,.08) !important; }
body.theme-sakura #diff-normal:hover    { border-color: #FF69B4 !important; background: rgba(255,105,180,.08) !important; }
body.theme-sakura #diff-difficile:hover { border-color: #FF4499 !important; background: rgba(255,68,153,.08) !important; }

/* Barre prochain trophée */
body.theme-sakura .next-ach-bar {
  border-bottom-color: rgba(255,105,180,.2) !important;
}
body.theme-sakura .nab-fill {
  background: linear-gradient(90deg, #FF69B4, #FFB7D5) !important;
}

/* Barre prestige */
body.theme-sakura .prestige-bar {
  background: rgba(255,105,180,.05) !important;
  border-bottom-color: rgba(255,105,180,.2) !important;
}
body.theme-sakura .prest-title { color: #FFB7D5 !important; }
body.theme-sakura .prest-fill  { background: linear-gradient(90deg, #FF69B4, #FF90C0) !important; }
body.theme-sakura .prest-count { color: #FF69B4 !important; }

/* Rival */
body.theme-sakura .rival-bar {
  background: rgba(255,105,180,.04) !important;
  border-bottom-color: rgba(255,105,180,.2) !important;
}

/* Barre musique */
body.theme-sakura .music-bar {
  background: rgba(45,10,30,.95) !important;
  border-top-color: rgba(255,105,180,.2) !important;
}
body.theme-sakura .music-btn  { background: rgba(60,10,40,.9) !important; border-color: rgba(255,105,180,.2) !important; color: #FF90C0 !important; }
body.theme-sakura .music-eq-bar { background: #FF69B4 !important; }

/* Settings box */
body.theme-sakura .settings-box {
  background: #2d0a1e !important;
  border-color: rgba(255,105,180,.3) !important;
}
body.theme-sakura .settings-row  { border-bottom-color: rgba(255,105,180,.15) !important; }
body.theme-sakura .settings-label { color: #FFB7D5 !important; }
body.theme-sakura .toggle-btn.on  { background: rgba(255,105,180,.25) !important; border-color: #FF69B4 !important; }
body.theme-sakura .toggle-btn.on::after { background: #FF69B4 !important; }

/* Bouton mine sakura */
body.theme-sakura .mine-btn {
  border-color: rgba(255,105,180,.35) !important;
}
body.theme-sakura .mine-btn:hover {
  border-color: #FF69B4 !important;
  box-shadow: 0 0 24px rgba(255,105,180,.35) !important;
}

/* Objectifs */
body.theme-sakura .objectives-bar  { border-bottom-color: rgba(255,105,180,.2) !important; }
body.theme-sakura .obj-card        { background: rgba(60,10,40,.8) !important; border-color: rgba(255,105,180,.15) !important; }
body.theme-sakura .obj-card.done   { border-color: rgba(255,105,180,.5) !important; color: #FF90C0 !important; }

/* Bouton settings & kofi */
body.theme-sakura .settings-btn,
body.theme-sakura .kofi-btn {
  background: rgba(60,10,40,.9) !important;
  border-color: rgba(255,105,180,.2) !important;
  color: #FF90C0 !important;
}

/* Scrollbar */
body.theme-sakura .panel::-webkit-scrollbar-thumb { background: rgba(255,105,180,.3) !important; }

/* Indicateur thème */
body.theme-sakura #theme-indicator { color: rgba(255,105,180,.7) !important; }

body.theme-day .settings-body::-webkit-scrollbar-thumb { background: #C4CEDF; }

body.theme-sakura .settings-section-title { color: rgba(255,105,180,.5); }
body.theme-sakura .lang-pick-btn { background: rgba(60,10,40,.8); border-color: rgba(255,105,180,.2); color: #FFD6EC; }
body.theme-sakura .lang-pick-btn .lp-name { color: rgba(255,105,180,.6); }
body.theme-sakura .lang-pick-btn:hover { border-color: rgba(255,105,180,.5); background: rgba(255,105,180,.08); }
body.theme-sakura .lang-pick-btn.active { border-color: #FF69B4 !important; background: rgba(255,105,180,.12) !important; }
body.theme-sakura .lang-pick-btn.active .lp-name { color: #FF69B4; }
</style>
</head>
<body>

<!-- LAYERS -->
<canvas id="layer-bg"></canvas>
<canvas id="layer-fx"></canvas>
<canvas id="layer-glitch"></canvas>
<canvas id="tunnel"></canvas>
<div id="scanlines"></div>
<div id="vignette"></div>
<div id="flash"></div>
<div id="flash-green"></div>
<div id="code-stream"></div>

<!-- CORNERS -->
<div class="corner tl"></div><div class="corner tr"></div>
<div class="corner bl"></div><div class="corner br"></div>

<!-- INTRO -->
<div id="intro">
  <div class="cin-line" id="cin1">Le monde tourne autour de l'argent…</div>
  <div class="cin-line" id="cin2">Mais le système peut s'effondrer.</div>
  <div class="cin-line" id="cin3">Une nouvelle ère commence.</div>
  <div id="btc-symbol">₿</div>
  <div id="logo-final">
    <div id="logo-smoke"></div>
    <h1 id="logo-h1">CRYPTO MINER</h1>
    <div class="logo-tagline" id="tag1">DEVIENS PLUS QU'UN JOUEUR</div>
    <div class="logo-tagline2" id="tag2">DEVIENS LE MAÎTRE DU CRYPTO</div>
  </div>
</div>

<!-- LANG -->
<div id="lang-screen">
  <div class="lang-title">◈ &nbsp;CHOISIS TA LANGUE&nbsp; ◈</div>
  <div class="lang-grid">
    <button class="lang-btn" onclick="selectLang('fr')"><span class="lang-flag">🇫🇷</span>Français</button>
    <button class="lang-btn" onclick="selectLang('en')"><span class="lang-flag">🇬🇧</span>English</button>
    <button class="lang-btn" onclick="selectLang('es')"><span class="lang-flag">🇪🇸</span>Español</button>
    <button class="lang-btn" onclick="selectLang('ar')"><span class="lang-flag">🇸🇦</span>العربية</button>
    <button class="lang-btn full" onclick="selectLang('pt')"><span class="lang-flag">🇧🇷</span>Português</button>
  </div>
</div>

<!-- ── DISCLAIMER INTRO ── -->
<div id="disclaimer-intro" style="display:none;position:fixed;inset:0;z-index:99999;background:rgba(5,8,14,0.98);align-items:center;justify-content:center;">
  <div style="background:#0D1420;border:1.5px solid #F7931A44;border-radius:18px;padding:32px 28px;max-width:400px;width:92%;text-align:center;">
    <div style="font-size:36px;margin-bottom:12px;">⚠️</div>
    <div id="di-title" style="font-size:13px;font-weight:700;color:#F7931A;letter-spacing:.12em;margin-bottom:14px;font-family:'Orbitron',monospace;">AVERTISSEMENT</div>
    <div style="width:60px;height:1px;background:#F7931A44;margin:0 auto 14px;"></div>
    <div id="di-text" style="font-family:'Share Tech Mono',monospace;font-size:10px;color:#8899BB;line-height:1.8;letter-spacing:.04em;margin-bottom:22px;"></div>
    <button id="di-btn" onclick="closeDisclaimerIntro()" style="width:100%;padding:13px;border-radius:10px;border:none;cursor:pointer;background:linear-gradient(135deg,#F7931A,#c97410);color:#fff;font-family:'Orbitron',monospace;font-size:11px;font-weight:700;letter-spacing:.15em;box-shadow:0 0 20px rgba(247,147,26,.3);">✓ J'AI COMPRIS</button>
  </div>
</div>

<!-- MENU -->
<div id="menu-screen">
  <div class="menu-logo">CRYPTO MINER</div>
  <div class="menu-sub" id="menu-sub-txt">MINE · ÉVOLUE · RENAISSANCE</div>
  <button class="menu-btn primary" onclick="startGame()">▶ &nbsp;JOUER</button>
  <button class="menu-btn" onclick="showOptions()">⚙ &nbsp;OPTIONS</button>
  <button class="menu-btn danger" onclick="showQuit()">✕ &nbsp;QUITTER</button>
</div>

<!-- OPTIONS -->
<div id="options-screen">
  <div class="opts-box">
    <div class="opts-title">◈ OPTIONS ◈</div>
    <div class="opts-row">
      <span class="opts-label">MUSIQUE</span>
      <input type="range" class="opts-slider" min="0" max="100" value="70" oninput="setVol('music',this.value)">
    </div>
    <div class="opts-row">
      <span class="opts-label">EFFETS</span>
      <input type="range" class="opts-slider" min="0" max="100" value="80" oninput="setVol('sfx',this.value)">
    </div>
    <div class="opts-row">
      <span class="opts-label">LANGUE</span>
      <select class="opts-select" onchange="selectLangOpt(this.value)">
        <option value="fr">🇫🇷 Français</option>
        <option value="en">🇬🇧 English</option>
        <option value="es">🇪🇸 Español</option>
        <option value="ar">🇸🇦 العربية</option>
        <option value="pt">🇧🇷 Português</option>
      </select>
    </div>
    <div class="opts-row">
      <span class="opts-label">QUALITÉ</span>
      <select class="opts-select">
        <option>ULTRA</option><option>HAUTE</option><option>NORMALE</option>
      </select>
    </div>
    <button class="opts-close" onclick="hideOptions()">◄ RETOUR</button>
  </div>
</div>

<!-- QUIT -->
<div id="quit-popup">
  <div class="quit-box">
    <div class="quit-title">⚠ QUITTER ?</div>
    <div class="quit-sub">VOULEZ-VOUS VRAIMENT QUITTER ?</div>
    <div class="quit-btns">
      <button class="quit-yes" onclick="confirmQuit()">OUI</button>
      <button class="quit-no" onclick="hideQuit()">NON</button>
    </div>
  </div>
</div>

<!-- SKIP -->
<div id="skip-btn" onclick="skipIntro()">SKIP ▶▶</div>

<script>

// ══════════════════════════
// TRADUCTIONS
// ══════════════════════════
let currentLang = 'fr';

const T = {
  fr: {
    cin1: "Le monde tourne autour de l'argent…",
    cin2: "Mais le système peut s'effondrer.",
    cin3: "Une nouvelle ère commence.",
    langTitle: "◈ &nbsp;CHOISIS TA LANGUE&nbsp; ◈",
    menuSub: "MINE · ÉVOLUE · RENAISSANCE",
    play: "▶ &nbsp;JOUER",
    options: "⚙ &nbsp;OPTIONS",
    quit: "✕ &nbsp;QUITTER",
    optsTitle: "◈ OPTIONS ◈",
    optsMusic: "MUSIQUE",
    optsSfx: "EFFETS",
    optsLang: "LANGUE",
    optsQuality: "QUALITÉ",
    optsBack: "◄ RETOUR",
    quitTitle: "⚠ QUITTER ?",
    quitSub: "VOULEZ-VOUS VRAIMENT QUITTER ?",
    quitYes: "OUI", quitNo: "NON",
    tagline1: "DEVIENS PLUS QU'UN JOUEUR",
    tagline2: "DEVIENS LE MAÎTRE DU CRYPTO",
  },
  en: {
    cin1: "The world revolves around money…",
    cin2: "But the system can collapse.",
    cin3: "A new era begins.",
    langTitle: "◈ &nbsp;CHOOSE YOUR LANGUAGE&nbsp; ◈",
    menuSub: "MINE · EVOLVE · RENAISSANCE",
    play: "▶ &nbsp;PLAY",
    options: "⚙ &nbsp;OPTIONS",
    quit: "✕ &nbsp;QUIT",
    optsTitle: "◈ OPTIONS ◈",
    optsMusic: "MUSIC",
    optsSfx: "EFFECTS",
    optsLang: "LANGUAGE",
    optsQuality: "QUALITY",
    optsBack: "◄ BACK",
    quitTitle: "⚠ QUIT ?",
    quitSub: "DO YOU REALLY WANT TO QUIT ?",
    quitYes: "YES", quitNo: "NO",
    tagline1: "BECOME MORE THAN A PLAYER",
    tagline2: "BECOME THE CRYPTO MASTER",
  },
  es: {
    cin1: "El mundo gira alrededor del dinero…",
    cin2: "Pero el sistema puede colapsar.",
    cin3: "Una nueva era comienza.",
    langTitle: "◈ &nbsp;ELIGE TU IDIOMA&nbsp; ◈",
    menuSub: "MINA · EVOLUCIONA · RENAISSANCE",
    play: "▶ &nbsp;JUGAR",
    options: "⚙ &nbsp;OPCIONES",
    quit: "✕ &nbsp;SALIR",
    optsTitle: "◈ OPCIONES ◈",
    optsMusic: "MÚSICA",
    optsSfx: "EFECTOS",
    optsLang: "IDIOMA",
    optsQuality: "CALIDAD",
    optsBack: "◄ VOLVER",
    quitTitle: "⚠ ¿SALIR?",
    quitSub: "¿REALMENTE QUIERES SALIR?",
    quitYes: "SÍ", quitNo: "NO",
    tagline1: "CONVIÉRTETE EN MÁS QUE UN JUGADOR",
    tagline2: "CONVIÉRTETE EN EL MAESTRO CRYPTO",
  },
  ar: {
    cin1: "يدور العالم حول المال…",
    cin2: "لكن النظام يمكن أن ينهار.",
    cin3: "عصر جديد يبدأ.",
    langTitle: "◈ &nbsp;اختر لغتك&nbsp; ◈",
    menuSub: "عدِّن · تطور · نهضة",
    play: "▶ &nbsp;العب",
    options: "⚙ &nbsp;خيارات",
    quit: "✕ &nbsp;خروج",
    optsTitle: "◈ الخيارات ◈",
    optsMusic: "موسيقى",
    optsSfx: "مؤثرات",
    optsLang: "اللغة",
    optsQuality: "الجودة",
    optsBack: "◄ رجوع",
    quitTitle: "⚠ خروج ؟",
    quitSub: "هل تريد فعلاً الخروج ؟",
    quitYes: "نعم", quitNo: "لا",
    tagline1: "كن أكثر من مجرد لاعب",
    tagline2: "كن سيد الكريبتو",
  },
  pt: {
    cin1: "O mundo gira em torno do dinheiro…",
    cin2: "Mas o sistema pode entrar em colapso.",
    cin3: "Uma nova era começa.",
    langTitle: "◈ &nbsp;ESCOLHA SEU IDIOMA&nbsp; ◈",
    menuSub: "MINE · EVOLUA · RENASÇA",
    play: "▶ &nbsp;JOGAR",
    options: "⚙ &nbsp;OPÇÕES",
    quit: "✕ &nbsp;SAIR",
    optsTitle: "◈ OPÇÕES ◈",
    optsMusic: "MÚSICA",
    optsSfx: "EFEITOS",
    optsLang: "IDIOMA",
    optsQuality: "QUALIDADE",
    optsBack: "◄ VOLTAR",
    quitTitle: "⚠ SAIR ?",
    quitSub: "VOCÊ REALMENTE QUER SAIR ?",
    quitYes: "SIM", quitNo: "NÃO",
    tagline1: "TORNE-SE MAIS DO QUE UM JOGADOR",
    tagline2: "TORNE-SE O MESTRE DO CRYPTO",
  },
};

function t(key) { return (T[currentLang] || T.fr)[key] || T.fr[key] || key; }

function applyTranslations() {
  // Intro texts
  const c1=document.getElementById('cin1'); if(c1) c1.textContent=t('cin1');
  const c2=document.getElementById('cin2'); if(c2) c2.textContent=t('cin2');
  const c3=document.getElementById('cin3'); if(c3) c3.textContent=t('cin3');
  // Lang screen
  const lt=document.querySelector('.lang-title'); if(lt) lt.innerHTML=t('langTitle');
  // Menu
  const ms=document.getElementById('menu-sub-txt'); if(ms) ms.textContent=t('menuSub');
  // Buttons
  document.querySelectorAll('.menu-btn').forEach((btn,i)=>{
    if(i===0) btn.innerHTML=t('play');
    else if(i===1) btn.innerHTML=t('options');
    else if(i===2) btn.innerHTML=t('quit');
  });
  // Options
  const ot=document.querySelector('.opts-title'); if(ot) ot.textContent=t('optsTitle');
  document.querySelectorAll('.opts-label').forEach((l,i)=>{
    const keys=['optsMusic','optsSfx','optsLang','optsQuality'];
    if(keys[i]) l.textContent=t(keys[i]);
  });
  const ob=document.querySelector('.opts-close'); if(ob) ob.textContent=t('optsBack');
  // Quit
  const qt=document.querySelector('.quit-title'); if(qt) qt.textContent=t('quitTitle');
  const qs=document.querySelector('.quit-sub');   if(qs) qs.textContent=t('quitSub');
  const qy=document.querySelector('.quit-yes');   if(qy) qy.textContent=t('quitYes');
  const qn=document.querySelector('.quit-no');    if(qn) qn.textContent=t('quitNo');
  // Taglines
  const tg1=document.getElementById('tag1'); if(tg1) tg1.textContent=t('tagline1');
  const tg2=document.getElementById('tag2'); if(tg2) tg2.textContent=t('tagline2');
  // RTL pour arabe
  document.body.dir = currentLang==='ar' ? 'rtl' : 'ltr';
}


// ══════════════════════════
// AUDIO ENGINE (sons intro désactivés — lo-fi uniquement)
// ══════════════════════════
const AC = new (window.AudioContext||window.webkitAudioContext)();

function playHB(){}
let hbInterval;
function startHeartbeat(){}
function stopHeartbeat(){}
function playGlitch(){}
function playImpact(){}
function playEpicSwell(){}
function playClick(){}

// ══════════════════════════
// CANVAS
// ══════════════════════════
const bgC=document.getElementById('layer-bg');
const fxC=document.getElementById('layer-fx');
const glC=document.getElementById('layer-glitch');
const bgX=bgC.getContext('2d');
const fxX=fxC.getContext('2d');
const glX=glC.getContext('2d');

let W,H;
function resize(){
  W=bgC.width=fxC.width=glC.width=window.innerWidth;
  H=bgC.height=fxC.height=glC.height=window.innerHeight;
}
resize();window.addEventListener('resize',resize);

// Stars
let stars=[];
function initStars(n=500){
  stars=Array.from({length:n},()=>({
    x:Math.random()*W-W/2,y:Math.random()*H-H/2,
    z:Math.random()*W,pz:0,
    col:['#00FF88','#00D4FF','#FFD700','#fff','#fff','#fff'][Math.floor(Math.random()*6)],
    tw:Math.random()*Math.PI*2
  }));
}
initStars();
window.addEventListener('resize',initStars);

let warpSpd=0,baseSpd=.4,bgA=.2,nebulaA=0;
const nebDefs=[
  {cx:.1,cy:.3,r:.5,rgb:'0,255,136'},{cx:.9,cy:.2,r:.5,rgb:'0,212,255'},
  {cx:.5,cy:.8,r:.6,rgb:'255,215,0'},{cx:.3,cy:.7,r:.4,rgb:'167,139,250'},
];

function drawSpace(){
  bgX.fillStyle=`rgba(2,4,8,${bgA})`;bgX.fillRect(0,0,W,H);
  if(nebulaA>0)nebDefs.forEach(n=>{
    const r=Math.max(1,n.r*W);
    const g=bgX.createRadialGradient(n.cx*W,n.cy*H,0,n.cx*W,n.cy*H,r);
    g.addColorStop(0,`rgba(${n.rgb},${Math.min(1,nebulaA*.1)})`);
    g.addColorStop(1,'transparent');
    bgX.fillStyle=g;bgX.fillRect(0,0,W,H);
  });
  const spd=baseSpd+warpSpd;
  stars.forEach(s=>{
    s.pz=s.z;s.z-=spd;
    if(s.z<=0){s.x=Math.random()*W-W/2;s.y=Math.random()*H-H/2;s.z=W;s.pz=W;}
    const sx=s.x/s.z*W+W/2,sy=s.y/s.z*H+H/2;
    const px=s.x/s.pz*W+W/2,py=s.y/s.pz*H+H/2;
    const r=Math.max(.1,(1-s.z/W)*2.5);
    s.tw+=.03;
    if(warpSpd>3){
      bgX.beginPath();bgX.moveTo(px,py);bgX.lineTo(sx,sy);
      bgX.strokeStyle=s.col+'BB';bgX.lineWidth=r*.5;bgX.stroke();
    } else {
      const a=(.3+.7*Math.sin(s.tw))*(1-s.z/W);
      bgX.beginPath();bgX.arc(sx,sy,r,0,Math.PI*2);
      bgX.fillStyle=s.col;bgX.globalAlpha=a;bgX.fill();bgX.globalAlpha=1;
    }
  });
}

// Floating particles
function spawnFloatParticles(){
  setInterval(()=>{
    const p=document.createElement('div');p.className='float-particle';
    const sz=1+Math.random()*3;
    const cols=['#00FF88','#00D4FF','#FFD700'];
    const col=cols[Math.floor(Math.random()*cols.length)];
    p.style.cssText=`width:${sz}px;height:${sz}px;background:${col};left:${Math.random()*100}vw;top:${100+Math.random()*20}vh;box-shadow:0 0 ${sz*3}px ${col};opacity:${.2+Math.random()*.5};transition:transform ${4+Math.random()*6}s linear,opacity ${4+Math.random()*6}s linear`;
    document.body.appendChild(p);
    setTimeout(()=>{p.style.transform=`translateY(-${110+Math.random()*30}vh)`;p.style.opacity='0';},50);
    setTimeout(()=>p.remove(),12000);
  },300);
}

// Data code stream
function buildCodeStream(){
  const chars='01₿#@!<>{}[]0x9F7A';
  const cs=document.getElementById('code-stream');
  const cols=Math.floor(W/18);
  for(let i=0;i<cols;i++){
    const col=document.createElement('div');
    col.className='code-col';
    col.style.left=i*18+'px';
    col.style.animationDuration=(8+Math.random()*12)+'s';
    col.style.animationDelay=(-Math.random()*10)+'s';
    col.style.opacity=(.05+Math.random()*.12)+'';
    let txt='';for(let j=0;j<60;j++)txt+=chars[Math.floor(Math.random()*chars.length)]+'\n';
    col.textContent=txt;
    cs.appendChild(col);
  }
}
buildCodeStream();

// Main render loop
function loop(){
  drawSpace();
  if(warpSpd>0){warpSpd*=.97;if(warpSpd<.05)warpSpd=0;}
  requestAnimationFrame(loop);
}
loop();

// ══════════════════════════
// UTILS
// ══════════════════════════
const wait=ms=>new Promise(r=>setTimeout(r,ms));
const easeOut=t=>1-Math.pow(1-t,3);
const easeIn=t=>t*t*t;
const easeOutExpo=t=>t===1?1:1-Math.pow(2,-10*t);
const easeOutElastic=t=>{if(t===0||t===1)return t;return Math.pow(2,-10*t)*Math.sin((t*10-.75)*(2*Math.PI/3))+1;};
const easeInOutQuart=t=>t<.5?8*t*t*t*t:1-Math.pow(-2*t+2,4)/2;

function tween(dur,ease,fn,delay=0){
  return new Promise(res=>setTimeout(()=>{
    const t0=performance.now();
    (function tick(now){
      const p=Math.min(1,(now-t0)/dur);
      fn(ease(p),p);
      p<1?requestAnimationFrame(tick):res();
    })(performance.now());
  },delay));
}

function flashW(i=1,d=400){
  const f=document.getElementById('flash');
  f.style.opacity=i;
  return tween(d,easeOutExpo,e=>f.style.opacity=String(i*(1-e)));
}
function flashG(i=.5,d=400){
  const f=document.getElementById('flash-green');
  f.style.opacity=i;
  return tween(d,easeOutExpo,e=>f.style.opacity=String(i*(1-e)));
}

function glitchEffect(dur=300){
  const el=document.getElementById('layer-glitch');
  el.style.opacity='1';
  const t0=Date.now();
  const iv=setInterval(()=>{
    glX.clearRect(0,0,W,H);
    for(let i=0;i<6;i++){
      const y=Math.random()*H,h=2+Math.random()*20;
      const off=(Math.random()-.5)*60;
      glX.drawImage(bgC,0,y,W,h,off,y,W,h);
      glX.fillStyle=`rgba(0,255,136,${Math.random()*.08})`;
      glX.fillRect(0,y,W,h);
    }
    if(Date.now()-t0>dur){clearInterval(iv);glX.clearRect(0,0,W,H);el.style.opacity='0';}
  },30);
  playGlitch();
}

function shakeDoc(mag=8,dur=400){
  const els=[document.getElementById('intro'),document.getElementById('lang-screen'),document.getElementById('menu-screen')];
  const t0=performance.now();
  (function tick(now){
    const p=Math.min(1,(now-t0)/dur),a=mag*(1-p);
    const tx=(Math.random()-.5)*2*a,ty=(Math.random()-.5)*2*a;
    els.forEach(el=>el&&(el.style.transform=`translate(${tx}px,${ty}px)`));
    if(p<1)requestAnimationFrame(tick);
    else els.forEach(el=>el&&(el.style.transform=''));
  })(performance.now());
}

function explodeParticles(x,y,n=60){
  const cols=['#00FF88','#00D4FF','#FFD700','#F7931A','#fff'];
  for(let i=0;i<n;i++){
    const d=document.createElement('div');
    const angle=(i/n)*Math.PI*2+Math.random()*.3;
    const dist=80+Math.random()*Math.min(W,H)*.4;
    const sz=2+Math.random()*5;
    const col=cols[Math.floor(Math.random()*cols.length)];
    d.style.cssText=`position:fixed;width:${sz}px;height:${sz}px;border-radius:50%;background:${col};left:${x}px;top:${y}px;transform:translate(-50%,-50%);box-shadow:0 0 ${sz*3}px ${col};pointer-events:none;z-index:50`;
    document.body.appendChild(d);
    const dur2=700+Math.random()*1000;const t0=performance.now();
    (function tick(now){
      const p=Math.min(1,(now-t0)/dur2),e=easeOutExpo(p);
      d.style.transform=`translate(calc(-50% + ${Math.cos(angle)*dist*e}px),calc(-50% + ${Math.sin(angle)*dist*e}px)) scale(${1-e*.9})`;
      d.style.opacity=String(Math.pow(1-p,1.5));
      p<1?requestAnimationFrame(tick):d.remove();
    })(performance.now());
  }
}

function shockRing(x,y,col='#00FF88',maxR=500){
  return tween(1000,easeOutExpo,e=>{
    fxX.clearRect(0,0,W,H);
    const r=Math.max(1,maxR*e);
    fxX.beginPath();fxX.arc(x,y,r,0,Math.PI*2);
    fxX.strokeStyle=col;fxX.lineWidth=Math.max(.3,3*(1-e));
    fxX.globalAlpha=(1-e)*.8;fxX.stroke();fxX.globalAlpha=1;
  });
}

function glitchText(el,final,dur=600){
  const chars='₿01#@!<>{}ABCDEF0x';
  const t0=Date.now();
  return new Promise(res=>{
    const iv=setInterval(()=>{
      const p=Math.min(1,(Date.now()-t0)/dur);
      const vis=Math.floor(p*final.length);
      el.textContent=final.slice(0,vis)+Array.from({length:final.length-vis},()=>chars[Math.floor(Math.random()*chars.length)]).join('');
      if(p>=1){el.textContent=final;clearInterval(iv);res();}
    },40);
  });
}

function setCorners(alpha){
  document.querySelectorAll('.corner').forEach(c=>c.style.opacity=String(alpha));
}

// ══════════════════════════
// RAPID FLASH SCENES
// ══════════════════════════
async function playRapidScenes() {
  // Canvas dédié aux scènes rapides, par-dessus tout
  const sc = document.createElement('canvas');
  sc.style.cssText = 'position:fixed;inset:0;z-index:60;pointer-events:none';
  sc.width=W; sc.height=H;
  document.body.appendChild(sc);
  const ctx = sc.getContext('2d');

  const scenes = [drawSceneBillets, drawSceneBanque, drawSceneCrash, drawSceneGraphique, drawSceneCrypto];
  const dur = 280; // ms par scène

  for (let i=0; i<scenes.length; i++) {
    // Flash blanc entre scènes
    flashW(.5, 100);
    glitchEffect(120);
    playGlitch();

    // Dessin de la scène
    ctx.clearRect(0,0,W,H);
    scenes[i](ctx);

    await wait(dur);
  }

  // Fade out
  await tween(300,easeIn,e=>{sc.style.opacity=String(1-e);});
  sc.remove();
  flashW(.3,200);
}

function drawSceneBillets(ctx) {
  // Fond sombre verdâtre
  ctx.fillStyle='rgba(0,20,8,0.95)'; ctx.fillRect(0,0,W,H);
  // Billets en cascade
  for(let i=0;i<18;i++) {
    const x=Math.random()*W, y=Math.random()*H;
    const w2=120+Math.random()*80, h2=55+Math.random()*20;
    const angle=(Math.random()-.5)*.8;
    ctx.save(); ctx.translate(x,y); ctx.rotate(angle);
    ctx.fillStyle=`rgba(0,${80+Math.floor(Math.random()*80)},${20+Math.floor(Math.random()*30)},0.85)`;
    ctx.strokeStyle='rgba(0,255,136,0.3)';ctx.lineWidth=1;
    roundRect(ctx,-w2/2,-h2/2,w2,h2,4); ctx.fill(); ctx.stroke();
    ctx.fillStyle='rgba(0,255,136,0.6)'; ctx.font='bold 14px Share Tech Mono,monospace';
    ctx.textAlign='center'; ctx.fillText('$',0,5);
    ctx.font='8px Share Tech Mono,monospace'; ctx.fillStyle='rgba(0,255,136,0.4)';
    ctx.fillText('100',w2*.3,5);
    ctx.restore();
  }
  // Texte DOLLAR SYSTEM
  ctx.fillStyle='rgba(0,255,136,0.15)'; ctx.font='bold '+clampF(80,180)+'px Orbitron,monospace';
  ctx.textAlign='center'; ctx.textBaseline='middle'; ctx.fillText('$$$',W/2,H/2);
  drawScanOverlay(ctx);
}

function drawSceneBanque(ctx) {
  ctx.fillStyle='rgba(0,4,20,0.95)'; ctx.fillRect(0,0,W,H);
  // Bâtiment banque stylisé
  const bw=W*.5, bh=H*.65, bx=(W-bw)/2, by=H*.2;
  ctx.fillStyle='rgba(0,20,50,0.9)'; ctx.fillRect(bx,by,bw,bh);
  ctx.strokeStyle='rgba(0,212,255,0.5)'; ctx.lineWidth=2; ctx.strokeRect(bx,by,bw,bh);
  // Colonnes
  for(let i=0;i<6;i++) {
    const cx=bx+bw*(.1+i*.16);
    ctx.fillStyle='rgba(0,30,60,0.8)'; ctx.fillRect(cx-6,by+10,12,bh-20);
    ctx.strokeStyle='rgba(0,212,255,0.3)'; ctx.strokeRect(cx-6,by+10,12,bh-20);
  }
  // Fenêtres lumineuses
  for(let r=0;r<4;r++) for(let c=0;c<5;c++) {
    const wx=bx+bw*(.12+c*.18), wy=by+bh*(.12+r*.22);
    const on=Math.random()>.3;
    ctx.fillStyle=on?`rgba(0,212,255,${.3+Math.random()*.4})`:'rgba(0,0,0,0.5)';
    ctx.fillRect(wx,wy,bw*.08,bh*.07);
    if(on){ctx.strokeStyle='rgba(0,212,255,0.6)';ctx.lineWidth=.5;ctx.strokeRect(wx,wy,bw*.08,bh*.07);}
  }
  // Texte
  ctx.fillStyle='rgba(0,212,255,0.8)'; ctx.font='bold '+clampF(12,20)+'px Orbitron,monospace';
  ctx.textAlign='center'; ctx.fillText('WORLD BANK', W/2, by-15);
  ctx.fillStyle='rgba(255,69,96,0.9)'; ctx.font='bold '+clampF(16,28)+'px Orbitron,monospace';
  ctx.fillText('SYSTEM OVERLOAD', W/2, H*.88);
  drawScanOverlay(ctx);
}

function drawSceneCrash(ctx) {
  ctx.fillStyle='rgba(20,0,4,0.95)'; ctx.fillRect(0,0,W,H);
  // Graphique qui s'effondre
  const pts=[];
  const n=60;
  // Monte puis crash brutal
  for(let i=0;i<n;i++) {
    const t=i/n;
    let y;
    if(t<.4) y=H*.6 - t*H*.4 + (Math.random()-.5)*H*.05;       // montée
    else if(t<.5) y=H*.2 + (t-.4)*H*.3;                         // plateau
    else y=H*.2 + Math.pow((t-.5)*2.5,2.5)*H*.7;                // crash
    pts.push({x:W*.05+t*W*.9, y:Math.min(H*.9,y)});
  }
  // Zone sous la courbe
  ctx.beginPath(); ctx.moveTo(pts[0].x,H*.95);
  pts.forEach(p=>ctx.lineTo(p.x,p.y));
  ctx.lineTo(pts[pts.length-1].x,H*.95); ctx.closePath();
  const grad=ctx.createLinearGradient(0,H*.1,0,H*.95);
  grad.addColorStop(0,'rgba(255,69,96,0.3)'); grad.addColorStop(1,'rgba(255,69,96,0)');
  ctx.fillStyle=grad; ctx.fill();
  // Ligne
  ctx.beginPath(); ctx.moveTo(pts[0].x,pts[0].y);
  pts.forEach(p=>ctx.lineTo(p.x,p.y));
  ctx.strokeStyle='#FF4560'; ctx.lineWidth=3;
  ctx.shadowColor='#FF4560'; ctx.shadowBlur=15; ctx.stroke(); ctx.shadowBlur=0;
  // Axes
  ctx.strokeStyle='rgba(255,255,255,0.15)'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(W*.05,H*.1); ctx.lineTo(W*.05,H*.92); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(W*.05,H*.92); ctx.lineTo(W*.95,H*.92); ctx.stroke();
  // Labels
  ctx.fillStyle='rgba(255,69,96,0.9)'; ctx.font='bold '+clampF(18,32)+'px Orbitron,monospace';
  ctx.textAlign='center'; ctx.fillText('MARKET CRASH  ▼ -89%', W/2, H*.12);
  ctx.fillStyle='rgba(255,255,255,0.3)'; ctx.font=clampF(9,12)+'px Share Tech Mono,monospace';
  ['$80k','$60k','$40k','$20k','$0'].forEach((l,i)=>{ ctx.textAlign='right'; ctx.fillText(l,W*.048,H*(.25+i*.16)); });
  drawScanOverlay(ctx);
}

function drawSceneGraphique(ctx) {
  ctx.fillStyle='rgba(0,8,20,0.95)'; ctx.fillRect(0,0,W,H);
  // Plusieurs cryptos en même temps — candlesticks
  const n=30, cw=W*.88/n;
  for(let i=0;i<n;i++) {
    const x=W*.06+i*cw+cw*.2;
    const open=H*.2+Math.random()*H*.5;
    const close=H*.2+Math.random()*H*.5;
    const high=Math.min(open,close)-Math.random()*H*.08;
    const low=Math.max(open,close)+Math.random()*H*.08;
    const bull=close<open;
    const col=bull?'#00FF88':'#FF4560';
    // Mèche
    ctx.strokeStyle=col; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(x+cw*.3,high); ctx.lineTo(x+cw*.3,low); ctx.stroke();
    // Corps
    ctx.fillStyle=col+Math.floor((bull?.8:.6)*255).toString(16);
    ctx.fillRect(x,Math.min(open,close),cw*.6,Math.abs(open-close)||2);
  }
  // Lignes de grille
  ctx.strokeStyle='rgba(0,212,255,0.08)'; ctx.lineWidth=1;
  for(let i=0;i<6;i++){ctx.beginPath();ctx.moveTo(0,H*(.15+i*.14));ctx.lineTo(W,H*(.15+i*.14));ctx.stroke();}
  // BTC price
  ctx.fillStyle='#FFD700'; ctx.font='bold '+clampF(20,40)+'px Orbitron,monospace';
  ctx.textAlign='right'; ctx.fillText('₿ $94,251', W*.95, H*.1);
  ctx.fillStyle='#00FF88'; ctx.font=clampF(10,16)+'px Share Tech Mono,monospace';
  ctx.fillText('+12.4%  ▲', W*.95, H*.16);
  drawScanOverlay(ctx);
}

function drawSceneCrypto(ctx) {
  ctx.fillStyle='rgba(2,0,14,0.95)'; ctx.fillRect(0,0,W,H);
  // Symboles crypto qui volent
  const cryptos=[{s:'₿',c:'#F7931A'},{s:'Ξ',c:'#627EEA'},{s:'◎',c:'#00D4FF'},{s:'◈',c:'#A855F7'},{s:'$',c:'#00FF88'}];
  for(let i=0;i<25;i++){
    const cr=cryptos[i%cryptos.length];
    const x=Math.random()*W, y=Math.random()*H;
    const sz=clampF(16,60)*(.3+Math.random()*.7);
    ctx.font=`bold ${sz}px Orbitron,monospace`;
    ctx.fillStyle=cr.c; ctx.globalAlpha=.15+Math.random()*.6;
    ctx.textAlign='center'; ctx.fillText(cr.s,x,y);
  }
  ctx.globalAlpha=1;
  // Lignes de transaction
  for(let i=0;i<12;i++){
    const y=H*(.05+i*.08);
    ctx.strokeStyle=`rgba(0,255,136,${.05+Math.random()*.12})`; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W*(.3+Math.random()*.7),y); ctx.stroke();
    ctx.fillStyle='rgba(0,255,136,0.4)'; ctx.font='8px Share Tech Mono,monospace';
    ctx.textAlign='left';
    ctx.fillText('TX: 0x'+Math.random().toString(16).slice(2,10).toUpperCase()+'... +'+Math.floor(Math.random()*100)+' BTC',10,y-3);
  }
  // Centre : ₿ géant
  ctx.font='bold '+clampF(120,240)+'px Orbitron,monospace';
  ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.globalAlpha=.08; ctx.fillStyle='#FFD700'; ctx.fillText('₿',W/2,H/2);
  ctx.globalAlpha=1;
  ctx.fillStyle='rgba(255,215,0,0.9)'; ctx.font='bold '+clampF(16,28)+'px Orbitron,monospace';
  ctx.textBaseline='alphabetic'; ctx.fillText('BLOCKCHAIN · DECENTRALIZED · FREE', W/2, H*.9);
  drawScanOverlay(ctx);
}

// helpers
function roundRect(ctx,x,y,w,h,r){ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.quadraticCurveTo(x+w,y,x+w,y+r);ctx.lineTo(x+w,y+h-r);ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);ctx.lineTo(x+r,y+h);ctx.quadraticCurveTo(x,y+h,x,y+h-r);ctx.lineTo(x,y+r);ctx.quadraticCurveTo(x,y,x+r,y);ctx.closePath();}
function drawScanOverlay(ctx){ctx.fillStyle='rgba(0,0,0,0)';for(let y=0;y<H;y+=4){ctx.fillStyle=`rgba(0,0,0,${.04+Math.random()*.02})`;ctx.fillRect(0,y,W,2);}}
function clampF(min,max){return Math.max(min,Math.min(max,W*.06));}

// ══════════════════════════
// FAKE CRASH — VERSION ÉPIQUE
// ══════════════════════════
async function fakeCrash() {
  if (!introRunning) throw 'skipped';

  const overlay = document.createElement('div');
  overlay.style.cssText = 'position:fixed;inset:0;z-index:200;pointer-events:none;background:transparent;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:Share Tech Mono,monospace;';
  document.body.appendChild(overlay);

  const redFlash = document.createElement('div');
  redFlash.style.cssText = 'position:fixed;inset:0;z-index:198;background:#FF0000;opacity:0;pointer-events:none;';
  document.body.appendChild(redFlash);

  const noiseCanvas = document.createElement('canvas');
  noiseCanvas.style.cssText = 'position:fixed;inset:0;z-index:197;pointer-events:none;opacity:0;';
  noiseCanvas.width=W; noiseCanvas.height=H;
  document.body.appendChild(noiseCanvas);
  const nCtx = noiseCanvas.getContext('2d');

  function drawNoise() {
    const img=nCtx.createImageData(W,H);
    for(let i=0;i<img.data.length;i+=4){
      const v=Math.random()>.5?255:0;
      img.data[i]=v;img.data[i+1]=v*.2;img.data[i+2]=0;img.data[i+3]=Math.random()*180;
    }
    nCtx.putImageData(img,0,0);
  }

  function playStatic(dur=500){
    try{
      const bufSize=AC.sampleRate*(dur/1000);
      const buf=AC.createBuffer(1,bufSize,AC.sampleRate);
      const data=buf.getChannelData(0);
      for(let i=0;i<bufSize;i++) data[i]=(Math.random()*2-1)*.4;
      const src=AC.createBufferSource(),g=AC.createGain();
      src.buffer=buf;
      g.gain.setValueAtTime(.3,AC.currentTime);
      g.gain.exponentialRampToValueAtTime(.001,AC.currentTime+dur/1000);
      src.connect(g);g.connect(AC.destination);src.start();src.stop(AC.currentTime+dur/1000);
    }catch(e){}
  }

  function playScream(){
    try{
      const o=AC.createOscillator(),g=AC.createGain(),dist=AC.createWaveShaper();
      const curve=new Float32Array(512);
      for(let i=0;i<512;i++) curve[i]=i<256?-1:1;
      dist.curve=curve;
      o.type='sawtooth';
      o.frequency.setValueAtTime(900,AC.currentTime);
      o.frequency.exponentialRampToValueAtTime(30,AC.currentTime+.5);
      g.gain.setValueAtTime(.7,AC.currentTime);
      g.gain.exponentialRampToValueAtTime(.001,AC.currentTime+.6);
      o.connect(dist);dist.connect(g);g.connect(AC.destination);
      o.start();o.stop(AC.currentTime+.6);
    }catch(e){}
  }

  let distIv;
  function startDistort(mag=1){
    clearInterval(distIv);
    distIv=setInterval(()=>{
      if(!introRunning){clearInterval(distIv);return;}
      document.body.style.transform=`skewX(${(Math.random()-.5)*25*mag}deg) translate(${(Math.random()-.5)*60*mag}px,${(Math.random()-.5)*18*mag}px) scale(${1+(Math.random()-.5)*.06*mag})`;
    },28);
  }
  function stopDistort(){ clearInterval(distIv); document.body.style.transform=''; }

  // ── 1. Texte normal qui glitche → "TU N'AURAIS PAS DU VOIR CA" ──
  const wEl=document.createElement('div');
  wEl.style.cssText='position:fixed;inset:0;z-index:201;display:flex;align-items:center;justify-content:center;pointer-events:none;';
  wEl.innerHTML=`<div id="wtxt" style="font-family:Share Tech Mono,monospace;font-size:clamp(10px,1.5vw,14px);color:rgba(255,255,255,.35);letter-spacing:.3em;text-align:center;">CHARGEMENT DU SYSTEME...</div>`;
  document.body.appendChild(wEl);
  await wait(500);
  if(!introRunning){wEl.remove();overlay.remove();redFlash.remove();noiseCanvas.remove();throw 'skipped';}

  // Glitch du texte
  const wtxt=wEl.querySelector('#wtxt');
  for(let i=0;i<7;i++){
    await wait(55);
    wtxt.style.transform=`translate(${(Math.random()-.5)*40}px,${(Math.random()-.5)*12}px) skewX(${(Math.random()-.5)*25}deg)`;
    wtxt.style.color=i%2===0?'#FF0000':'rgba(255,255,255,.5)';
    wtxt.style.filter=`blur(${Math.random()*5}px)`;
    redFlash.style.opacity=String(Math.random()*.25);
    playGlitch();
  }
  // Reveal du vrai message
  wtxt.style.cssText=`font-family:Orbitron,monospace;font-size:clamp(18px,3.5vw,42px);font-weight:900;color:#FF0000;letter-spacing:.12em;text-align:center;text-shadow:0 0 30px #FF0000,0 0 60px rgba(255,0,0,.5);transform:none;filter:none;`;
  wtxt.textContent="TU N'AURAIS PAS DU VOIR CA";
  playScream();
  redFlash.style.opacity='.35';
  shakeDoc(15,300);
  await wait(120);
  redFlash.style.opacity='0';

  // ── 2. MICRO SILENCE ──
  await wait(300);
  if(!introRunning){wEl.remove();overlay.remove();redFlash.remove();noiseCanvas.remove();throw 'skipped';}

  // ── 3. GLITCH ULTRA VIOLENT ──
  playStatic(700);
  startDistort(2);
  noiseCanvas.style.opacity='.55';
  let noiseIv=setInterval(drawNoise,28);
  redFlash.style.opacity='.3';

  // Canvas de déchirure
  const tearC=document.createElement('canvas');
  tearC.style.cssText='position:fixed;inset:0;z-index:199;pointer-events:none;';
  tearC.width=W;tearC.height=H;
  document.body.appendChild(tearC);
  const tCtx=tearC.getContext('2d');
  let tearIv=setInterval(()=>{
    tCtx.clearRect(0,0,W,H);
    for(let i=0;i<10;i++){
      const y=Math.random()*H,h=2+Math.random()*25,off=(Math.random()-.5)*100;
      tCtx.drawImage(bgC,0,y,W,h,off,y,W,h);
      tCtx.fillStyle=`rgba(255,${Math.floor(Math.random()*40)},0,${.08+Math.random()*.15})`;
      tCtx.fillRect(0,y,W,h);
    }
  },32);

  await wait(350);
  wEl.remove();

  // ── 4. INTRUSION DETECTEE ──
  overlay.style.background='rgba(0,0,0,.93)';
  overlay.innerHTML=`
    <div id="ctitle" style="font-family:Orbitron,monospace;font-size:clamp(22px,5vw,58px);font-weight:900;color:#FF0000;letter-spacing:.12em;text-align:center;text-shadow:0 0 40px #FF0000,0 0 80px rgba(255,0,0,.5);margin-bottom:28px;opacity:0;">
      INTRUSION DETECTEE
    </div>
    <div style="font-family:Share Tech Mono,monospace;font-size:clamp(9px,1.3vw,13px);color:rgba(255,60,60,.85);letter-spacing:.2em;line-height:2.4;text-align:left;max-width:min(520px,82vw);">
      <div class="cl" style="opacity:0">&gt; Acces non autorise au systeme...</div>
      <div class="cl" style="opacity:0">&gt; Tentative de controle detectee...</div>
      <div class="cl" style="opacity:0">&gt; Tracage en cours...</div>
      <div class="cl" style="opacity:0;color:rgba(255,200,0,.9)">&gt; Localisation : <span id="lspan">_</span></div>
      <div class="cl" id="stvous" style="opacity:0;font-family:Orbitron,monospace;font-size:clamp(16px,3vw,34px);font-weight:900;color:#FF0000;text-shadow:0 0 20px #FF0000;margin-top:16px;">&gt; ON TE VOIT</div>
    </div>
  `;

  const ctitle=overlay.querySelector('#ctitle');
  await tween(200,easeOutExpo,e=>ctitle.style.opacity=String(e));
  playGlitch();

  const cls=overlay.querySelectorAll('.cl');
  for(let i=0;i<cls.length-1;i++){
    await wait(170);
    if(!introRunning) break;
    cls[i].style.opacity='1'; playGlitch();
    if(i===3){
      const lsp=overlay.querySelector('#lspan');
      const addr='192.168.'+Math.floor(Math.random()*255)+'.'+Math.floor(Math.random()*255);
      let idx=0;
      const liv=setInterval(()=>{
        if(idx>addr.length){clearInterval(liv);return;}
        lsp.textContent=addr.slice(0,idx)+(idx<addr.length?'█':'');idx++;
      },55);
      await wait(550);
    }
  }

  await wait(180);

  // ── 5. ON TE VOIT ──
  const stvous=overlay.querySelector('#stvous');
  playScream();
  startDistort(2.5);
  for(let i=0;i<6;i++){
    await wait(55);
    stvous.style.opacity=i%2===0?'1':'0';
    stvous.style.transform=`translate(${(Math.random()-.5)*25}px,${(Math.random()-.5)*10}px)`;
    redFlash.style.opacity=String(.15+Math.random()*.35);
  }
  stvous.style.opacity='1'; stvous.style.transform='';

  // ── 6. COUPER LE SON ──
  await wait(200);

  // ── 7. FREEZE 2s ──
  stopDistort();
  clearInterval(noiseIv); clearInterval(tearIv);
  noiseCanvas.style.opacity='0'; tearC.style.opacity='0';
  redFlash.style.opacity='.04';
  document.body.style.transform='skewX(1.5deg) translateX(5px)';
  await wait(2000);

  // ── 8. ECRAN NOIR ──
  if(!introRunning){overlay.remove();redFlash.remove();noiseCanvas.remove();tearC.remove();throw 'skipped';}
  document.body.style.transform='';
  await tween(200,t=>t,e=>{ overlay.style.background=`rgba(0,0,0,${.93+e*.07})`; });
  overlay.innerHTML=''; overlay.style.background='#000'; redFlash.style.opacity='0';
  await wait(250);

  // ── REPRISE : IMPACT MASSIF ──
  playImpact(); playImpact();
  flashW(1,700); shakeDoc(35,800); glitchEffect(400);
  overlay.remove(); redFlash.remove(); noiseCanvas.remove(); tearC.remove();
  await wait(250);
}

// ══════════════════════════
// INTRO SEQUENCE
// ══════════════════════════
let introRunning=true;

async function playIntro(){
  introRunning=true;
  // Afficher le skip maintenant que l'intro commence
  const sk=document.getElementById('skip-btn');
  if(sk) sk.style.display='block';
  if(AC.state==='suspended') await AC.resume().catch(()=>{});
  const guard = async (ms) => { if(!introRunning) throw 'skipped'; await wait(ms); };

  const cin1=document.getElementById('cin1');
  const cin2=document.getElementById('cin2');
  const cin3=document.getElementById('cin3');
  const btcSym=document.getElementById('btc-symbol');
  const logoFinal=document.getElementById('logo-final');
  const logoH1=document.getElementById('logo-h1');
  const logoSmoke=document.getElementById('logo-smoke');
  const tag1=document.getElementById('tag1');
  const tag2=document.getElementById('tag2');
  const codeStream=document.getElementById('code-stream');

  // ── 0. NOIR TOTAL + battement de coeur ──
  await guard(500);
  startHeartbeat();
  await guard(1200);

  // ── 1. "Le monde tourne autour de l'argent…" ──
  await tween(1200,easeOut,e=>{cin1.style.opacity=String(e);cin1.style.letterSpacing=`${.04+e*.04}em`;});
  await guard(2200);
  await tween(700,easeIn,e=>cin1.style.opacity=String(1-e));

  // ── 2. GLITCH + "Mais le système peut s'effondrer." ──
  glitchEffect(300);
  flashW(.12,200);
  await guard(350);
  await tween(1000,easeOut,e=>{cin2.style.opacity=String(e);cin2.style.letterSpacing=`${.04+e*.04}em`;});
  await guard(2000);
  await tween(600,easeIn,e=>cin2.style.opacity=String(1-e));

  // ── 2.5. PLANS RAPIDES : billets, banques, graphiques crypto ──
  await playRapidScenes();

  // ── 3. SILENCE ──
  stopHeartbeat();
  await guard(800);

  // ── FAKE CRASH ──
  await fakeCrash();

  // ── 4. "Une nouvelle ère commence." apparaît d'abord ──
  await tween(900,easeOut,e=>{cin3.style.opacity=String(e);cin3.style.letterSpacing=`${.04+e*.06}em`;});
  await guard(600);

  // ── 5. LOGO ₿ SURGIT PAR DESSUS et cache le texte ──
  // Positionner le ₿ en bas au départ, puis le faire monter pour couvrir le texte
  btcSym.style.transform='scale(0) translateY(120px)';
  btcSym.style.position='absolute';
  btcSym.style.zIndex='25';
  await tween(1000,easeOutElastic,e=>{
    btcSym.style.opacity=String(Math.min(1,e));
    btcSym.style.transform=`scale(${.2+e*.8}) translateY(${120*(1-e)}px)`;
    btcSym.style.filter=`drop-shadow(0 0 ${e*50}px #FFD700)`;
    // Le texte disparaît progressivement derrière le logo
    cin3.style.opacity=String(Math.max(0,1-e*2));
  });
  cin3.style.opacity='0';
  await guard(1200);

  // ── 6. MONTÉE ÉPIQUE ── warp + code stream ──
  playEpicSwell();
  warpSpd=6;bgA=.35;nebulaA=1;
  await tween(400,easeIn,e=>codeStream.style.opacity=String(e*.4));
  glitchEffect(200);
  flashW(.2,300);

  await tween(800,easeIn,e=>{
    btcSym.style.opacity=String(1-e);
    cin3.style.opacity=String(1-e);
    warpSpd=6+e*50;bgA=.35+e*.3;
  });

  btcSym.style.opacity='0';cin3.style.opacity='0';

  // ── 7. TUNNEL DE DONNÉES ──
  nebulaA=3;warpSpd=80;bgA=.6;
  await guard(1500);

  // ── 8. GROS IMPACT ──
  playImpact();
  flashW(1,.600);
  shakeDoc(25,700);
  warpSpd=0;bgA=.18;nebulaA=1.5;
  glitchEffect(400);
  explodeParticles(W/2,H/2,80);
  shockRing(W/2,H/2,'#00FF88',Math.min(W,H)*.8);
  shockRing(W/2,H/2,'#00D4FF',Math.min(W,H)*.6);

  await guard(400);
  await tween(400,easeOut,e=>codeStream.style.opacity=String(.4*(1-e)));
  codeStream.style.opacity='0';

  // ── 9. LOGO "CRYPTO MINER" ──
  logoFinal.style.opacity='1';logoFinal.style.transform='scale(1) translateY(0)';
  logoH1.textContent='';logoH1.style.opacity='1';
  logoSmoke.style.opacity='.8';

  await tween(700,easeOutExpo,e=>logoSmoke.style.opacity=String(.8*(1-e)),200);
  await glitchText(logoH1,'CRYPTO MINER',700);

  flashG(.3,400);
  shakeDoc(10,400);
  explodeParticles(W/2,H/2,40);

  // TAGLINES
  await tween(800,easeOut,e=>tag1.style.opacity=String(e),200);
  await tween(600,easeOut,e=>tag2.style.opacity=String(e),300);

  nebulaA=.8;
  setCorners(1);

  await guard(1500);

  // ── 10. LOGO → PARTICULES → LANG ──
  glitchEffect(500);
  await tween(500,easeIn,e=>{
    logoFinal.style.opacity=String(1-e);
    logoFinal.style.transform=`scale(${1+e*.3})`;
    logoFinal.style.filter=`blur(${e*20}px)`;
  });
  logoFinal.style.opacity='0';

  await guard(200);
  showMenu();
}

// ══════════════════════════
// LANG SCREEN
// ══════════════════════════
function showLangFirst() {
  // Cacher le skip pendant le choix de langue
  const sk=document.getElementById('skip-btn');
  if(sk) sk.style.display='none';
  const ls = document.getElementById('lang-screen');
  ls.style.pointerEvents = 'all';
  tween(1000, easeOutElastic, e => {
    ls.style.opacity = String(Math.min(1, e));
    ls.style.transform = `scale(${.9 + e * .1})`;
  });
}

function showLang(){
  const ls=document.getElementById('lang-screen');
  ls.style.pointerEvents='all';
  tween(800,easeOutElastic,e=>{
    ls.style.opacity=String(Math.min(1,e));
    ls.style.transform=`scale(${.9+e*.1})`;
  });
  playClick();
}

function selectLang(code){
  currentLang = code;
  applyTranslations();
  playClick();
  AC.resume().catch(()=>{});
  flashW(.15,200);
  glitchEffect(250);
  const ls=document.getElementById('lang-screen');
  tween(500,easeIn,e=>{ls.style.opacity=String(1-e);ls.style.transform=`scale(${1+e*.05})`;});
  setTimeout(()=>{
    ls.style.pointerEvents='none';
    showDisclaimerIntro(); // affiche le disclaimer, l'intro se lance depuis closeDisclaimerIntro()
  },500);
}

function showDisclaimerIntro() {
  const texts = {
    fr: { title:'⚠️ AVERTISSEMENT', btn:'✓  J\'AI COMPRIS — COMMENCER', html:'<strong style="color:#E8F0FF">CRYPTO MINER</strong> est un jeu de simulation <strong style="color:#E8F0FF">100% fictif</strong>.<br><br>Les Bitcoin, cryptomonnaies, marchés, rivaux, événements et prix affichés sont <strong style="color:#E8F0FF">entièrement imaginaires</strong> et ne reflètent pas la réalité.<br><br>Ce jeu ne constitue <strong style="color:#E8F0FF">pas un conseil financier</strong>.<br><br>L\'intro, les personnages et les scénarios sont <strong style="color:#E8F0FF">purement fictifs</strong>.' },
    en: { title:'⚠️ DISCLAIMER',    btn:'✓  I UNDERSTAND — START',      html:'<strong style="color:#E8F0FF">CRYPTO MINER</strong> is a <strong style="color:#E8F0FF">100% fictional</strong> simulation game.<br><br>All Bitcoin, cryptocurrencies, markets, rivals, events and prices are <strong style="color:#E8F0FF">entirely imaginary</strong>.<br><br>This game does <strong style="color:#E8F0FF">not constitute financial advice</strong>.<br><br>The intro and scenarios are <strong style="color:#E8F0FF">purely fictional</strong>.' },
    es: { title:'⚠️ AVISO',         btn:'✓  ENTENDIDO — COMENZAR',      html:'<strong style="color:#E8F0FF">CRYPTO MINER</strong> es un juego <strong style="color:#E8F0FF">100% ficticio</strong>.<br><br>Los Bitcoin, mercados y precios son <strong style="color:#E8F0FF">completamente imaginarios</strong>.<br><br>Este juego <strong style="color:#E8F0FF">no es consejo financiero</strong>.<br><br>La intro y personajes son <strong style="color:#E8F0FF">puramente ficticios</strong>.' },
    ar: { title:'⚠️ تنبيه',         btn:'✓  فهمت — ابدأ',               html:'<strong style="color:#E8F0FF">CRYPTO MINER</strong> لعبة <strong style="color:#E8F0FF">خيالية 100%</strong>.<br><br>جميع العملات والأسواق <strong style="color:#E8F0FF">خيالية تمامًا</strong>.<br><br>هذه اللعبة <strong style="color:#E8F0FF">ليست نصيحة مالية</strong>.' },
    pt: { title:'⚠️ AVISO',         btn:'✓  ENTENDI — COMEÇAR',         html:'<strong style="color:#E8F0FF">CRYPTO MINER</strong> é um jogo <strong style="color:#E8F0FF">100% fictício</strong>.<br><br>Todos os Bitcoin e mercados são <strong style="color:#E8F0FF">completamente imaginários</strong>.<br><br>Este jogo <strong style="color:#E8F0FF">não é conselho financeiro</strong>.' },
  };
  const t = texts[currentLang] || texts.fr;
  const overlay = document.getElementById('disclaimer-intro');
  if (!overlay) { playIntro().catch(e=>{ if(e!=='skipped') console.warn(e); }); return; }
  const titleEl = document.getElementById('di-title');
  const textEl  = document.getElementById('di-text');
  const btnEl   = document.getElementById('di-btn');
  if (titleEl) titleEl.textContent = t.title;
  if (textEl)  textEl.innerHTML    = t.html;
  if (btnEl)   btnEl.textContent   = t.btn;
  overlay.style.display = 'flex';
}

function closeDisclaimerIntro() {
  const overlay = document.getElementById('disclaimer-intro');
  if (overlay) overlay.style.display = 'none';
  playIntro().catch(e=>{ if(e!=='skipped') console.warn(e); });
}

// ══════════════════════════
// MENU
// ══════════════════════════
function showMenu(){
  // Cacher le bouton skip
  const sk=document.getElementById('skip-btn');
  if(sk) sk.style.display='none';
  const ms=document.getElementById('menu-screen');
  ms.style.pointerEvents='all';
  nebulaA=.6;
  tween(900,easeOutElastic,e=>{
    ms.style.opacity=String(Math.min(1,e));
    ms.style.transform=`scale(${.92+e*.08})`;
  });
  flashG(.15,400);
  playClick();
}

function startGame(){
  playClick();
  flashW(.6,400);
  shakeDoc(8,400);
  warpSpd=25;

  setTimeout(()=>{
    document.body.style.transition='opacity .55s ease';
    document.body.style.opacity='0';

    setTimeout(()=>{
      // Arrêter les canvas/animations de l'intro
      warpSpd=0;
      ['layer-bg','layer-fx','layer-glitch','tunnel','scanlines','vignette',
       'flash','flash-green','code-stream','intro','lang-screen','menu-screen',
       'options-screen','quit-popup','skip-btn'].forEach(id=>{
        const el=document.getElementById(id);
        if(el){ el.style.display='none'; el.style.visibility='hidden'; }
      });
      document.querySelectorAll('.corner,.float-particle').forEach(el=>el.remove());

      // Transmettre la langue au jeu
      localStorage.setItem('cm_lang', currentLang);
      if(typeof applyLang==='function') applyLang(currentLang);

      // Fond propre
      document.body.style.background='#080C14';

      // Afficher le wrapper jeu
      const gw=document.getElementById('game-wrapper');
      if(gw){ gw.style.display='flex'; gw.style.flexDirection='column'; }

      // Masquer les overlays internes du jeu
      ['lang-overlay','intro-overlay'].forEach(id=>{
        const el=document.getElementById(id);
        if(el) el.classList.add('hidden');
      });

      // Fade in
      requestAnimationFrame(()=>{
        document.body.style.opacity='0';
        requestAnimationFrame(()=>{
          document.body.style.transition='opacity .65s ease';
          document.body.style.opacity='1';
          setTimeout(()=>{
            if(typeof startTuto==='function'&&!localStorage.getItem('cm_tuto_done')) startTuto();
          },900);
        });
      });
    },550);
  },700);
}

function showOptions(){
  playClick();
  const o=document.getElementById('options-screen');
  o.style.pointerEvents='all';
  tween(400,easeOut,e=>o.style.opacity=String(e));
}
function hideOptions(){
  playClick();
  const o=document.getElementById('options-screen');
  tween(300,easeIn,e=>o.style.opacity=String(1-e)).then(()=>o.style.pointerEvents='none');
}

function showQuit(){
  playClick();
  const q=document.getElementById('quit-popup');
  q.style.pointerEvents='all';
  tween(400,easeOutElastic,e=>{q.style.opacity=String(Math.min(1,e));q.style.transform=`scale(${.9+e*.1})`;});
}
function hideQuit(){
  playClick();
  const q=document.getElementById('quit-popup');
  tween(300,easeIn,e=>{q.style.opacity=String(1-e);q.style.transform=`scale(${1+e*.05})`;}).then(()=>q.style.pointerEvents='none');
}
function confirmQuit(){
  playClick();flashW(1,.5);
  setTimeout(()=>{ document.body.innerHTML='<div style="display:flex;align-items:center;justify-content:center;height:100vh;font-family:monospace;color:#2a3a56;font-size:12px;letter-spacing:.3em">FERME CET ONGLET</div>'; },500);
}

function setVol(type,val){ /* connecter au moteur audio du jeu */ }
function selectLangOpt(code){ playClick(); }

// ══════════════════════════
// SKIP
// ══════════════════════════
function skipIntro(){
  introRunning=false;
  stopHeartbeat();
  warpSpd=0; bgA=.18; nebulaA=.3;

  // Stop all intro animations
  const intro=document.getElementById('intro');
  if(intro){ intro.style.opacity='0'; intro.style.pointerEvents='none'; intro.style.display='none'; }
  const lf=document.getElementById('logo-final');
  if(lf){ lf.style.opacity='0'; lf.style.display='none'; }
  // Hide canvas extras
  document.querySelectorAll('canvas:not(#layer-bg):not(#layer-fx):not(#layer-glitch)').forEach(c=>{
    if(c.id!=='layer-bg'&&c.id!=='layer-fx'&&c.id!=='layer-glitch') c.style.display='none';
  });
  document.querySelectorAll('.debris,.float-particle').forEach(d=>d.remove());
  document.getElementById('flash').style.opacity='0';
  document.getElementById('flash-green').style.opacity='0';
  document.getElementById('layer-glitch').style.opacity='0';
  const sk=document.getElementById('skip-btn');
  if(sk) sk.style.display='none';

  glitchEffect(200);
  flashW(.3,300);
  setTimeout(()=>{ setCorners(1); showMenu(); },350);
}

// ══════════════════════════
// INIT
// ══════════════════════════
spawnFloatParticles();
document.addEventListener('click',()=>AC.resume().catch(()=>{}),{once:true});

// Choix de langue EN PREMIER avant l'intro
showLangFirst();
</script>

